generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- MODÈLES UTILISATEURS ---

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String   @unique
  name      String?
  role      UserRole @default(TENANT) // [cite: 2]
  password  String
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true) 
  resetPasswordToken   String?
  resetPasswordExpires DateTime? // [cite: 3]
  
  // FINANCES
  walletBalance Int    @default(0) // Argent disponible
  escrowBalance Int    @default(0) // Argent bloqué (Cautions)

  // Relations
  properties        Property[]          @relation("OwnerProperties")
  leasesAsTenant    Lease[]             @relation("TenantLeases")
  reportedIncidents Incident[]          @relation("Reporter")
  leads             Lead[]              @relation("AgentLeads") // [cite: 4]
  transactions      CreditTransaction[] 
  withdrawals       Withdrawal[]        // Relation ajoutée
  
  // RELATIONS SYSTÈME
  pushSubscriptions PushSubscription[] // Notifications Push
  activityLogs      ActivityLog[]      // Logs d'activité
}

enum UserRole {
  OWNER
  TENANT
  ADMIN
  AGENT
}

// --- TRAÇABILITÉ DE L'ARGENT ---

model CreditTransaction {
  id          String   @id @default(cuid())
  amount      Int      
  description String   
  
  date        DateTime @default(now()) // [cite: 5]
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

// --- MODÈLES IMMOBILIERS ---

model Property {
  id        String   @id @default(cuid())
  title     String
  address   String
  commune   String
  price     Int      
  createdAt DateTime @default(now())
  
  // Modification : Support de plusieurs images (Array) au lieu d'une seule String
  images    String[] 

  ownerId   String // 
  owner     User     @relation("OwnerProperties", fields: [ownerId], references: [id])

  leases    Lease[]
  incidents Incident[]
  expenses  Expense[]
  candidates Candidate[]
}

model Lease {
  id            String    @id @default(cuid())
  startDate     DateTime
  endDate       DateTime?
  depositAmount Int        // [cite: 7]
  monthlyRent   Int       
  isActive      Boolean   @default(true)

  tenantId      String
  tenant        User      @relation("TenantLeases", fields: [tenantId], references: [id])

  propertyId    String
  property      Property  @relation(fields: [propertyId], references: [id])

  payments      Payment[]
  inventories   Inventory[]
}

// --- FINANCES, INCIDENTS ET ÉTAT DES LIEUX ---

model Payment { // [cite: 8]
  id        String   @id @default(cuid())
  amount    Int      
  date      DateTime @default(now())
  month     String
  type      String   @default("LOYER")
  
  leaseId   String
  lease     Lease    @relation(fields: [leaseId], references: [id])
}

model Incident {
  id          String   @id @default(cuid())
  title       String   // [cite: 9]
  description String
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  createdAt   DateTime @default(now())
  
  reporterId  String
  reporter    User     @relation("Reporter", fields: [reporterId], references: [id])

  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Int      // [cite: 10]
  
  date        DateTime @default(now())
  category    String
  
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
}

model Inventory {
  id             String   @id @default(cuid())
  type           String
  date           DateTime @default(now())
  
  kitchenState   String?
  kitchenPhoto   String? // [cite: 11]
  livingState    String?
  livingPhoto    String?
  bathState      String? // [cite: 12]
  bathPhoto      String?
  generalComment String?
  leaseId        String // [cite: 13]
  lease          Lease    @relation(fields: [leaseId], references: [id])
}

// --- GESTION DES PROSPECTS (LEADS) ET CANDIDATS ---

model Lead {
  id          String   @id @default(cuid())
  name        String
  phone       String
  address     String?
  photo       String? // [cite: 14]
  status      String   @default("NOUVEAU")
  createdAt   DateTime @default(now())
  
  agentId     String?
  agent       User?    @relation("AgentLeads", fields: [agentId], references: [id]) // [cite: 15]
}

model Candidate {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String
  income      Int      
  status      String   @default("PENDING")
  score       Int
  createdAt   DateTime @default(now())
  
  propertyId  String // [cite: 16]
  property    Property @relation(fields: [propertyId], references: [id])
}

// --- MODÈLE ARTISAN ---

model Artisan {
  id          String   @id @default(uuid())
  name        String
  job         String   
  phone       String
  location    String   
  isVerified  Boolean  @default(true)
  rating      Float    @default(5.0)
  createdAt   DateTime @default(now()) // [cite: 17]
}

// --- SYSTÈME DE NOTIFICATIONS (WEB PUSH) ---

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique 
  keys      Json     
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade) 
}

// --- LOGS D'ACTIVITÉ ---

model ActivityLog { // [cite: 18]
  id        String   @id @default(cuid())
  action    String   
  category  String  
  metadata  Json?
  createdAt DateTime @default(now()) // [cite: 19]
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id]) // [cite: 20]
}

// --- MODÈLE DE RETRAIT ---

model Withdrawal {
  id        String   @id @default(cuid())
  amount    Int
  details   String   // Numéro ou RIB
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
}
