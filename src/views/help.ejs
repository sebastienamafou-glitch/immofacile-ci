                            <a href="https://wa.me/2250707070707" target="_blank" class="w-full bg-[#25D366] text-[#0B1120] py-3 rounded-xl font-bold hover:bg-[#20bd5a] transition">
                                Ouvrir WhatsApp
                            </a>
                        </div>
                    
