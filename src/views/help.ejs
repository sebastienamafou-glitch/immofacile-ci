                                </div>
                            </details>

                            <details class="search-item group glass-panel rounded-2xl open:bg-slate-900/80 transition-colors duration-300">
                                <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-white text-base">
                                    <span class="search-text">La signature WhatsApp est-elle légale ?</span>
                                    <span class="transition group-open:rotate-180">
                                        <i class="ph-bold ph-caret-down text-blue-500"></i>
                                    </span>
