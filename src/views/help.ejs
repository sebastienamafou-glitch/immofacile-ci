<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Centre d'Aide | ImmoFacile CI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass-card {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
    </style>
</head>
<body class="bg-[#0B1120] text-slate-200 antialiased min-h-screen">

    <main class="max-w-3xl mx-auto p-4 md:p-8 pb-24">
        
        <header class="mb-10">
            <a href="/owner/dashboard" class="inline-flex items-center gap-2 text-slate-400 text-xs font-bold mb-6 hover:text-white transition group bg-slate-800/50 px-4 py-2 rounded-full border border-slate-700 hover:border-slate-500">
                <span class="group-hover:-translate-x-1 transition-transform">←</span> Retour au Tableau de bord
            </a>
            
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
                <div>
                    <h1 class="text-3xl md:text-4xl font-extrabold text-white">Centre d'Aide <span class="text-[#F59E0B]">.</span></h1>
                    <p class="text-slate-400 mt-2 text-sm font-medium">Documentation, support et statistiques.</p>
                </div>
                <img src="/images/immo_logo.png" alt="Logo" class="h-12 w-auto opacity-80">
            </div>
        </header>
    
        <section class="mb-12">
            <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4 flex items-center gap-2">
                <span>📊</span> Votre Impact
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
                    <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition transform group-hover:scale-110">
                        <span class="text-6xl">🔐</span>
                    </div>
                    <p class="text-3xl font-black text-blue-500">
                        <%= (statsActions && statsActions.reminders) || 0 %>
                    </p>
                    <p class="text-xs text-slate-400 font-bold uppercase mt-1">Accès Partagés</p>
                </div>

                <div class="glass-card p-6 rounded-2xl relative overflow-hidden group border-orange-500/20">
                    <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition transform group-hover:scale-110">
                        <span class="text-6xl">💰</span>
                    </div>
                    <p class="text-3xl font-black text-[#F59E0B]">
                        <%= (statsActions && statsActions.rentCollected ? statsActions.rentCollected : 0).toLocaleString('fr-FR') %>
                        <span class="text-xs text-slate-500 font-normal">FCFA</span>
                    </p>
                    <p class="text-xs text-slate-400 font-bold uppercase mt-1">Loyers Sécurisés</p>
                </div>

                <div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
                    <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition transform group-hover:scale-110">
                        <span class="text-6xl">📝</span>
                    </div>
                    <p class="text-3xl font-black text-green-500">
                        <%= (statsActions && statsActions.inventory) || 0 %>
                    </p>
                    <p class="text-xs text-slate-400 font-bold uppercase mt-1">États des lieux</p>
                </div>
            </div>
        </section>

        <section class="mb-12">
            <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4 flex items-center gap-2">
                <span>🚀</span> Guides Rapides
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-slate-900 border border-slate-800 p-5 rounded-2xl flex gap-4 items-start">
                    <div class="bg-blue-500/10 text-blue-400 p-3 rounded-xl text-xl">👤</div>
                    <div>
                        <h4 class="font-bold text-white text-sm">Ajouter un Locataire</h4>
                        <p class="text-xs text-slate-400 mt-1 leading-relaxed">
                            Allez dans "Locataires" > "Ajouter". Le système génère automatiquement un mot de passe et vous permet de l'envoyer par WhatsApp.
                        </p>
                    </div>
                </div>
                
                <div class="bg-slate-900 border border-slate-800 p-5 rounded-2xl flex gap-4 items-start">
                    <div class="bg-red-500/10 text-red-400 p-3 rounded-xl text-xl">🚨</div>
                    <div>
                        <h4 class="font-bold text-white text-sm">Gérer une Urgence</h4>
                        <p class="text-xs text-slate-400 mt-1 leading-relaxed">
                            Si un locataire signale un incident, vous recevez une notif. Cliquez sur "Résoudre" une fois l'artisan intervenu.
                        </p>
                    </div>
                </div>

                <div class="bg-slate-900 border border-slate-800 p-5 rounded-2xl flex gap-4 items-start">
                    <div class="bg-orange-500/10 text-orange-400 p-3 rounded-xl text-xl">💸</div>
                    <div>
                        <h4 class="font-bold text-white text-sm">Encaisser un Loyer</h4>
                        <p class="text-xs text-slate-400 mt-1 leading-relaxed">
                            Bouton "Encaisser" sur la carte du bien. Assurez-vous d'avoir au moins 5% du montant sur votre solde Wallet.
                        </p>
                    </div>
                </div>

                <div class="bg-slate-900 border border-slate-800 p-5 rounded-2xl flex gap-4 items-start">
                    <div class="bg-purple-500/10 text-purple-400 p-3 rounded-xl text-xl">📂</div>
                    <div>
                        <h4 class="font-bold text-white text-sm">Documents</h4>
                        <p class="text-xs text-slate-400 mt-1 leading-relaxed">
                            Contrats et Quittances sont générés automatiquement en PDF. Retrouvez-les dans l'onglet "Documents".
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <section class="space-y-4">
            <h2 class="text-xl font-black mb-6 text-white flex items-center gap-2">
                ❓ Questions Fréquentes
            </h2>
            
            <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden hover:border-slate-700 transition">
                <button onclick="toggleFaq('faq-1', 'icon-1')" class="w-full p-5 text-left flex justify-between items-center group">
                    <span class="font-bold text-sm text-slate-200 group-hover:text-white transition">Comment recharger mon solde ?</span>
                    <span id="icon-1" class="text-slate-500 font-bold text-lg transition">＋</span>
                </button>
                <div id="faq-1" class="hidden p-5 pt-0 text-sm text-slate-400 border-t border-slate-800 bg-slate-900/50">
                    Cliquez sur le bouton orange <strong>"Recharger"</strong> dans le tableau de bord. Le paiement est sécurisé par CinetPay (Mobile Money, Carte). Le solde est mis à jour instantanément.
                </div>
            </div>

            <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden hover:border-slate-700 transition">
                <button onclick="toggleFaq('faq-2', 'icon-2')" class="w-full p-5 text-left flex justify-between items-center group">
                    <span class="font-bold text-sm text-slate-200 group-hover:text-white transition">Pourquoi mon séquestre est à 0 ?</span>
                    <span id="icon-2" class="text-slate-500 font-bold text-lg transition">＋</span>
                </button>
                <div id="faq-2" class="hidden p-5 pt-0 text-sm text-slate-400 border-t border-slate-800 bg-slate-900/50">
                    Le séquestre ne compte que les <strong>cautions réellement encaissées</strong> lors de la création d'un bail. Si vous avez ajouté vos biens manuellement sans passer par la procédure "Ajouter Locataire", le montant peut être à 0.
                </div>
            </div>

            <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden hover:border-slate-700 transition">
                <button onclick="toggleFaq('faq-3', 'icon-3')" class="w-full p-5 text-left flex justify-between items-center group">
                    <span class="font-bold text-sm text-slate-200 group-hover:text-white transition">Un locataire peut-il voir mes autres biens ?</span>
                    <span id="icon-3" class="text-slate-500 font-bold text-lg transition">＋</span>
                </button>
                <div id="faq-3" class="hidden p-5 pt-0 text-sm text-slate-400 border-t border-slate-800 bg-slate-900/50">
                    <strong>Non.</strong> Chaque locataire a un accès strictement limité à son propre contrat, ses quittances et l'état des lieux de son logement. La confidentialité est totale.
                </div>
            </div>
            
            <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden hover:border-slate-700 transition">
                <button onclick="toggleFaq('faq-4', 'icon-4')" class="w-full p-5 text-left flex justify-between items-center group">
                    <span class="font-bold text-sm text-slate-200 group-hover:text-white transition">Comment terminer un bail ?</span>
                    <span id="icon-4" class="text-slate-500 font-bold text-lg transition">＋</span>
                </button>
                <div id="faq-4" class="hidden p-5 pt-0 text-sm text-slate-400 border-t border-slate-800 bg-slate-900/50">
                    Allez dans "Mes Biens", cliquez sur le bouton <strong>"Sortie"</strong> du bien concerné. Vous pourrez alors saisir les éventuelles retenues sur caution pour travaux. Le bien repassera automatiquement en "Vacant".
                </div>
            </div>
        </section>

        <footer class="mt-12 p-8 bg-gradient-to-br from-blue-900/20 to-slate-900 rounded-3xl border border-blue-500/30 text-center shadow-2xl">
            <p class="font-bold text-lg mb-2 text-white">Besoin d'aide technique ?</p>
            <p class="text-slate-400 text-sm mb-6">Notre équipe support est disponible 7j/7 sur WhatsApp.</p>
            
            <a href="https://wa.me/2250707070707" target="_blank" class="inline-flex items-center gap-3 bg-[#25D366] text-[#0B1120] px-6 py-3 rounded-xl font-bold hover:bg-[#20bd5a] transition hover:scale-105">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                Contacter le Support
            </a>
        </footer>
    </main>

    <script>
        function toggleFaq(contentId, iconId) {
            const content = document.getElementById(contentId);
            const icon = document.getElementById(iconId);
            
            if (content.classList.contains('hidden')) {
                content.classList.remove('hidden');
                icon.innerText = '－';
                icon.classList.add('text-[#F59E0B]');
            } else {
                content.classList.add('hidden');
                icon.innerText = '＋';
                icon.classList.remove('text-[#F59E0B]');
            }
        }
    </script>
</body>
</html>
