<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Centre d'Aide & Support | ImmoFacile CI</title>
    
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0B1120">

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass-panel {
            background: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        /* Animation pour le badge système */
        @keyframes pulse-green {
            0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
            70% { box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
            100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
        }
        .status-dot { animation: pulse-green 2s infinite; }
    </style>
</head>
<body class="bg-[#0B1120] text-slate-200 antialiased min-h-screen pb-12">

    <header class="relative bg-gradient-to-b from-blue-900/20 to-[#0B1120] pt-10 pb-16 px-6 border-b border-white/5">
        <div class="max-w-4xl mx-auto text-center relative z-10">
            <a href="/owner/dashboard" class="inline-flex items-center gap-2 text-slate-400 hover:text-white transition text-sm font-bold mb-6 bg-white/5 px-4 py-1.5 rounded-full">
                <i class="ph-bold ph-arrow-left"></i> Retour Dashboard
            </a>
            
            <h1 class="text-3xl md:text-5xl font-black text-white mb-4 tracking-tight">Comment pouvons-nous vous aider ?</h1>
            <p class="text-slate-400 mb-8 max-w-xl mx-auto">Documentation, tutoriels et assistance technique pour gérer vos biens immobiliers.</p>

            <div class="relative max-w-lg mx-auto group">
                <i class="ph-bold ph-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl group-focus-within:text-[#F59E0B] transition"></i>
                <input type="text" id="helpSearch" onkeyup="filterHelp()" placeholder="Rechercher une réponse (ex: caution, contrat...)" 
                       class="w-full bg-slate-800/80 border border-slate-700 rounded-2xl py-4 pl-12 pr-4 text-white placeholder-slate-500 focus:outline-none focus:border-[#F59E0B] focus:ring-1 focus:ring-[#F59E0B] transition shadow-2xl">
            </div>
        </div>

        <div class="absolute top-0 right-0 w-64 h-64 bg-[#F59E0B]/10 rounded-full blur-3xl -mr-16 -mt-16 pointer-events-none"></div>
    </header>

    <main class="max-w-6xl mx-auto px-4 md:px-6 -mt-8 relative z-20">
        
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            
            <aside class="hidden lg:block lg:col-span-3">
                <div class="sticky top-8 space-y-6">
                    <div class="glass-panel p-4 rounded-xl flex items-center gap-3">
                        <div class="w-3 h-3 bg-green-500 rounded-full status-dot"></div>
                        <div>
                            <p class="text-xs font-bold text-green-400 uppercase">Système OK</p>
                            <p class="text-[10px] text-slate-500">Tous les services actifs</p>
                        </div>
                    </div>

                    <nav class="space-y-1">
                        <a href="#impact" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-slate-800/50 text-white font-bold border border-slate-700">
                            <i class="ph-fill ph-chart-bar text-[#F59E0B]"></i> Statistiques
                        </a>
                        <a href="#guides" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition">
                            <i class="ph-bold ph-book-open"></i> Guides Rapides
                        </a>
                        <a href="#faq" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition">
                            <i class="ph-bold ph-question"></i> FAQ
                        </a>
                        <a href="#contact" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition">
                            <i class="ph-bold ph-headset"></i> Support
                        </a>
                    </nav>
                </div>
            </aside>

            <div class="lg:col-span-9 space-y-12">

                <section id="impact">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="glass-panel p-6 rounded-2xl relative overflow-hidden group">
                            <div class="absolute -right-4 -bottom-4 opacity-10 rotate-12 group-hover:scale-110 transition">
                                <i class="ph-fill ph-users-three text-8xl text-white"></i>
                            </div>
                            <p class="text-xs text-slate-400 font-bold uppercase mb-1">Total Locataires</p>
                            <p class="text-3xl font-black text-white"><%= (statsActions && statsActions.reminders) || 0 %></p>
                        </div>
                        <div class="bg-gradient-to-br from-[#F59E0B] to-orange-700 p-6 rounded-2xl shadow-lg relative overflow-hidden">
                            <p class="text-xs text-black/60 font-bold uppercase mb-1">Loyers Encaissés</p>
                            <p class="text-3xl font-black text-white">
                                <%= (statsActions && statsActions.rentCollected ? statsActions.rentCollected : 0).toLocaleString('fr-FR') %> <span class="text-lg font-medium opacity-80">F</span>
                            </p>
                        </div>
                        <div class="glass-panel p-6 rounded-2xl relative overflow-hidden group">
                            <div class="absolute -right-4 -bottom-4 opacity-10 rotate-12 group-hover:scale-110 transition">
                                <i class="ph-fill ph-files text-8xl text-green-500"></i>
                            </div>
                            <p class="text-xs text-slate-400 font-bold uppercase mb-1">Documents Générés</p>
                            <p class="text-3xl font-black text-green-500"><%= (statsActions && statsActions.inventory) || 0 %></p>
                        </div>
                    </div>
                </section>

                <section id="guides">
                    <h2 class="text-xl font-black text-white mb-6 flex items-center gap-2">
                        <i class="ph-fill ph-rocket-launch text-[#F59E0B]"></i> Raccourcis Rapides
                    </h2>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 searchable-container">
                        
                        <div class="search-item bg-slate-900 border border-slate-800 p-5 rounded-2xl flex flex-col justify-between hover:border-slate-600 transition group">
                            <div>
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="bg-blue-500/20 text-blue-400 p-2 rounded-lg"><i class="ph-bold ph-user-plus text-xl"></i></div>
                                    <h3 class="font-bold text-white">Nouveau Locataire</h3>
                                </div>
                                <p class="text-sm text-slate-400 mb-4 search-text">Créez un bail, générez le contrat et ajoutez un locataire en 2 minutes.</p>
                            </div>
                            <a href="/owner/add-tenant" class="inline-flex items-center justify-center gap-2 w-full py-2.5 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-bold text-sm transition">
                                Commencer <i class="ph-bold ph-arrow-right"></i>
                            </a>
                        </div>

                        <div class="search-item bg-slate-900 border border-slate-800 p-5 rounded-2xl flex flex-col justify-between hover:border-slate-600 transition group">
                            <div>
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="bg-green-500/20 text-green-400 p-2 rounded-lg"><i class="ph-bold ph-money text-xl"></i></div>
                                    <h3 class="font-bold text-white">Encaisser un Loyer</h3>
                                </div>
                                <p class="text-sm text-slate-400 mb-4 search-text">Enregistrez un paiement reçu et envoyez la quittance automatiquement.</p>
                            </div>
                            <a href="/owner/dashboard#properties" class="inline-flex items-center justify-center gap-2 w-full py-2.5 rounded-xl bg-slate-800 hover:bg-slate-700 text-white border border-slate-600 font-bold text-sm transition">
                                Voir mes biens
                            </a>
                        </div>

                        <div class="search-item bg-slate-900 border border-slate-800 p-5 rounded-2xl flex flex-col justify-between hover:border-slate-600 transition group">
                            <div>
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="bg-purple-500/20 text-purple-400 p-2 rounded-lg"><i class="ph-bold ph-file-pdf text-xl"></i></div>
                                    <h3 class="font-bold text-white">Documents</h3>
                                </div>
                                <p class="text-sm text-slate-400 mb-4 search-text">Accédez à l'historique de tous les contrats et quittances générés.</p>
                            </div>
                            <a href="/owner/dashboard#documents" class="inline-flex items-center justify-center gap-2 w-full py-2.5 rounded-xl bg-slate-800 hover:bg-slate-700 text-white border border-slate-600 font-bold text-sm transition">
                                Ouvrir la bibliothèque
                            </a>
                        </div>
                        
                        <div class="search-item bg-slate-900 border border-slate-800 p-5 rounded-2xl flex flex-col justify-between hover:border-slate-600 transition group">
                            <div>
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="bg-red-500/20 text-red-400 p-2 rounded-lg"><i class="ph-bold ph-warning-octagon text-xl"></i></div>
                                    <h3 class="font-bold text-white">Incidents</h3>
                                </div>
                                <p class="text-sm text-slate-400 mb-4 search-text">Gérez les signalements de vos locataires et suivez les réparations.</p>
                            </div>
                            <a href="/owner/dashboard#incidents" class="inline-flex items-center justify-center gap-2 w-full py-2.5 rounded-xl bg-slate-800 hover:bg-slate-700 text-white border border-slate-600 font-bold text-sm transition">
                                Voir les alertes
                            </a>
                        </div>

                    </div>
                </section>

                <section id="faq">
                    <h2 class="text-xl font-black text-white mb-6 flex items-center gap-2">
                        <i class="ph-fill ph-question text-[#F59E0B]"></i> Questions Fréquentes
                    </h2>
                    
                    <div class="space-y-3 searchable-container">
                        
                        <div class="search-item bg-slate-900/50 border border-slate-800 rounded-xl overflow-hidden">
                            <button onclick="toggleFaq(this)" class="w-full p-4 text-left flex justify-between items-center group hover:bg-slate-800/50 transition">
                                <span class="font-bold text-sm text-slate-200 search-text">Comment recharger mon solde ?</span>
                                <i class="ph-bold ph-caret-down text-slate-500 transition-transform duration-300"></i>
                            </button>
                            <div class="hidden p-4 pt-0 text-sm text-slate-400 border-t border-slate-800/50 search-text">
                                Cliquez sur le bouton orange <strong>"Recharger"</strong> dans le tableau de bord. Le paiement est sécurisé par CinetPay (Mobile Money, Carte). Le solde est mis à jour instantanément.
                            </div>
                        </div>

                        <div class="search-item bg-slate-900/50 border border-slate-800 rounded-xl overflow-hidden">
                            <button onclick="toggleFaq(this)" class="w-full p-4 text-left flex justify-between items-center group hover:bg-slate-800/50 transition">
                                <span class="font-bold text-sm text-slate-200 search-text">Pourquoi mon séquestre est à 0 ?</span>
                                <i class="ph-bold ph-caret-down text-slate-500 transition-transform duration-300"></i>
                            </button>
                            <div class="hidden p-4 pt-0 text-sm text-slate-400 border-t border-slate-800/50 search-text">
                                Le séquestre ne compte que les <strong>cautions réellement encaissées</strong> lors de la création d'un bail via l'application. Si vous avez ajouté vos biens manuellement, le montant peut être à 0.
                            </div>
                        </div>

                        <div class="search-item bg-slate-900/50 border border-slate-800 rounded-xl overflow-hidden">
                            <button onclick="toggleFaq(this)" class="w-full p-4 text-left flex justify-between items-center group hover:bg-slate-800/50 transition">
                                <span class="font-bold text-sm text-slate-200 search-text">Le locataire voit-il mes autres biens ?</span>
                                <i class="ph-bold ph-caret-down text-slate-500 transition-transform duration-300"></i>
                            </button>
                            <div class="hidden p-4 pt-0 text-sm text-slate-400 border-t border-slate-800/50 search-text">
                                <strong>Non.</strong> La confidentialité est totale. Chaque locataire n'a accès qu'aux informations concernant son propre contrat.
                            </div>
                        </div>
                        
                        <div class="search-item bg-slate-900/50 border border-slate-800 rounded-xl overflow-hidden">
                            <button onclick="toggleFaq(this)" class="w-full p-4 text-left flex justify-between items-center group hover:bg-slate-800/50 transition">
                                <span class="font-bold text-sm text-slate-200 search-text">Comment modifier un contrat ?</span>
                                <i class="ph-bold ph-caret-down text-slate-500 transition-transform duration-300"></i>
                            </button>
                            <div class="hidden p-4 pt-0 text-sm text-slate-400 border-t border-slate-800/50 search-text">
                                Pour des raisons légales, un contrat signé ne peut être modifié. Vous devez terminer le bail actuel (Sortie) et en créer un nouveau avec les nouvelles conditions.
                            </div>
                        </div>

                    </div>
                    
                    <div id="noResults" class="hidden text-center py-10">
                        <i class="ph-duotone ph-magnifying-glass text-4xl text-slate-600 mb-2"></i>
                        <p class="text-slate-500">Aucun résultat trouvé pour cette recherche.</p>
                    </div>
                </section>

                <section id="contact" class="bg-gradient-to-r from-blue-900/40 to-slate-900 p-8 rounded-3xl border border-blue-500/20 text-center relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl -mr-10 -mt-10"></div>
                    
                    <h2 class="text-2xl font-black text-white mb-2 relative z-10">Besoin d'une assistance humaine ?</h2>
                    <p class="text-slate-400 mb-8 max-w-lg mx-auto relative z-10">Nos experts sont disponibles 7j/7 de 8h à 20h pour vous accompagner.</p>
                    
                    <a href="https://wa.me/2250707070707" target="_blank" class="inline-flex items-center gap-3 bg-[#25D366] text-[#0B1120] px-8 py-4 rounded-xl font-bold hover:bg-[#20bd5a] transition hover:scale-105 shadow-lg shadow-green-900/20 relative z-10">
                        <i class="ph-fill ph-whatsapp-logo text-2xl"></i>
                        Discuter sur WhatsApp
                    </a>
                </section>

            </div>
        </div>
    </main>

    <script>
        // 1. GESTION FAQ ACCORDION
        function toggleFaq(button) {
            const content = button.nextElementSibling;
            const icon = button.querySelector('i');
            
            // Fermer les autres (Optionnel, pour effet accordéon strict)
            // document.querySelectorAll('.search-item > div').forEach(div => {
            //     if(div !== content) div.classList.add('hidden');
            // });

            if (content.classList.contains('hidden')) {
                content.classList.remove('hidden');
                icon.style.transform = 'rotate(180deg)';
                button.classList.add('bg-slate-800');
            } else {
                content.classList.add('hidden');
                icon.style.transform = 'rotate(0deg)';
                button.classList.remove('bg-slate-800');
            }
        }

        // 2. MOTEUR DE RECHERCHE CLIENT-SIDE
        function filterHelp() {
            const input = document.getElementById('helpSearch');
            const filter = input.value.toLowerCase();
            const items = document.querySelectorAll('.search-item');
            let hasResults = false;

            items.forEach(item => {
                const text = item.querySelector('.search-text').textContent.toLowerCase(); // Cherche dans le titre et la description
                // Cherche aussi dans le titre h3 si existant
                const title = item.querySelector('h3') ? item.querySelector('h3').textContent.toLowerCase() : '';
                
                if (text.includes(filter) || title.includes(filter)) {
                    item.style.display = "";
                    hasResults = true;
                    // Si c'est une FAQ, on pourrait l'ouvrir automatiquement, mais peut être envahissant
                } else {
                    item.style.display = "none";
                }
            });

            const noResultsMsg = document.getElementById('noResults');
            if(noResultsMsg) {
                noResultsMsg.style.display = hasResults ? 'none' : 'block';
            }
        }
        
        // 3. SERVICE WORKER
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js'));
        }
    </script>
</body>
</html>
