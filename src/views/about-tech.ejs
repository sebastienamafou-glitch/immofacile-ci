<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Architecture & Technologie | ImmoFacile CI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Plus Jakarta Sans', sans-serif; }</style>
</head>
<body class="bg-gray-50 text-slate-800 min-h-screen p-8">

    <header class="mb-12 text-center max-w-3xl mx-auto">
        <a href="/" class="text-slate-400 hover:text-slate-600 mb-4 inline-block text-sm">&larr; Retour Accueil</a>
        <h1 class="text-4xl font-black text-slate-900 mb-4">
            Architecture Système <span class="text-blue-600">IMMOFACILE V3</span>
        </h1>
        <p class="text-slate-500 text-lg">
            Une plateforme hybride (SaaS + Transactionnel) couvrant toute la chaîne de valeur de l'immobilier ivoirien.
        </p>
    </header>

    <div class="flex justify-center mb-10 gap-4">
        <button onclick="switchTab('ecosystem')" id="btn-ecosystem" class="px-6 py-3 rounded-full font-bold transition-all bg-blue-600 text-white shadow-lg transform hover:scale-105">
            Écosystème & Rôles
        </button>
        <button onclick="switchTab('tech')" id="btn-tech" class="px-6 py-3 rounded-full font-bold transition-all bg-white text-slate-600 hover:bg-gray-100 border border-slate-200">
            La Stack Technique
        </button>
    </div>

    <div id="tab-ecosystem" class="max-w-7xl mx-auto transition-opacity duration-300">
        
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 mb-8 flex flex-col md:flex-row items-center justify-around">
            <div class="flex items-center gap-4">
                <div class="bg-green-100 p-3 rounded-full text-green-600"><i class="ph-fill ph-check-circle text-2xl"></i></div>
                <div>
                    <h3 class="font-bold text-lg">Conformité Juridique</h3>
                    <p class="text-sm text-slate-500">Baux loi 2024 & Plafonnement</p>
                </div>
            </div>
            <div class="hidden md:block h-12 w-px bg-slate-200"></div>
            <div class="flex items-center gap-4">
                <div class="bg-blue-100 p-3 rounded-full text-blue-600"><i class="ph-fill ph-shield-check text-2xl"></i></div>
                <div>
                    <h3 class="font-bold text-lg">Sécurité Données</h3>
                    <p class="text-sm text-slate-500">Protection CSRF & PostgreSQL</p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            
            <div class="bg-blue-50 border-2 border-blue-200 p-6 rounded-2xl hover:-translate-y-1 transition duration-300">
                <div class="flex justify-between mb-4"><i class="ph-duotone ph-buildings text-3xl text-blue-600 bg-white p-2 rounded-lg"></i></div>
                <h3 class="text-xl font-bold text-slate-900">Le Propriétaire</h3>
                <p class="text-xs font-bold uppercase text-slate-500 mb-4 tracking-widest">L'Automatisation</p>
                <ul class="space-y-2 text-sm text-slate-700">
                    <li class="flex gap-2"><i class="ph-bold ph-robot"></i> Rédaction Annonces IA</li>
                    <li class="flex gap-2"><i class="ph-bold ph-map-pin"></i> Délégation "Uber-like"</li>
                    <li class="flex gap-2"><i class="ph-bold ph-user-check"></i> KYC Mindee (Anti-fraude)</li>
                </ul>
            </div>

            <div class="bg-green-50 border-2 border-green-200 p-6 rounded-2xl hover:-translate-y-1 transition duration-300">
                <div class="flex justify-between mb-4"><i class="ph-duotone ph-users text-3xl text-green-600 bg-white p-2 rounded-lg"></i></div>
                <h3 class="text-xl font-bold text-slate-900">Le Locataire</h3>
                <p class="text-xs font-bold uppercase text-slate-500 mb-4 tracking-widest">Expérience Low-Cost</p>
                <ul class="space-y-2 text-sm text-slate-700">
                    <li class="flex gap-2"><i class="ph-bold ph-tag"></i> Frais fixes 20 000 FCFA</li>
                    <li class="flex gap-2"><i class="ph-bold ph-device-mobile"></i> Paiement Mobile Money</li>
                    <li class="flex gap-2"><i class="ph-bold ph-file-pdf"></i> Bail Numérique Instantané</li>
                </ul>
            </div>

            <div class="bg-purple-50 border-2 border-purple-200 p-6 rounded-2xl hover:-translate-y-1 transition duration-300">
                <div class="flex justify-between items-start mb-4">
                    <i class="ph-duotone ph-briefcase text-3xl text-purple-600 bg-white p-2 rounded-lg"></i>
                    <span class="bg-purple-200 text-purple-800 text-[10px] font-bold px-2 py-1 rounded-full uppercase">Uber-Model</span>
                </div>
                <h3 class="text-xl font-bold text-slate-900">L'Agent / Visiteur</h3>
                <p class="text-xs font-bold uppercase text-slate-500 mb-4 tracking-widest">Le Bras Droit</p>
                <ul class="space-y-2 text-sm text-slate-700">
                    <li class="flex gap-2"><i class="ph-bold ph-bell-ringing"></i> Missions par Notification Push</li>
                    <li class="flex gap-2"><i class="ph-bold ph-map-trifold"></i> Filtrage par Commune</li>
                    <li class="flex gap-2"><i class="ph-bold ph-money"></i> Commissions à la visite</li>
                </ul>
            </div>

            <div class="bg-red-50 border-2 border-red-200 p-6 rounded-2xl hover:-translate-y-1 transition duration-300">
                <div class="flex justify-between mb-4"><i class="ph-duotone ph-shield-check text-3xl text-red-600 bg-white p-2 rounded-lg"></i></div>
                <h3 class="text-xl font-bold text-slate-900">L'Administrateur</h3>
                <p class="text-xs font-bold uppercase text-slate-500 mb-4 tracking-widest">La Tour de Contrôle</p>
                <ul class="space-y-2 text-sm text-slate-700">
                    <li class="flex gap-2"><i class="ph-bold ph-chart-line-up"></i> Dashboard Financier Global</li>
                    <li class="flex gap-2"><i class="ph-bold ph-eye"></i> Logs & Audit (Le Mouchard)</li>
                </ul>
            </div>

            <div class="bg-amber-50 border-2 border-amber-200 p-6 rounded-2xl hover:-translate-y-1 transition duration-300">
                <div class="flex justify-between mb-4"><i class="ph-duotone ph-trend-up text-3xl text-amber-600 bg-white p-2 rounded-lg"></i></div>
                <h3 class="text-xl font-bold text-slate-900">L'Investisseur</h3>
                <p class="text-xs font-bold uppercase text-slate-500 mb-4 tracking-widest">Suivi Rentabilité</p>
                <ul class="space-y-2 text-sm text-slate-700">
                    <li class="flex gap-2"><i class="ph-bold ph-chart-pie-slice"></i> Dashboard ROI Temps Réel</li>
                    <li class="flex gap-2"><i class="ph-bold ph-crane"></i> Suivi Chantier / Rénovation</li>
                </ul>
            </div>

        </div>
    </div>

    <div id="tab-tech" class="max-w-5xl mx-auto hidden transition-opacity duration-300">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            
            <div class="space-y-6">
                <h3 class="text-xl font-bold text-slate-700 flex items-center gap-2 border-b pb-2">
                    <i class="ph-fill ph-cpu text-indigo-600"></i> Cœur du Système
                </h3>
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 divide-y divide-slate-100">
                    <div class="p-5 flex gap-4 hover:bg-slate-50 transition">
                        <div class="bg-indigo-50 text-indigo-600 p-3 rounded-lg h-fit"><i class="ph-bold ph-layout text-xl"></i></div>
                        <div><h4 class="font-bold">Frontend</h4><p class="text-indigo-600 font-mono text-sm">EJS + TailwindCSS</p></div>
                    </div>
                    <div class="p-5 flex gap-4 hover:bg-slate-50 transition">
                        <div class="bg-indigo-50 text-indigo-600 p-3 rounded-lg h-fit"><i class="ph-bold ph-hard-drives text-xl"></i></div>
                        <div><h4 class="font-bold">Backend</h4><p class="text-indigo-600 font-mono text-sm">Node.js + Express</p></div>
                    </div>
                    <div class="p-5 flex gap-4 hover:bg-slate-50 transition">
                        <div class="bg-indigo-50 text-indigo-600 p-3 rounded-lg h-fit"><i class="ph-bold ph-database text-xl"></i></div>
                        <div><h4 class="font-bold">Base de Données</h4><p class="text-indigo-600 font-mono text-sm">PostgreSQL + Prisma</p></div>
                    </div>
                </div>
            </div>

            <div class="space-y-6">
                <h3 class="text-xl font-bold text-slate-700 flex items-center gap-2 border-b pb-2">
                    <i class="ph-fill ph-plugs-connected text-green-600"></i> Services Externes
                </h3>
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 divide-y divide-slate-100">
                    <div class="p-5 flex gap-4 hover:bg-slate-50 transition">
                        <div class="bg-green-50 text-green-600 p-3 rounded-lg h-fit"><i class="ph-bold ph-robot text-xl"></i></div>
                        <div><h4 class="font-bold">AI & OCR</h4><p class="text-green-700 font-mono text-sm">OpenAI + Mindee</p></div>
                    </div>
                    <div class="p-5 flex gap-4 hover:bg-slate-50 transition">
                        <div class="bg-green-50 text-green-600 p-3 rounded-lg h-fit"><i class="ph-bold ph-credit-card text-xl"></i></div>
                        <div><h4 class="font-bold">Paiement</h4><p class="text-green-700 font-mono text-sm">CinetPay (Wave/Orange/MTN)</p></div>
                    </div>
                    <div class="p-5 flex gap-4 hover:bg-slate-50 transition">
                        <div class="bg-green-50 text-green-600 p-3 rounded-lg h-fit"><i class="ph-bold ph-whatsapp-logo text-xl"></i></div>
                        <div><h4 class="font-bold">Communication</h4><p class="text-green-700 font-mono text-sm">WhatsApp API + Web Push</p></div>
                    </div>
                </div>
            </div>

        </div>

        <div class="mt-12 bg-slate-900 text-white rounded-3xl p-10 shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl"></div>
            <h3 class="text-center font-bold text-xl mb-10 text-slate-300 uppercase tracking-widest">Flux de Délégation "Uber-like"</h3>
            
            <div class="flex flex-col md:flex-row items-center justify-center gap-6 text-center relative z-10">
                <div class="bg-slate-800 p-6 rounded-2xl w-48 border border-slate-700">
                    <i class="ph-duotone ph-house-line text-4xl text-blue-400 mb-2"></i>
                    <div class="font-bold text-lg">Propriétaire</div>
                    <div class="text-xs text-slate-400">1. Demande visite</div>
                </div>

                <div class="hidden md:block h-0.5 flex-1 bg-slate-700 relative mx-4">
                    <div class="absolute -top-3 left-1/2 -translate-x-1/2 text-[10px] uppercase font-bold text-slate-500 bg-slate-900 px-2">Géolocalisation</div>
                </div>
                <i class="ph-bold ph-arrow-down md:hidden text-slate-600 my-2"></i>

                <div class="bg-purple-900/40 border border-purple-500/50 p-6 rounded-2xl w-48 relative shadow-[0_0_30px_rgba(168,85,247,0.2)]">
                    <div class="absolute -top-3 -right-3 bg-red-500 text-white text-[10px] font-bold px-2 py-1 rounded-full animate-pulse shadow-lg">PUSH</div>
                    <i class="ph-duotone ph-device-mobile text-4xl text-purple-400 mb-2"></i>
                    <div class="font-bold text-lg text-purple-100">Agent</div>
                    <div class="text-xs text-purple-300">2. Reçoit notif</div>
                </div>

                <div class="hidden md:block h-0.5 flex-1 bg-slate-700 mx-4"></div>
                <i class="ph-bold ph-arrow-down md:hidden text-slate-600 my-2"></i>

                <div class="bg-slate-800 p-6 rounded-2xl w-48 border border-slate-700">
                    <i class="ph-duotone ph-check-circle text-4xl text-green-400 mb-2"></i>
                    <div class="font-bold text-lg">Locataire</div>
                    <div class="text-xs text-slate-400">3. Visite effectuée</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function switchTab(tab) {
            const eco = document.getElementById('tab-ecosystem');
            const tech = document.getElementById('tab-tech');
            const btnEco = document.getElementById('btn-ecosystem');
            const btnTech = document.getElementById('btn-tech');

            if (tab === 'ecosystem') {
                eco.classList.remove('hidden');
                tech.classList.add('hidden');
                
                btnEco.className = "px-6 py-3 rounded-full font-bold transition-all bg-blue-600 text-white shadow-lg transform hover:scale-105";
                btnTech.className = "px-6 py-3 rounded-full font-bold transition-all bg-white text-slate-600 hover:bg-gray-100 border border-slate-200";
            } else {
                eco.classList.add('hidden');
                tech.classList.remove('hidden');

                btnTech.className = "px-6 py-3 rounded-full font-bold transition-all bg-indigo-600 text-white shadow-lg transform hover:scale-105";
                btnEco.className = "px-6 py-3 rounded-full font-bold transition-all bg-white text-slate-600 hover:bg-gray-100 border border-slate-200";
            }
        }
    </script>
</body>
</html>
