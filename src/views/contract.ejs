<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    [cite_start]<title>Bail d'Habitation - <%= locals.property ? property.title : 'Contrat' %> [cite: 206]</title>
    
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#ffffff">
    
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        /* RESET & BASICS */
        body { 
            font-family: 'Georgia', 'Times New Roman', serif; [cite_start]/* Plus élégant que Times standard [cite: 208] */
            line-height: 1.5;
            color: #1a1a1a; 
            max-width: 210mm; /* Largeur A4 exacte */
            margin: 0 auto;
            padding: 20mm; /* Marges d'impression standard */
            background: white;
            font-size: 11pt; /* Taille de lecture standard */
        }

        /* TYPOGRAPHIE */
        h1 { 
            text-align: center;
            font-size: 18pt; 
            text-transform: uppercase; 
            letter-spacing: 2px;
            margin-bottom: 40px; 
            font-weight: 900;
            border: 3px double #000;
            padding: 10px;
        }
        h2 { 
            font-size: 12pt;
            text-transform: uppercase; 
            background: #f3f3f3; 
            padding: 5px 10px; 
            margin-top: 30px; 
            border-bottom: 1px solid #000;
        }
        h3 {
            font-size: 11pt;
            text-decoration: underline;
            margin-top: 15px;
            margin-bottom: 5px;
        }
        p { text-align: justify; margin-bottom: 10px; }
        ul { margin: 0; padding-left: 20px; text-align: justify; }
        li { margin-bottom: 5px; }

        /* BLOCS PARTIES */
        .parties-container {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 30px;
        }
        .party-box { 
            width: 48%;
            padding: 15px; 
            border: 1px solid #ccc;
            background: #fdfdfd;
            font-size: 10pt;
        }
        .party-role {
            font-weight: bold;
            text-transform: uppercase;
            border-bottom: 1px solid #ddd;
            padding-bottom: 5px;
            margin-bottom: 10px;
            display: block;
            text-align: center;
        }

        /* INFO BIEN */
        .property-details {
            background: #eef2ff;
            border: 1px solid #cfdaff;
            padding: 15px;
            margin: 15px 0;
        }

        /* SIGNATURES */
        .signature-section { 
            margin-top: 50px;
            page-break-inside: avoid; 
        }
        .signature-grid {
            display: flex;
            justify-content: space-between;
            gap: 30px;
        }
        .sign-box { 
            flex: 1;
            height: 150px; 
            border: 1px solid #000; 
            padding: 10px; 
            position: relative; /* Important pour le positionnement du tampon */
        }
        .sign-label {
            font-weight: bold;
            text-decoration: underline;
            margin-bottom: 5px;
        }
        .lu-et-approuve {
            font-size: 0.8em;
            color: #666;
            font-style: italic;
            margin-bottom: 10px;
        }

        /* TAMPON NUMERIQUE (NOUVEAU) */
        .digital-stamp {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-10deg);
            border: 3px solid #059669; /* Vert émeraude */
            color: #059669;
            padding: 10px;
            text-align: center;
            font-weight: bold;
            font-family: 'Courier New', monospace;
            text-transform: uppercase;
            font-size: 14px;
            opacity: 0.9;
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            z-index: 10;
            width: 80%;
        }

        /* UI ECRAN SEULEMENT */
        @media screen {
            body { 
                box-shadow: 0 0 20px rgba(0,0,0,0.1);
                margin-top: 40px; 
                margin-bottom: 100px; /* Espace pour la barre fixe du bas */
            }
            .action-bar-top {
                position: sticky;
                top: 0;
                background: #0B1120;
                color: white;
                padding: 15px;
                text-align: center;
                margin: -20mm -20mm 30px -20mm;
                box-shadow: 0 4px 6px rgba(0,0,0,0.1);
                display: flex;
                justify-content: space-between;
                align-items: center;
                z-index: 40;
            }
            .btn {
                background: #F59E0B;
                color: #000;
                border: none;
                padding: 10px 20px;
                font-weight: bold;
                border-radius: 6px;
                cursor: pointer;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }
            .btn:hover { background: #d97706; }
            .btn-outline {
                background: transparent;
                border: 1px solid rgba(255,255,255,0.3);
                color: white;
            }
            .btn-outline:hover { background: rgba(255,255,255,0.1); }
        }

        /* IMPRESSION */
        @media print { 
            .no-print, #signAction, #signModal { display: none !important; } 
            body { 
                box-shadow: none;
                margin: 0; 
                width: 100%;
                padding: 0; 
            } 
            @page {
                margin: 20mm;
                size: A4;
            }
            body { counter-reset: page; }
            .page-footer {
                position: fixed;
                bottom: 0;
                width: 100%;
                text-align: center;
                font-size: 9pt;
                border-top: 1px solid #eee;
                padding-top: 5px;
            }
            .page-footer::after {
                counter-increment: page;
                content: "Page " counter(page);
            }
        }
    </style>
</head>
<body>

    <div class="action-bar-top no-print">
        <a href="/owner/dashboard" class="btn btn-outline">← Retour Tableau de bord</a>
        <div>
            <span style="font-size: 0.9em; opacity: 0.8; margin-right: 15px;">Document généré le <%= new Date().toLocaleDateString('fr-FR') %></span>
            <button onclick="window.print()" class="btn">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M19 8h-1V3H6v5H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zM8 5h8v3H8V5zm8 12v2H8v-4h8v2zm2-2v-2H6v2H4v-4c0-.55.45-1 1-1h14c.55 0 1 .45 1 1v4h-2z"/></svg>
                Imprimer / PDF
            </button>
        </div>
    </div>

    <h1>Contrat de Bail à Usage d'Habitation</h1>

    <div class="parties-container">
        <div class="party-box">
            <span class="party-role">Le Bailleur (Propriétaire)</span>
            [cite_start]<strong><%= locals.owner ? owner.name : '____________________' %> [cite: 250]</strong><br>
            [cite_start]<% if(locals.owner && owner.email) { %>Email : <%= owner.email %><br><% } [cite: 250] %>
            [cite_start]<% if(locals.owner && owner.phone) { %>Tél : <%= owner.phone %><br><% } [cite: 250] %>
            <br>
            <em>Ci-après dénommé <strong>"LE BAILLEUR"</strong></em>
        </div>

        <div class="party-box">
            <span class="party-role">Le Preneur (Locataire)</span>
            [cite_start]<strong><%= locals.tenant ? tenant.name : '____________________' %> [cite: 252]</strong><br>
            [cite_start]<% if(locals.tenant && tenant.phone) { %>Tél : <%= tenant.phone %><br><% } [cite: 252] %>
            <% if(locals.tenant && tenant.email) { %>Email : <%= tenant.email %><br><% } %>
            <br>
            <em>Ci-après dénommé <strong>"LE PRENEUR"</strong></em>
        </div>
    </div>

    <p>Il a été convenu et arrêté ce qui suit :</p>

    <h2>ARTICLE 1 : DÉSIGNATION DES LIEUX</h2>
    <p>Le Bailleur donne en location au Preneur, qui accepte, les locaux désignés ci-après :</p>
    
    <div class="property-details">
        <ul style="list-style-type: none; padding: 0;">
            <li>🏠 <strong>Type de bien :</strong> <%= locals.property ? property.type || 'Appartement/Maison' : '_______________' %></li>
            <li>📍 <strong>Adresse :</strong> <%= locals.property ? (property.address + ', ' + property.commune) [cite_start]: '________________________________________' %> [cite: 255]</li>
            <li>🔑 <strong>Destination :</strong> Habitation bourgeoise exclusive. L'exercice de toute activité commerciale, artisanale ou libérale est strictement interdit sans accord écrit.</li>
        </ul>
    </div>

    <h2>ARTICLE 2 : DURÉE DU BAIL</h2>
    <p>
        Le présent bail est consenti et accepté pour une durée de <strong>1 AN (un an)</strong> renouvelable par tacite reconduction.<br>
        Il prend effet à compter du : <strong><%= new Date(startDate).toLocaleDateString('fr-FR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></strong>.
    </p>

    <h2>ARTICLE 3 : LOYER ET CHARGES</h2>
    <p>La présente location est consentie et acceptée moyennant un loyer mensuel de :</p>
    <p style="text-align: center; font-size: 1.2em; font-weight: bold; margin: 20px 0;">
        [cite_start]<%= lease.monthlyRent.toLocaleString('fr-FR') %> Francs CFA [cite: 258]
    </p>
    <p>Le loyer est payable d'avance, mensuellement, au plus tard le <strong>05 de chaque mois</strong>, au domicile du Bailleur ou par tout moyen convenu (Mobile Money, virement).</p>
    <p><em>Révision du loyer : Le loyer pourra être révisé à chaque renouvellement du contrat, conformément à la législation en vigueur.</em></p>

    <h2>ARTICLE 4 : DÉPÔT DE GARANTIE (CAUTION)</h2>
    <p>
        Pour garantir l'exécution de ses obligations, le Preneur verse ce jour la somme de :<br>
        [cite_start]<strong><%= lease.depositAmount.toLocaleString('fr-FR') %> FCFA</strong>, correspondant à <%= Math.round(lease.depositAmount / lease.monthlyRent) %> mois de loyer. [cite: 260]
    </p>
    <p>Cette somme ne porte pas intérêt et ne peut en aucun cas s'imputer sur le paiement des derniers mois de loyer. Elle sera restituée au Preneur en fin de bail, déduction faite des sommes dues, dans un délai maximum de 2 mois après la remise des clés.</p>

    <h2>ARTICLE 5 : OBLIGATIONS DES PARTIES</h2>
    <h3>5.1 Obligations du Preneur</h3>
    <ul>
        <li>Payer le loyer et les charges aux termes convenus.</li>
        <li>User paisiblement des lieux loués suivant la destination prévue au contrat.</li>
        <li>Ne pas sous-louer ni céder le bail sans l'accord écrit du Bailleur.</li>
        <li>Répondre des dégradations et pertes qui surviennent pendant la durée du contrat.</li>
        <li>Laisser exécuter dans les lieux loués les travaux d'amélioration ou d'entretien nécessaires.</li>
    </ul>

    <h3>5.2 Obligations du Bailleur</h3>
    <ul>
        <li>Délivrer au Preneur un logement décent ne laissant pas paraître de risques manifestes pouvant porter atteinte à la sécurité physique ou à la santé.</li>
        <li>Assurer au Preneur la jouissance paisible du logement.</li>
        <li>Entretenir les locaux en état de servir à l'usage prévu.</li>
    </ul>

    <h2>ARTICLE 6 : CLAUSE RÉSOLUTOIRE</h2>
    <p>
        [cite_start]À défaut de paiement d'un seul terme de loyer à son échéance ou des charges, ou en cas d'inexécution de l'une des clauses du bail, et <strong>un mois après un commandement de payer ou une sommation d'exécuter restés infructueux</strong>, le bail sera résilié de plein droit. [cite: 264]
    </p>
    <p>Le Preneur devra libérer les lieux dès la résiliation acquise. À défaut, il pourra y être contraint par simple ordonnance de référé.</p>

    <h2>ARTICLE 7 : ÉTAT DES LIEUX</h2>
    <p>Un état des lieux contradictoire sera établi lors de la remise des clés au Preneur et lors de leur restitution. Il sera annexé au présent contrat.</p>

    <div class="signature-section">
        <p>Fait à <strong><%= locals.property ? property.commune : 'Abidjan' %></strong>, le <strong><%= new Date().toLocaleDateString('fr-FR') %></strong>, en deux exemplaires originaux.</p>
        
        <div class="signature-grid">
            <div class="sign-box">
                <div class="sign-label">LE BAILLEUR</div>
                <div class="lu-et-approuve">"Lu et approuvé"</div>
                
                <% if(locals.lease && lease.signatureDate) { %>
                <div class="digital-stamp">
                    ✍️ SIGNÉ NUMÉRIQUEMENT<br>
                    ID: <%= lease.id.substring(0,6).toUpperCase() %><br>
                    DATE: <%= new Date(lease.signatureDate).toLocaleDateString('fr-FR') %>
                </div>
                <% } %>
            </div>
            
            <div class="sign-box">
                <div class="sign-label">LE PRENEUR</div>
                <div class="lu-et-approuve">"Lu et approuvé"</div>

                <% if(locals.lease && lease.signatureDate) { %>
                <div class="digital-stamp">
                    ✍️ SIGNÉ NUMÉRIQUEMENT<br>
                    ID: <%= lease.id.substring(0,6).toUpperCase() %><br>
                    DATE: <%= new Date(lease.signatureDate).toLocaleDateString('fr-FR') %>
                </div>
                <% } %>
            </div>
        </div>
    </div>

    <div class="page-footer no-print">
        [cite_start]ImmoFacile CI - Contrat de Bail Réf: <%= typeof lease !== 'undefined' ? lease.id.substring(0,8).toUpperCase() : 'N/A' %> [cite: 269]
    </div>

    <% if(locals.lease && !lease.signatureDate) { %>
    <div id="signAction" class="fixed bottom-0 left-0 w-full bg-white p-4 border-t shadow-[0_-5px_20px_rgba(0,0,0,0.1)] flex justify-between items-center z-50 no-print">
        <div class="pl-4">
            <p class="text-xs text-slate-500 uppercase font-bold tracking-wider">Action requise</p>
            <p class="font-bold text-[#0B1120] text-lg">Finaliser le bail</p>
        </div>
        <button onclick="startSigning()" class="bg-[#F59E0B] text-black px-8 py-3 rounded-xl font-bold hover:scale-105 transition shadow-lg flex items-center gap-2">
            <span>✍️</span> Signer électroniquement
        </button>
    </div>

    <div id="signModal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-sm z-[60] flex items-center justify-center p-4 no-print">
        <div class="bg-white rounded-3xl p-8 max-w-sm w-full text-center relative shadow-2xl">
            <button onclick="closeModal()" class="absolute top-4 right-4 text-slate-400 hover:text-black">✕</button>
            
            <div class="bg-blue-50 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">📱</div>
            <h3 class="text-xl font-bold mb-2 text-gray-800">Signature Sécurisée</h3>
            <p class="text-slate-500 text-sm mb-6">Pour valider ce contrat légalement, un code unique va être envoyé sur votre numéro WhatsApp.</p>
            
            <div id="step1">
                <button onclick="sendCode()" class="w-full bg-[#0B1120] hover:bg-slate-800 text-white py-3 rounded-xl font-bold transition">
                    Recevoir mon code
                </button>
            </div>

            <div id="step2" class="hidden space-y-4">
                <input type="text" id="otpInput" placeholder="ex: 123456" maxlength="6" class="w-full text-center text-2xl tracking-widest border-2 border-slate-200 rounded-xl p-3 focus:border-[#F59E0B] outline-none font-bold bg-slate-50">
                <button onclick="confirmSign()" class="w-full bg-green-600 hover:bg-green-700 text-white py-3 rounded-xl font-bold transition shadow-lg">
                    Valider la signature
                </button>
                <p id="errorMsg" class="text-red-500 text-xs hidden">Code incorrect, veuillez réessayer.</p>
            </div>
            
            <button onclick="closeModal()" class="mt-6 text-xs text-slate-400 underline hover:text-slate-600">Annuler l'opération</button>
        </div>
    </div>

    <script>
        const leaseId = "<%= lease.id %>"; // ID injecté par EJS

        function startSigning() {
            document.getElementById('signModal').classList.remove('hidden');
        }

        async function sendCode() {
            // Simulation d'envoi ou appel API réel
            const btn = document.querySelector('#step1 button');
            const originalText = btn.innerText;
            btn.innerText = "Envoi en cours...";
            btn.disabled = true;

            try {
                const res = await fetch(`/api/lease/${leaseId}/sign-request`, { method: 'POST' });
                if(res.ok) {
                    document.getElementById('step1').classList.add('hidden');
                    document.getElementById('step2').classList.remove('hidden');
                    console.log("Code envoyé (Mode test)");
                } else {
                    alert("Erreur lors de l'envoi du code. Vérifiez votre connexion.");
                    btn.innerText = originalText;
                    btn.disabled = false;
                }
            } catch (e) {
                console.error(e);
                alert("Erreur de connexion");
                btn.innerText = originalText;
                btn.disabled = false;
            }
        }

        async function confirmSign() {
            const code = document.getElementById('otpInput').value;
            const errorMsg = document.getElementById('errorMsg');
            
            if(!code) return;

            try {
                const res = await fetch(`/api/lease/sign-verify`, {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ otp: code, leaseId: leaseId })
                });
                
                const data = await res.json();
                if(data.success) {
                    // Rechargement pour afficher le tampon
                    window.location.reload(); 
                } else {
                    errorMsg.classList.remove('hidden');
                    document.getElementById('otpInput').classList.add('border-red-500');
                }
            } catch (e) {
                console.error(e);
            }
        }
        
        function closeModal() {
            document.getElementById('signModal').classList.add('hidden');
            // Reset modal state
            document.getElementById('step1').classList.remove('hidden');
            document.getElementById('step2').classList.add('hidden');
            document.getElementById('errorMsg').classList.add('hidden');
            document.getElementById('otpInput').value = '';
        }
    </script>
    <% } %>

</body>
</html>
