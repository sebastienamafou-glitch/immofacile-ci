    <div class="max-w-5xl mx-auto px-4 md:px-6 -mt-16 relative z-20 pb-20">
        
        <div class="flex flex-col lg:flex-row gap-8">
            
            <aside class="hidden lg:block w-64 shrink-0 no-print">
                <div class="sticky top-8 space-y-2">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3 pl-3">Sommaire</p>
                    <a href="#mentions" class="block px-4 py-2 rounded-lg hover:bg-white hover:shadow-sm text-slate-600 hover:text-[#0B1120] transition font-medium border-l-2 border-transparent hover:border-[#F59E0B]">Mentions Légales</a>
                    <a href="#objet" class="block px-4 py-2 rounded-lg hover:bg-white hover:shadow-sm text-slate-600 hover:text-[#0B1120] transition font-medium border-l-2 border-transparent hover:border-[#F59E0B]">Objet & Rôle</a>
