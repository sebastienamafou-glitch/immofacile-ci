<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <meta name="author" content="WebAppCI SARL">
    <meta name="copyright" content="WebAppCI SARL">
    <meta name="generator" content="ImmoFacile Engine v2">
    
    <title>Dashboard Admin | ImmoFacile CI</title>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0B1120">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass { background: rgba(30, 41, 59, 0.4); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.05); }
        .glass-card { background: linear-gradient(145deg, rgba(30, 41, 59, 0.6) 0%, rgba(15, 23, 42, 0.8) 100%); border: 1px solid rgba(255,255,255,0.05); }
        
        /* Sidebar transition */
        #sidebar { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        @media (max-width: 768px) {
            #sidebar.closed { transform: translateX(-100%); }
            #sidebar.open { transform: translateX(0); }
        }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0F172A; }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #475569; }

        /* Active Link Style */
        .nav-link.active { background-color: rgba(255, 255, 255, 0.1); color: white; border-left: 3px solid #F59E0B; }
    </style>
</head>
<body class="bg-[#0B1120] text-slate-200 antialiased overflow-hidden">

    <div class="md:hidden flex items-center justify-between p-4 bg-[#0B1120]/90 backdrop-blur-md border-b border-slate-800 sticky top-0 z-50">
        <div class="flex items-center gap-2 font-extrabold text-white tracking-tight">
            <i class="ph-fill ph-house-line text-[#F59E0B] text-xl"></i>
            IMMOFACILE
        </div>
        <button onclick="toggleMenu()" class="text-white p-2 rounded-lg hover:bg-slate-800 transition">
            <i class="ph ph-list text-2xl"></i>
        </button>
    </div>

    <div class="flex h-screen overflow-hidden">
        
        <aside id="sidebar" class="fixed inset-y-0 left-0 w-72 border-r border-slate-800 bg-[#0B1120] z-40 md:relative md:translate-x-0 closed flex flex-col p-6">
            <div class="text-xl font-extrabold mb-10 tracking-tighter hidden md:flex items-center gap-2 text-white">
                <i class="ph-fill ph-house-line text-[#F59E0B] text-2xl"></i>
                IMMOFACILE <span class="text-[#F59E0B]">CI</span>
            </div>
            
            <nav class="space-y-1 flex-1">
                <div class="text-[10px] uppercase font-bold text-slate-500 mb-2 pl-3 tracking-widest">Menu Principal</div>
                
                <a href="/admin/dashboard" class="nav-link flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-white hover:bg-white/5 rounded-xl transition group">
                    <i class="ph-bold ph-chart-pie-slice group-hover:text-[#F59E0B] transition-colors"></i>
                    Vue d'ensemble
                </a>
                <a href="#" class="nav-link flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-white hover:bg-white/5 rounded-xl transition group">
                    <i class="ph ph-users group-hover:text-blue-400 transition-colors"></i>
                    Propriétaires
                </a>
                <a href="#" class="nav-link flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-white hover:bg-white/5 rounded-xl transition group">
                    <i class="ph ph-wallet group-hover:text-green-400 transition-colors"></i>
                    Finances
                </a>
                <a href="#" class="nav-link flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-white hover:bg-white/5 rounded-xl transition group">
                    <i class="ph ph-gear group-hover:text-purple-400 transition-colors"></i>
                    Paramètres
                </a>
            </nav>

            <div class="mt-auto pt-6 border-t border-slate-800">
                <div class="flex items-center gap-3 mb-6 px-2">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-slate-700 to-slate-600 flex items-center justify-center text-white font-bold border border-slate-500">
                        AD
                    </div>
                    <div>
                        <p class="text-sm font-bold text-white">Super Admin</p>
                        <p class="text-xs text-slate-500">admin@immofacile.ci</p>
                    </div>
                </div>
                <a href="/logout" class="flex items-center justify-center gap-2 px-4 py-2 text-red-400 hover:text-white hover:bg-red-500 rounded-xl transition font-bold text-sm bg-red-500/10 border border-red-500/20">
                    <i class="ph-bold ph-sign-out"></i> Déconnexion
                </a>
            </div>
        </aside>

        <div id="overlay" onclick="toggleMenu()" class="fixed inset-0 bg-black/60 z-30 hidden md:hidden backdrop-blur-sm transition-opacity"></div>

        <main class="flex-1 overflow-y-auto w-full relative">
            <div class="p-6 md:p-10 max-w-7xl mx-auto pb-24">
                
                <header class="mb-10">
                    <div class="flex flex-col md:flex-row justify-between md:items-end gap-4 mb-8">
                        <div>
                            <p class="text-xs font-bold text-[#F59E0B] uppercase tracking-widest mb-1 flex items-center gap-2">
                                <span class="w-2 h-2 rounded-full bg-[#F59E0B] animate-pulse"></span>
                                Live Dashboard
                            </p>
                            <h1 class="text-3xl md:text-4xl font-bold text-white">Performance Lancement</h1>
                        </div>
                        <div class="flex gap-3">
                            <button onclick="exportToCSV()" class="bg-slate-800 hover:bg-slate-700 text-white px-4 py-2 rounded-xl font-bold text-sm border border-slate-700 flex items-center gap-2 transition hover:shadow-lg">
                                <i class="ph-bold ph-download-simple"></i> Export CSV
                            </button>
                        </div>
                    </div>

                    <% 
                        const CONFIG = { GOAL: 50, PRICE: 5000 };
                        const percentGoal = Math.min((leadsCount / CONFIG.GOAL) * 100, 100);
                        const potentialRevenue = leadsCount * CONFIG.PRICE;
                    %>

                    <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                        <article class="glass-card p-6 rounded-[1.5rem] relative overflow-hidden group">
                            <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition duration-500">
                                <i class="ph-fill ph-users-three text-8xl text-white"></i>
                            </div>
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <p class="text-slate-400 text-xs font-bold uppercase tracking-wider">Total Inscrits</p>
                                    <h3 class="text-4xl font-black text-white mt-1"><%= leadsCount %></h3>
                                </div>
                                <span class="bg-green-500/20 text-green-400 px-2 py-1 rounded-lg text-xs font-bold flex items-center gap-1">
                                    <i class="ph-bold ph-trend-up"></i> +12%
                                </span>
                            </div>
                            <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden">
                                <div class="bg-[#F59E0B] h-full rounded-full transition-all duration-1000 ease-out" style="width: <%= percentGoal %>%"></div>
                            </div>
                            <p class="text-xs text-slate-400 mt-2">Objectif: <%= CONFIG.GOAL %> inscrits (<%= Math.round(percentGoal) %>%)</p>
                        </article>

                        <article class="glass-card p-6 rounded-[1.5rem]">
                            <p class="text-slate-400 text-xs font-bold uppercase tracking-wider mb-1">Potentiel Mensuel</p>
                            <h3 class="text-3xl font-black text-white"><%= potentialRevenue.toLocaleString('fr-FR') %> <span class="text-lg text-slate-500 font-normal">FCFA</span></h3>
                            <p class="text-xs text-slate-400 mt-4 flex items-center gap-1">
                                <i class="ph-fill ph-info text-blue-400"></i> Basé sur <%= CONFIG.PRICE.toLocaleString('fr-FR') %>F / lead
                            </p>
                        </article>

                        <article class="glass-card p-6 rounded-[1.5rem] flex flex-col justify-between">
                            <div class="flex justify-between">
                                <p class="text-slate-400 text-xs font-bold uppercase tracking-wider">Qualité Leads</p>
                                <i class="ph-fill ph-star text-[#F59E0B] text-xl"></i>
                            </div>
                            <div class="flex items-end gap-2 mt-2">
                                <h3 class="text-3xl font-black text-white">Haute</h3>
                                <p class="text-sm text-green-400 font-bold mb-1">Top Tier</p>
                            </div>
                            <p class="text-xs text-slate-400 mt-2">Profils vérifiés par mobile.</p>
                        </article>
                    </section>

                    <section class="glass-card p-6 rounded-[1.5rem] mb-8 border border-slate-700/50">
                        <div class="flex justify-between items-center mb-6">
                            <h3 class="text-lg font-bold text-white flex items-center gap-2">
                                <i class="ph-fill ph-chart-line-up text-[#F59E0B]"></i> Croissance des Inscriptions
                            </h3>
                            <select id="chartPeriod" onchange="updateChart(this.value)" class="bg-slate-800 border border-slate-700 text-xs text-white rounded-lg px-2 py-1 outline-none hover:border-[#F59E0B] transition cursor-pointer">
                                <option value="7">7 derniers jours</option>
                                <option value="30">30 derniers jours</option>
                            </select>
                        </div>
                        <div class="h-64 w-full">
                            <canvas id="leadsChart"></canvas>
                        </div>
                    </section>
                </header>

                <section class="glass-card rounded-[1.5rem] border border-slate-700/50 overflow-hidden">
                    <div class="p-6 border-b border-slate-700/50 flex flex-col md:flex-row justify-between items-center gap-4">
                        <h3 class="text-lg font-bold text-white flex items-center gap-2">
                            Dernières Inscriptions <span class="bg-slate-700 text-xs px-2 py-0.5 rounded-full text-slate-300"><%= leads.length %></span>
                        </h3>
                        
                        <div class="relative w-full md:w-64">
                            <i class="ph ph-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="Rechercher un nom..." 
                                   class="w-full bg-slate-900/50 border border-slate-700 rounded-xl py-2 pl-10 pr-4 text-sm text-white focus:outline-none focus:border-[#F59E0B] transition placeholder-slate-500">
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse" id="leadsTable">
                            <thead>
                                <tr class="text-xs font-bold text-slate-500 uppercase bg-slate-900/50 border-b border-slate-700/50">
                                    <th class="p-4 pl-6">Utilisateur</th>
                                    <th class="p-4">Téléphone</th>
                                    <th class="p-4">Date Inscription</th>
                                    <th class="p-4 text-right pr-6">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm divide-y divide-slate-800">
                                <% if (leads.length > 0) { %>
                                    <% leads.forEach(function(lead) { %>
                                    <tr class="hover:bg-slate-800/30 transition group">
                                        <td class="p-4 pl-6">
                                            <div class="flex items-center gap-3">
                                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#F59E0B] to-orange-600 flex items-center justify-center text-white font-bold text-xs shadow-md">
                                                    <%= lead.name.charAt(0).toUpperCase() %>
                                                </div>
                                                <span class="font-bold text-slate-200 lead-name"><%= lead.name %></span>
                                            </div>
                                        </td>
                                        <td class="p-4 font-mono text-slate-400 select-all"><%= lead.phone %></td>
                                        <td class="p-4 text-slate-400 text-xs">
                                            <%= new Date(lead.createdAt).toLocaleDateString('fr-FR', {day: 'numeric', month: 'short', year: 'numeric'}) %>
                                            <span class="text-slate-500 ml-1"><%= new Date(lead.createdAt).toLocaleTimeString('fr-FR', {hour: '2-digit', minute:'2-digit'}) %></span>
                                        </td>
                                        <td class="p-4 text-right pr-6">
                                            <div class="flex items-center justify-end gap-2">
                                                <a href="https://wa.me/<%= lead.phone.replace(/\s+/g, '') %>" target="_blank" class="p-2 bg-green-500/10 text-green-400 rounded-lg hover:bg-green-500 hover:text-white transition" title="WhatsApp">
                                                    <i class="ph-fill ph-whatsapp-logo"></i>
                                                </a>
                                                <a href="tel:<%= lead.phone %>" class="p-2 bg-blue-500/10 text-blue-400 rounded-lg hover:bg-blue-500 hover:text-white transition" title="Appeler">
                                                    <i class="ph-fill ph-phone"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="4" class="p-8 text-center text-slate-500 italic">
                                            Aucune donnée disponible pour le moment.
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </section>

            </div>
        </main>
    </div>

    <script>
        // 1. DATA SETUP
        // Sécurisation contre les injections XSS
        const rawLeads = <%- JSON.stringify(leads).replace(/</g, '\\u003c') %>;
        let leadsChartInstance = null;

        // 2. CHART LOGIC
        function updateChart(days) {
            const ctx = document.getElementById('leadsChart').getContext('2d');
            const daysMap = {};
            
            // Initialiser les X derniers jours à 0
            for(let i = days - 1; i >= 0; i--) {
                const d = new Date();
                d.setDate(d.getDate() - i);
                daysMap[d.toLocaleDateString('fr-FR')] = 0;
            }
            
            // Remplir avec les vraies données
            rawLeads.forEach(l => {
                const dateKey = new Date(l.createdAt).toLocaleDateString('fr-FR');
                if (daysMap.hasOwnProperty(dateKey)) {
                    daysMap[dateKey]++;
                }
            });

            // Création du dégradé
            let gradient = ctx.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, 'rgba(245, 158, 11, 0.5)'); 
            gradient.addColorStop(1, 'rgba(245, 158, 11, 0.0)');

            // Si un graphique existe déjà, le détruire avant de recréer
            if (leadsChartInstance) {
                leadsChartInstance.destroy();
            }

            leadsChartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: Object.keys(daysMap),
                    datasets: [{
                        label: 'Nouveaux Inscrits',
                        data: Object.values(daysMap),
                        borderColor: '#F59E0B',
                        backgroundColor: gradient,
                        borderWidth: 2,
                        pointBackgroundColor: '#1e293b',
                        pointBorderColor: '#F59E0B',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { 
                            beginAtZero: true, 
                            ticks: { stepSize: 1, color: '#94a3b8' },
                            grid: { color: 'rgba(255,255,255,0.05)' } 
                        },
                        x: { 
                            ticks: { color: '#94a3b8' },
                            grid: { display: false } 
                        }
                    }
                }
            });
        }

        // 3. SEARCH FUNCTION
        function filterTable() {
            const input = document.getElementById("searchInput");
            const filter = input.value.toUpperCase();
            const table = document.getElementById("leadsTable");
            const tr = table.getElementsByTagName("tr");
            for (let i = 1; i < tr.length; i++) {
                const tdName = tr[i].querySelector(".lead-name");
                if (tdName) {
                    const txtValue = tdName.textContent || tdName.innerText;
                    if (txtValue.toUpperCase().indexOf(filter) > -1) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }       
            }
        }

        // 4. EXPORT CSV FUNCTION
        function exportToCSV() {
            let csvContent = "data:text/csv;charset=utf-8,";
            csvContent += "Nom,Telephone,Date Inscription\n";

            rawLeads.forEach(function(lead) {
                let row = `${lead.name},${lead.phone},${new Date(lead.createdAt).toLocaleDateString('fr-FR')}`;
                csvContent += row + "\n";
            });

            const encodedUri = encodeURI(csvContent);
            const link = document.createElement("a");
            link.setAttribute("href", encodedUri);
            link.setAttribute("download", "inscrits_immofacile.csv");
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        // 5. UI INTERACTION
        function toggleMenu() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('overlay');
            
            if (sidebar.classList.contains('closed')) {
                sidebar.classList.remove('closed');
                sidebar.classList.add('open');
                overlay.classList.remove('hidden');
            } else {
                sidebar.classList.add('closed');
                sidebar.classList.remove('open');
                overlay.classList.add('hidden');
            }
        }

        // 6. ACTIVE LINK HANDLER
        function setActiveLink() {
            const currentPath = window.location.pathname;
            const links = document.querySelectorAll('.nav-link');
            
            links.forEach(link => {
                // Vérifie si le href correspond à l'URL actuelle
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('active');
                    // Change aussi l'icône si nécessaire
                    const icon = link.querySelector('i');
                    if(icon && icon.classList.contains('ph')) {
                        icon.classList.remove('ph');
                        icon.classList.add('ph-fill');
                    }
                }
            });
        }

        // INIT
        document.addEventListener('DOMContentLoaded', () => {
            // Initialiser le graphique avec la valeur par défaut du select (7 jours)
            updateChart(document.getElementById('chartPeriod').value);
            setActiveLink();
        });

        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW Error:', err));
            });
        }
    </script>
</body>
</html>
