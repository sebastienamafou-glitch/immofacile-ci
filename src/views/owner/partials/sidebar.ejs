<aside id="sidebar" class="fixed inset-y-0 left-0 w-64 border-r border-slate-800 p-6 bg-[#0B1120] overflow-y-auto z-50 md:z-30 md:translate-x-0 closed shadow-2xl md:shadow-none flex flex-col transition-transform duration-300">
    
    <div class="mb-8 text-center md:text-left hidden md:block">
        <a href="/">
            <img src="/images/immo_logo.png" alt="ImmoFacile CI" class="h-14 object-contain">
        </a>
    </div>

    <nav class="space-y-1 flex-1">
        
        <% if (user.role === 'ADMIN') { %>
            <a href="/admin/dashboard" class="block p-3 bg-red-600 rounded-xl text-white font-bold hover:bg-red-700 transition flex items-center gap-3 shadow-lg mb-6">
                <i class="ph-fill ph-shield-star text-xl"></i>
                <span>Admin Panel</span>
            </a>
        <% } else if (user.role === 'INVESTOR') { %>
            <a href="/investor/dashboard" class="block p-3 bg-blue-600 rounded-xl text-white font-bold hover:bg-blue-700 transition flex items-center gap-3 shadow-lg mb-6">
                <i class="ph-fill ph-chart-line-up text-xl"></i>
                <span>Mon Portefeuille</span>
            </a>
        <% } else { %>
            <a href="/owner/dashboard" class="block p-3 bg-blue-600 rounded-xl text-white font-bold hover:bg-blue-700 transition flex items-center gap-3 shadow-lg mb-6">
                <i class="ph-fill ph-squares-four text-xl"></i>
                <span>Tableau de bord</span>
            </a>
        <% } %>

        <% if (user.role === 'INVESTOR' || user.role === 'ADMIN') { %>
            <div class="mb-6 space-y-1">
                <p class="text-[10px] uppercase text-slate-500 font-bold ml-3 mb-2 tracking-widest">Investissement</p>
                
                <a href="/investor/opportunities" class="block p-3 text-slate-300 hover:bg-slate-800/50 rounded-xl transition flex items-center gap-3">
                    <i class="ph-bold ph-hand-coins text-xl text-purple-400"></i> Opportunités
                </a>

                <button onclick="exportMyData()" class="w-full text-left p-3 text-slate-300 hover:bg-slate-800/50 rounded-xl transition flex items-center gap-3">
                    <i class="ph-bold ph-file-arrow-down text-xl text-green-400"></i> Exporter mes relevés
                </button>
            </div>
        <% } %>

        <% if (user.role === 'ADMIN') { %>
            <div class="mb-6 space-y-1">
                <p class="text-[10px] uppercase text-slate-500 font-bold ml-3 mb-2 tracking-widest">Administration</p>
                <a href="/admin/logs" class="block p-3 text-slate-300 hover:bg-slate-800/50 rounded-xl transition flex items-center gap-3">
                    <i class="ph-bold ph-list-checks text-xl"></i> Logs d'audit
                </a>
            </div>
        <% } %>

        <div class="border-t border-slate-800 pt-4 mt-auto">
            <a href="/logout" class="block p-3 text-red-400 hover:bg-red-500/10 rounded-xl transition flex items-center gap-3">
                <i class="ph-bold ph-sign-out text-xl"></i> Déconnexion
            </a>
        </div>
    </nav>

    <div class="mt-6 bg-[#0B1120] border border-blue-900/30 p-3 rounded-xl">
        <div class="flex items-center gap-3">
            <i class="ph-fill ph-shield-check text-2xl text-blue-500"></i>
            <p class="text-[10px] text-slate-400 leading-tight">
                Certifié <strong class="text-blue-400">SHA-256</strong> & Loi 2024-1115.
            </p>
        </div>
    </div>
</aside>

<script>
    async function exportMyData() {
        try {
            const res = await fetch('/investor/export');
            const data = await res.json();
            if (data.success) {
                const blob = new Blob([JSON.stringify(data.data, null, 2)], { type: 'application/json' });
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `mon_portefeuille_${new Date().toLocaleDateString()}.json`;
                a.click();
            }
        } catch (e) {
            console.error("Erreur d'exportation");
        }
    }
</script>
