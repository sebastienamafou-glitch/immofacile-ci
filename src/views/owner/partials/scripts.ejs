<script>
    // --- 1. Gestion du Menu Burger Mobile ---
    function toggleMenu() {
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('overlay');
        // Vérification si les éléments existent avant d'agir
        if(!sidebar || !overlay) return;

        if (sidebar.classList.contains('closed')) {
            sidebar.classList.remove('closed');
            sidebar.classList.add('open');
            overlay.classList.remove('hidden');
        } else {
            sidebar.classList.add('closed');
            sidebar.classList.remove('open');
            overlay.classList.add('hidden');
        }
    }

    function closeMenuMobile() {
        if (window.innerWidth < 768) {
            toggleMenu();
        }
    }

    // --- 2. Gestion des Modals ---
    function openExitModal(leaseId, tenantName, deposit) {
        document.getElementById('exitModal').classList.remove('hidden');
        document.getElementById('exitLeaseId').value = leaseId;
        document.getElementById('exitTenantName').innerText = "Fin de bail pour : " + tenantName;
        document.getElementById('exitDepositDisplay').innerText = (parseInt(deposit) || 0).toLocaleString('fr-FR') + " FCFA";
    }

    function closeNewTenantModal() {
        document.getElementById('newTenantModal').classList.add('hidden');
    }

    // --- 3. Filtre de Recherche Global ---
    function filterAll() {
        const input = document.getElementById('globalSearch');
        if(!input) return;
        const filter = input.value.toUpperCase();
        const items = document.querySelectorAll('.searchable-item');

        items.forEach(item => {
            const text = item.innerText || item.textContent;
            if (text.toUpperCase().indexOf(filter) > -1) {
                item.style.display = ""; 
            } else {
                item.style.display = "none";
            }
        });
    }

    // --- 4. Initialisation Chart.js (Graphique) ---
    document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('financeChart');
        if(ctx) {
            const context = ctx.getContext('2d');
            const revenus = Number('<%= typeof totalRent !== "undefined" ? totalRent : 0 %>');
            const depenses = Number('<%= typeof totalExpenses !== "undefined" ? totalExpenses : 0 %>');

            new Chart(context, {
                type: 'bar',
                data: {
                    labels: ['Revenus', 'Dépenses'],
                    datasets: [{
                        label: 'Montant (FCFA)',
                        data: [revenus, depenses],
                        backgroundColor: ['rgba(34, 197, 94, 0.7)', 'rgba(239, 68, 68, 0.7)'],
                        borderColor: ['rgb(34, 197, 94)', 'rgb(239, 68, 68)'],
                        borderWidth: 1,
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: 'rgba(255, 255, 255, 0.1)' }, ticks: { color: '#94a3b8' } },
                        x: { grid: { display: false }, ticks: { color: '#ffffff', font: { weight: 'bold' } } }
                    }
                }
            });
        }
    });

    // --- 5. Pop-up Succès Création Locataire ---
    document.addEventListener('DOMContentLoaded', function() {
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('success') === 'tenant_added' && urlParams.get('new_pass')) {
            const name = urlParams.get('new_user');
            const phone = urlParams.get('new_phone');
            const pass = urlParams.get('new_pass');

            document.getElementById('modalNewUser').innerText = name;
            document.getElementById('modalNewPhone').innerText = phone;
            document.getElementById('modalNewPass').innerText = pass;

            const waMsg = `Bonjour ${name}, bienvenue sur ImmoFacile ! Voici tes accès : \n\n📱 Identifiant: ${phone}\n🔑 Mot de passe: ${pass}\n\nConnecte-toi ici : https://immofacile-ci.vercel.app/login`;
            let cleanPhone = phone.replace(/\s+/g, '').replace(/^(\+)?/, '');
            if (cleanPhone.length === 10) cleanPhone = '225' + cleanPhone;
            
            document.getElementById('shareWaBtn').href = `https://wa.me/${cleanPhone}?text=${encodeURIComponent(waMsg)}`;
            document.getElementById('newTenantModal').classList.remove('hidden');

            if (window.history.replaceState) {
                const cleanUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
                window.history.replaceState({path: cleanUrl}, '', cleanUrl);
            }
        }
    });

    // Service Worker
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW Erreur', err));
        });
    }
</script>
