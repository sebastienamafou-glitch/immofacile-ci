<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% if (typeof tenants !== 'undefined' && tenants.length > 0) { %>
        <% tenants.forEach(function(lease) { %>
            
            <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md transition group">
                
                <div class="flex justify-between items-start mb-4">
                    <div class="flex items-center gap-3">
                        <div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center text-xl">
                            👤
                        </div>
                        <div>
                            <h3 class="font-bold text-[#0B1120] flex items-center gap-2">
                                <%= lease.tenant.name %>
                                <% if (lease.tenant.tenantProfile && lease.tenant.tenantProfile.idCardStatus === 'VALIDATED') { %>
                                    <span title="Identité Vérifiée par IA" class="text-blue-500 text-[10px]">✅</span>
                                    <% } %>
                            </h3>
                            <p class="text-xs text-slate-500 font-bold"><%= lease.property.title %></p>
                        </div>
                    </div>
                    
                    <% if (lease.isActive) { %>
                        <span class="bg-green-100 text-green-700 text-[10px] px-2 py-1 rounded-full font-bold uppercase">Actif</span>
                    <% } else { %>
                        <span class="bg-orange-100 text-orange-700 text-[10px] px-2 py-1 rounded-full font-bold uppercase">En Attente</span>
                    <% } %>
                </div>

                <div class="bg-slate-50 rounded-xl p-3 mb-4 flex justify-between items-center">
                    <span class="text-xs text-slate-500 uppercase font-bold">Loyer</span>
                    <span class="font-bold text-[#0B1120]"><%= lease.monthlyRent.toLocaleString('fr-FR') %> FCFA</span>
                </div>

                <div class="grid grid-cols-2 gap-2 mt-4">
                    
                    <a href="/chat/whatsapp?targetUserId=<%= lease.tenant.id %>&context=WELCOME" 
                       target="_blank"
                       class="flex items-center justify-center gap-2 bg-slate-100 hover:bg-slate-200 text-slate-600 py-3 rounded-xl font-bold text-xs transition">
                        💬 Discuter
                    </a>

                    <a href="/chat/whatsapp?targetUserId=<%= lease.tenant.id %>&context=RENT_REMINDER" 
                       target="_blank"
                       class="flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#20bd5a] text-white py-3 rounded-xl font-bold text-xs transition shadow-lg shadow-green-500/20">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.017-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
                        <span>Relancer</span>
                    </a>
                </div>

            </div>
        <% }); %>
    <% } else { %>
        <div class="col-span-3 text-center py-12 bg-slate-900/50 rounded-2xl border border-dashed border-slate-700">
            <p class="text-slate-400">Aucun locataire actif.</p>
        </div>
    <% } %>
</div>
