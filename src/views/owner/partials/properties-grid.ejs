<section id="biens" class="mb-10 pt-10 border-t border-slate-800">
    <div class="flex justify-between items-center mb-6">
        <h3 class="text-xl font-bold flex items-center gap-2 text-white">
            <span>🏠</span> Mes Biens
        </h3>
        
        <a href="/owner/add-property" class="hidden md:flex bg-[#F59E0B] text-[#0B1120] px-5 py-2 rounded-xl font-bold text-sm hover:bg-yellow-400 hover:scale-105 transition items-center gap-2 shadow-lg shadow-yellow-500/10">
            <span class="text-lg">+</span> Nouveau Bien
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <% properties.forEach(function(prop) { %>
            <div class="bg-slate-900/50 border border-slate-800 rounded-2xl overflow-hidden hover:border-slate-700 transition group relative">
                
                <a href="/owner/property/<%= prop.id %>" class="block h-48 w-full bg-slate-800 relative overflow-hidden">
                    <% if (prop.images && prop.images.length > 0) { %>
                        <img src="<%= prop.images[0] %>" alt="<%= prop.title %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
                    <% } else if (prop.imageUrl) { %>
                        <img src="<%= prop.imageUrl %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
                    <% } else { %>
                        <div class="w-full h-full flex items-center justify-center text-4xl bg-slate-800 text-slate-700">🏠</div>
                    <% } %>
                    
                    <div class="absolute bottom-3 right-3 bg-black/70 backdrop-blur-md px-3 py-1 rounded-lg border border-white/10">
                        <span class="text-white font-bold text-xs"><%= formatMoney(prop.price) %> FCFA</span>
                    </div>
                </a>

                <div class="p-5">
                    <div class="flex justify-between items-start mb-2">
                        <h4 class="font-bold text-white text-lg"><%= prop.title %></h4>
                        <span class="text-xs text-slate-400 bg-slate-800 px-2 py-1 rounded border border-slate-700"><%= prop.commune %></span>
                    </div>
                </div>
            </div>
        <% }); %>
        
        <% if (properties.length === 0) { %>
            <div class="col-span-full py-12 text-center border-2 border-dashed border-slate-800 rounded-3xl">
                <p class="text-4xl mb-4">🏚️</p>
                <p class="text-slate-500">Vous n'avez pas encore ajouté de bien.</p>
                <a href="/owner/add-property" class="text-[#F59E0B] font-bold hover:underline mt-2 inline-block">Ajouter mon premier bien</a>
            </div>
        <% } %>
    </div>
</section>
