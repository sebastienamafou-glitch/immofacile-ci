<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Espace Propriétaire | ImmoFacile V4</title>
    
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0B1120">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; scroll-behavior: smooth; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
        .glass-panel { background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.05); }
        .glass-card { background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(255,255,255,0.03); transition: all 0.3s ease; }
        .glass-card:hover { transform: translateY(-2px); border-color: rgba(255,255,255,0.1); }
    </style>
</head>
<body class="bg-[#0B1120] text-slate-200 custom-scrollbar">

    <div id="globalLoader" class="fixed inset-0 z-[100] flex flex-col items-center justify-center bg-[#0B1120] transition-opacity duration-500">
        <div class="w-16 h-16 border-4 border-slate-800 border-t-[#F59E0B] rounded-full animate-spin"></div>
        <p class="mt-4 text-xs font-bold text-slate-500 uppercase tracking-widest animate-pulse">Chargement V4...</p>
    </div>

    <div class="flex min-h-screen">
        <%- include('../partials/sidebar') %>

        <main class="flex-1 md:ml-72 p-6 lg:p-10 max-w-7xl mx-auto w-full">
            
            <header class="flex flex-col md:flex-row justify-between items-end mb-10 gap-6">
                <div>
                    <h1 class="text-3xl font-black text-white uppercase tracking-tight">
                        Bonjour <%= user.name.split(' ')[0] %> 👋
                    </h1>
                    <p class="text-slate-400 mt-2 flex items-center gap-2 text-sm">
                        <span class="relative flex h-2 w-2">
                          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                        </span>
                        <span>Espace Propriétaire V4 • Actif</span>
                    </p>
                </div>

                <div class="bg-gradient-to-r from-blue-900 to-slate-900 p-0.5 rounded-2xl shadow-2xl w-full md:w-auto hover:shadow-blue-900/20 transition group">
                    <div class="bg-[#0B1120] rounded-2xl px-6 py-4 flex items-center gap-6 relative overflow-hidden">
                        <div class="absolute right-0 top-0 p-4 opacity-10 group-hover:opacity-20 transition">
                            <i class="ph-fill ph-wallet text-6xl text-blue-500"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Solde Disponible</p>
                            <p class="text-3xl font-black text-white">
                                <%= user.walletBalance ? user.walletBalance.toLocaleString('fr-FR') : '0' %> <span class="text-base font-normal text-slate-500">FCFA</span>
                            </p>
                        </div>
                        <div class="h-10 w-px bg-slate-800"></div>
                        <button onclick="requestWithdrawal()" class="flex flex-col items-center gap-1 text-blue-400 hover:text-white transition group/btn">
                            <div class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center group-hover/btn:bg-blue-500 transition">
                                <i class="ph-bold ph-download-simple"></i>
                            </div>
                            <span class="text-[9px] font-bold uppercase mt-1">Retrait</span>
                        </button>
                    </div>
                </div>
            </header>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-12">
                <div class="glass-panel p-5 rounded-2xl border-l-4 border-[#F59E0B]">
                    <p class="text-slate-400 text-xs font-bold uppercase mb-1">Revenus (Mois)</p>
                    <p class="text-2xl font-black text-white"><%= totalRent ? totalRent.toLocaleString('fr-FR') : '0' %> <span class="text-sm font-normal text-slate-500">F</span></p>
                </div>
                <div class="glass-panel p-5 rounded-2xl border-l-4 border-blue-500">
                    <p class="text-slate-400 text-xs font-bold uppercase mb-1">Dépôts / Caution</p>
                    <p class="text-2xl font-black text-white"><%= totalDeposit ? totalDeposit.toLocaleString('fr-FR') : '0' %> <span class="text-sm font-normal text-slate-500">F</span></p>
                </div>
                <div class="glass-panel p-5 rounded-2xl border-l-4 border-red-500">
                    <p class="text-slate-400 text-xs font-bold uppercase mb-1">Dépenses</p>
                    <p class="text-2xl font-black text-white"><%= totalExpenses ? totalExpenses.toLocaleString('fr-FR') : '0' %> <span class="text-sm font-normal text-slate-500">F</span></p>
                </div>
                <div class="glass-panel p-5 rounded-2xl border-l-4 border-emerald-500">
                    <p class="text-slate-400 text-xs font-bold uppercase mb-1">Résultat Net</p>
                    <p class="text-2xl font-black text-emerald-400"><%= netIncome ? netIncome.toLocaleString('fr-FR') : '0' %> <span class="text-sm font-normal text-emerald-600/50">F</span></p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
                
                <div class="lg:col-span-2 space-y-8">
                    
                    <section id="properties" class="scroll-mt-24">
                        <div class="flex justify-between items-center mb-6">
                            <h3 class="text-lg font-bold text-white flex items-center gap-2">
                                <i class="ph-fill ph-house-line text-blue-500"></i> Vos Biens Immobiliers
                            </h3>
                            <a href="/owner/add-property" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-xl text-xs font-bold transition flex items-center gap-2">
                                <i class="ph-bold ph-plus"></i> Ajouter un bien
                            </a>
                        </div>

                        <% if (properties && properties.length > 0) { %>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <% properties.forEach(prop => { %>
                                    <div class="glass-card rounded-2xl overflow-hidden group">
                                        <div class="h-32 bg-slate-800 relative">
                                            <% if (prop.images && prop.images.length > 0) { %>
                                                <img src="<%= prop.images[0] %>" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition">
                                            <% } else { %>
                                                <div class="flex items-center justify-center h-full text-slate-600"><i class="ph-duotone ph-image text-4xl"></i></div>
                                            <% } %>
                                            <div class="absolute top-3 right-3 bg-black/60 backdrop-blur-sm px-2 py-1 rounded text-[10px] font-bold text-white border border-white/10">
                                                <%= prop.price.toLocaleString('fr-FR') %> F
                                            </div>
                                        </div>
                                        <div class="p-4">
                                            <h4 class="font-bold text-white truncate"><%= prop.title %></h4>
                                            <p class="text-xs text-slate-400 flex items-center gap-1 mt-1">
                                                <i class="ph-fill ph-map-pin text-slate-500"></i> <%= prop.commune %>
                                            </p>
                                            <div class="mt-4 flex items-center justify-between border-t border-white/5 pt-3">
                                                <span class="text-[10px] font-bold <%= prop.leases && prop.leases.some(l => l.isActive) ? 'text-emerald-400' : 'text-orange-400' %> uppercase tracking-wider">
                                                    <%= prop.leases && prop.leases.some(l => l.isActive) ? 'Loué' : 'Vacant' %>
                                                </span>
                                                <a href="/property/<%= prop.id %>" class="text-xs text-blue-400 hover:text-white font-bold">Gérer</a>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <div class="text-center py-10 bg-slate-900/50 rounded-2xl border border-dashed border-slate-800">
                                <i class="ph-duotone ph-house text-4xl text-slate-600 mb-3"></i>
                                <p class="text-sm text-slate-500">Aucun bien enregistré.</p>
                            </div>
                        <% } %>
                    </section>

                    <section id="tenants" class="scroll-mt-24">
                        <div class="flex justify-between items-center mb-6">
                            <h3 class="text-lg font-bold text-white flex items-center gap-2">
                                <i class="ph-fill ph-users text-purple-500"></i> Locataires Actifs
                            </h3>
                            <a href="/owner/add-tenant" class="text-xs font-bold text-slate-400 hover:text-white transition">Nouveau bail +</a>
                        </div>

                        <div class="glass-panel rounded-2xl overflow-hidden">
                            <table class="w-full text-left text-sm">
                                <thead class="bg-slate-900/50 text-slate-500 text-[10px] uppercase font-bold border-b border-white/5">
                                    <tr>
                                        <th class="p-4">Locataire</th>
                                        <th class="p-4">Bien Loué</th>
                                        <th class="p-4 text-right">Loyer</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-white/5">
                                    <% let hasTenants = false; %>
                                    <% properties.forEach(prop => { %>
                                        <% if (prop.leases) { %>
                                            <% prop.leases.forEach(lease => { %>
                                                <% if (lease.isActive && lease.tenant) { hasTenants = true; %>
                                                    <tr class="hover:bg-white/5 transition">
                                                        <td class="p-4">
                                                            <p class="font-bold text-white"><%= lease.tenant.name %></p>
                                                            <a href="tel:<%= lease.tenant.phone %>" class="text-xs text-slate-400 hover:text-blue-400 font-mono"><%= lease.tenant.phone %></a>
                                                        </td>
                                                        <td class="p-4 text-slate-300 text-xs"><%= prop.title %></td>
                                                        <td class="p-4 text-right font-mono font-bold text-emerald-400">
                                                            <%= lease.monthlyRent.toLocaleString('fr-FR') %> F
                                                        </td>
                                                    </tr>
                                                <% } %>
                                            <% }) %>
                                        <% } %>
                                    <% }) %>
                                    
                                    <% if (!hasTenants) { %>
                                        <tr><td colspan="3" class="p-6 text-center text-slate-500 text-xs italic">Aucun locataire actif pour le moment.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </section>
                </div>

                <div class="space-y-8">
                    
                    <div id="artisans" class="bg-white rounded-3xl p-6 border border-slate-100 shadow-xl text-slate-900 scroll-mt-24">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="font-black text-lg flex items-center gap-2">
                                <i class="ph-duotone ph-toolbox text-orange-500"></i> Artisans
                            </h3>
                            <button onclick="addArtisanModal()" class="w-8 h-8 bg-slate-100 rounded-full flex items-center justify-center hover:bg-slate-200 transition"><i class="ph-bold ph-plus"></i></button>
                        </div>
                        <div class="space-y-3 max-h-64 overflow-y-auto custom-scrollbar pr-1">
                            <% if (artisans && artisans.length > 0) { %>
                                <% artisans.forEach(a => { %>
                                    <div class="flex items-center justify-between p-3 border border-slate-100 rounded-xl hover:bg-slate-50 transition group">
                                        <div>
                                            <p class="font-bold text-sm"><%= a.name %></p>
                                            <p class="text-[10px] text-slate-500 uppercase font-bold tracking-wide"><%= a.job %></p>
                                        </div>
                                        <a href="tel:<%= a.phone %>" class="w-8 h-8 rounded-lg bg-green-100 text-green-600 flex items-center justify-center hover:scale-110 transition">
                                            <i class="ph-fill ph-phone"></i>
                                        </a>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p class="text-xs text-slate-400 text-center py-4">Annuaire vide.</p>
                            <% } %>
                        </div>
                    </div>

                    <div class="glass-card rounded-3xl p-6">
                        <h3 class="font-bold text-white mb-4 flex items-center gap-2">
                            <i class="ph-duotone ph-files text-purple-400"></i> Documents
                        </h3>
                        <div class="space-y-2">
                            <a href="/owner/tax-summary" class="w-full flex items-center gap-3 p-3 rounded-xl bg-white/5 hover:bg-white/10 transition text-left group">
                                <i class="ph-file-text text-blue-400 text-xl group-hover:scale-110 transition"></i>
                                <div>
                                    <p class="text-sm font-bold text-slate-200">Relevé Fiscal</p>
                                    <p class="text-[10px] text-slate-500">Pour déclaration d'impôts</p>
                                </div>
                            </a>
                        </div>
                    </div>

                    <div class="glass-panel p-6 rounded-3xl border border-red-500/20">
                        <div class="flex items-center gap-3 mb-2">
                            <div class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></div>
                            <h3 class="font-bold text-red-400 text-sm uppercase tracking-wide">Incidents en cours</h3>
                        </div>
                        <p class="text-3xl font-black text-white"><%= activeIncidentsCount || 0 %></p>
                        <p class="text-xs text-slate-500 mt-1">Requêtes locataires non résolues.</p>
                        <% if(activeIncidentsCount > 0) { %>
                            <a href="/owner/incidents" class="block mt-4 text-center text-xs font-bold bg-red-500/10 text-red-400 py-2 rounded-lg hover:bg-red-500 hover:text-white transition">Voir les détails</a>
                        <% } %>
                    </div>

                </div>
            </div>

        </main>
    </div>

    <script>
        // LOADER
        window.addEventListener('load', () => {
            const loader = document.getElementById('globalLoader');
            if(loader) {
                setTimeout(() => {
                    loader.style.opacity = '0';
                    setTimeout(() => loader.style.display = 'none', 500);
                }, 600);
            }
        });

        // GESTION INTELLIGENTE DES NOTIFICATIONS ET POPUPS (CLIENT-SIDE)
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            
            // 1. POPUP LOCATAIRE (Avec identifiants)
            if (urlParams.has('new_pass')) {
                const newUser = urlParams.get('new_user');
                const newPass = urlParams.get('new_pass');
                const newPhone = urlParams.get('new_phone');

                Swal.fire({
                    title: '🎉 Locataire créé !',
                    html: `
                        <div class="bg-slate-100 p-4 rounded-xl text-left text-slate-800 mb-4">
                            <p class="mb-2">Transmettez ces accès au locataire :</p>
                            <p><strong>Nom :</strong> ${newUser}</p>
                            <p><strong>Identifiant :</strong> ${newPhone}</p>
                            <div class="flex items-center gap-2 mt-2 bg-white p-2 rounded border border-slate-200">
                                <code class="text-xl font-mono font-bold text-[#F59E0B]">${newPass}</code>
                            </div>
                            <p class="text-xs text-red-500 mt-2">⚠️ Notez-le, il ne s'affichera qu'une seule fois.</p>
                        </div>
                    `,
                    icon: 'success',
                    confirmButtonText: 'C\'est noté',
                    confirmButtonColor: '#0B1120',
                    background: '#fff',
                    allowOutsideClick: false
                }).then(() => {
                    window.history.replaceState({}, document.title, window.location.pathname);
                });
            }

            // 2. GESTION SUCCÈS GÉNÉRAL
            const success = urlParams.get('success');
            if (success) {
                let msg = 'Opération réussie';
                if (success === 'withdrawal_initiated') msg = 'Demande de retrait envoyée.';
                if (success === 'tenant_added') msg = 'Locataire ajouté avec succès.';
                if (success === 'property_created') msg = 'Bien immobilier créé.';
                
                Swal.fire({ 
                    toast: true, position: 'top-end', icon: 'success', 
                    title: 'Succès', text: msg, 
                    showConfirmButton: false, timer: 4000, background: '#1e293b', color: '#fff' 
                });
            }

            // 3. GESTION ERREURS
            const error = urlParams.get('error');
            if (error) {
                let msg = 'Une erreur est survenue.';
                if (error === 'illegal_deposit') msg = 'La caution ne peut excéder 4 mois (Loi 2019).';
                if (error === 'withdrawal_failed') msg = 'Solde insuffisant.';
                
                Swal.fire({ 
                    toast: true, position: 'top-end', icon: 'error', 
                    title: 'Erreur', text: msg, 
                    showConfirmButton: false, timer: 4000, background: '#1e293b', color: '#fff' 
                });
            }
        });

        // FONCTION AJOUT ARTISAN (Réparée avec CSRF)
        async function addArtisanModal() {
            const { value: formValues } = await Swal.fire({
                title: 'Nouvel Artisan',
                html:
                    '<input id="swal-name" class="swal2-input" placeholder="Nom (ex: Koné Plomberie)">' +
                    '<select id="swal-job" class="swal2-input">' +
                        '<option value="Plombier">Plombier</option>' +
                        '<option value="Électricien">Électricien</option>' +
                        '<option value="Menuisier">Menuisier</option>' +
                        '<option value="Peintre">Peintre</option>' +
                        '<option value="Climatisation">Climatisation</option>' +
                    '</select>' +
                    '<input id="swal-phone" class="swal2-input" placeholder="Téléphone (07...)">',
                focusConfirm: false,
                showCancelButton: true,
                confirmButtonText: 'Ajouter',
                confirmButtonColor: '#0B1120',
                preConfirm: () => {
                    return {
                        name: document.getElementById('swal-name').value,
                        job: document.getElementById('swal-job').value,
                        phone: document.getElementById('swal-phone').value
                    }
                }
            });

            if (formValues) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/owner/add-artisan';
                
                // Injection CSRF Token depuis le serveur
                const csrfInput = document.createElement('input');
                csrfInput.type = 'hidden';
                csrfInput.name = '_csrf';
                csrfInput.value = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';
                form.appendChild(csrfInput);

                for (const key in formValues) {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = key;
                    input.value = formValues[key];
                    form.appendChild(input);
                }
                document.body.appendChild(form);
                form.submit();
            }
        }

        // FONCTION RETRAIT (Réparée avec CSRF)
        async function requestWithdrawal() {
            const { value: formValues } = await Swal.fire({
                title: 'Effectuer un retrait',
                html:
                    '<input id="swal-amount" type="number" class="swal2-input" placeholder="Montant (FCFA)">' +
                    '<input id="swal-details" class="swal2-input" placeholder="Numéro Wave/OM">',
                focusConfirm: false,
                showCancelButton: true,
                confirmButtonColor: '#0B1120',
                preConfirm: () => {
                    return {
                        amount: document.getElementById('swal-amount').value,
                        paymentDetails: document.getElementById('swal-details').value
                    }
                }
            });

            if (formValues) {
                if(!formValues.amount || !formValues.paymentDetails) return;
                
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/owner/request-withdrawal';
                
                const csrfInput = document.createElement('input');
                csrfInput.type = 'hidden';
                csrfInput.name = '_csrf';
                csrfInput.value = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';
                form.appendChild(csrfInput);

                for (const key in formValues) {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = key;
                    input.value = formValues[key];
                    form.appendChild(input);
                }
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
</body>
</html>
