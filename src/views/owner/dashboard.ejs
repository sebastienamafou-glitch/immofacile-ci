<!DOCTYPE html>
<html lang="fr">
<% 
    const formatMoney = (amount) => (amount || 0).toLocaleString('fr-FR');
    const formatWaLink = (phone, text = '') => {
        if (!phone) return '#';
        let clean = phone.replace(/\D/g, '');
        if (clean.length === 10) clean = '225' + clean;
        return `https://wa.me/${clean}${text ? '?text=' + encodeURIComponent(text) : ''}`;
    };
%>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Propriétaire | ImmoFacile CI</title>
    
    <meta name="author" content="WebAppCI SARL">
    <meta name="copyright" content="WebAppCI SARL">
    
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0B1120">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="bg-[#0B1120] text-white font-['Plus_Jakarta_Sans']">

    <div id="globalLoader" class="hidden fixed inset-0 z-[100] flex flex-col items-center justify-center bg-[#0B1120]/80 backdrop-blur-sm">
        <div class="w-16 h-16 border-4 border-slate-700 border-t-[#F59E0B] rounded-full animate-spin"></div>
    </div>

    <div class="flex min-h-screen">
        <%- include('partials/sidebar') %>

        <main class="flex-1 p-4 md:p-8 md:ml-64 w-full">
            <%- include('partials/stats-header') %>
            <%- include('partials/properties-grid') %>
            <%- include('partials/section-tenants') %> 
            <%- include('partials/section-documents') %>
            <%- include('partials/section-artisans') %>
        </main>
    </div>

    <%- include('partials/fab-actions') %>

    <%- include('partials/modals') %>
    <%- include('partials/scripts') %>

</body>
</html>
