<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Solde Insuffisant | ImmoFacile</title>
    
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0B1120">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="icon" type="image/png" href="/images/immo_logo.png">
    <link rel="apple-touch-icon" href="/images/immo_logo.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body class="bg-[#0B1120] text-white font-['Plus_Jakarta_Sans'] flex items-center justify-center min-h-screen p-4">

    <div class="bg-slate-900 border border-slate-800 p-8 rounded-3xl max-w-md w-full text-center shadow-2xl">
        <div class="w-20 h-20 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-4xl">💸</span>
        </div>
        
        <h1 class="text-2xl font-black text-white mb-2">Oups ! Solde insuffisant</h1>
        <p class="text-slate-400 mb-8">
            Pour effectuer cette opération, vous devez avoir un solde positif pour couvrir les frais de commission.
        </p>

        <div class="bg-slate-800 p-4 rounded-xl mb-8 border border-slate-700">
            <p class="text-xs text-slate-500 uppercase font-bold mb-1">Votre solde actuel</p>
            <p class="text-2xl font-mono text-red-500 font-bold">
                <%= typeof user !== 'undefined' ? user.walletBalance.toLocaleString('fr-FR') : 0 %> FCFA
            </p>
        </div>

        <div class="space-y-3">
            <button onclick="document.getElementById('rechargeModal').classList.remove('hidden')" class="w-full bg-[#F59E0B] hover:bg-yellow-400 text-[#0B1120] font-bold py-4 rounded-xl transition">
                ⚡️ Recharger mon compte
            </button>
            
            <a href="/owner/dashboard" class="block w-full bg-slate-800 hover:bg-slate-700 text-white font-bold py-4 rounded-xl transition">
                Retour au tableau de bord
            </a>
        </div>
    </div>

    <div id="rechargeModal" class="hidden fixed inset-0 bg-black/90 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
        <div class="bg-slate-900 border border-slate-700 p-8 rounded-3xl w-full max-w-sm relative shadow-2xl">
            <button onclick="document.getElementById('rechargeModal').classList.add('hidden')" class="absolute top-4 right-4 text-slate-500 hover:text-white transition">✕</button>
            <div class="text-center mb-6">
                <h2 class="text-xl font-bold text-white mb-2">Recharger mon compte</h2>
                <p class="text-slate-400 text-sm">Paiement sécurisé via CinetPay</p>
            </div>
            
            <form action="/api/payment/init" method="POST" class="space-y-4">
                <% if(typeof csrfToken !== 'undefined') { %>
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% } %>

                <select name="amount" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white font-bold outline-none focus:border-[#F59E0B]">
                    <option value="5000">5 000 FCFA</option>
                    <option value="10000" selected>10 000 FCFA</option>
                    <option value="20000">20 000 FCFA</option>
                    <option value="50000">50 000 FCFA</option>
                </select>
                <button type="submit" class="w-full bg-[#F59E0B] text-[#0B1120] font-black py-4 rounded-xl hover:bg-yellow-400 transition">Payer maintenant</button>
            </form>
        </div>
    </div>

    <script>
        // PWA Service Worker (Comme dans le dashboard)
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW Erreur', err));
            });
        }
    </script>

</body>
</html>
