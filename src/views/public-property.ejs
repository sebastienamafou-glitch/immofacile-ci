<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>À Louer : <%= property.title %> | ImmoFacile</title>
    <meta name="description" content="Découvrez ce bien à <%= property.commune %> pour <%= property.price.toLocaleString('fr-FR') %> FCFA.">
    
    <meta property="og:title" content="<%= property.title %> - <%= property.price.toLocaleString('fr-FR') %> FCFA">
    <meta property="og:description" content="Bien situé à <%= property.commune %>. Cliquez pour voir les photos.">
    <meta property="og:image" content="<%= (property.images && property.images.length > 0) ? property.images[0] : '/images/default-house.jpg' %>">
    <meta property="og:type" content="website">

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#ffffff">

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script> 
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; padding-bottom: 90px; }
        
        /* Masquer la scrollbar tout en gardant le scroll */
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* Snap Scroll pour le carrousel */
        .snap-x-mandatory { scroll-snap-type: x mandatory; }
        .snap-center { scroll-snap-align: center; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <div class="max-w-md mx-auto bg-white min-h-screen shadow-2xl relative">
        
        <div class="relative h-80 bg-slate-200 group">
            <% if (property.images && property.images.length > 0) { %>
                <div id="imageSlider" class="flex overflow-x-auto w-full h-full snap-x-mandatory scrollbar-hide scroll-smooth">
                    <% property.images.forEach((img, index) => { %>
                        <img src="<%= img %>" alt="Photo <%= index + 1 %> du bien" class="w-full h-full object-cover flex-shrink-0 snap-center">
                    <% }) %>
                </div>
                
                <div class="absolute bottom-4 right-4 bg-black/60 backdrop-blur-md text-white text-xs font-bold px-3 py-1 rounded-full border border-white/10">
                    <span id="slideCounter">1</span> / <%= property.images.length %>
                </div>
            <% } else { %>
                <div class="w-full h-full flex flex-col items-center justify-center bg-slate-800 text-slate-400">
                    <i class="ph ph-image text-5xl mb-2 opacity-50"></i>
                    <span class="text-xs font-bold uppercase tracking-wider">Pas de photo</span>
                </div>
            <% } %>

            <div class="absolute top-0 left-0 w-full p-4 flex justify-between items-start bg-gradient-to-b from-black/60 to-transparent">
                <button onclick="history.back()" aria-label="Retour" class="w-10 h-10 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center text-white hover:bg-white/40 transition active:scale-90">
                    <i class="ph-bold ph-arrow-left text-xl"></i>
                </button>
                <button onclick="shareProperty()" aria-label="Partager ce bien" class="w-10 h-10 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center text-white hover:bg-white/40 transition active:scale-90">
                    <i class="ph-bold ph-share-network text-xl"></i>
                </button>
            </div>
            
            <div class="absolute bottom-4 left-4 bg-[#0B1120]/90 backdrop-blur-md text-white px-4 py-2 rounded-xl border border-slate-700 shadow-xl">
                <span class="text-[10px] text-slate-400 font-bold uppercase block tracking-wider">Loyer mensuel</span>
                <span class="text-xl font-black text-[#F59E0B]"><%= property.price.toLocaleString('fr-FR') %> F</span>
            </div>
        </div>

        <div class="p-6 -mt-6 bg-white rounded-t-[2rem] relative z-10 shadow-[0_-10px_40px_rgba(0,0,0,0.1)]">
            
            <div class="mb-8">
                <div class="flex justify-between items-start mb-3">
                    <span class="bg-blue-50 text-blue-700 border border-blue-100 text-[10px] font-bold px-2.5 py-1 rounded-md uppercase tracking-wide">
                        <%= property.type || 'Appartement' %>
                    </span>
                    <span class="flex items-center gap-1.5 text-xs text-slate-500 font-medium">
                        <i class="ph-fill ph-clock text-slate-400"></i> Publié récemment
                    </span>
                </div>
                <h1 class="text-2xl font-black text-[#0B1120] leading-tight mb-2"><%= property.title %></h1>
                <p class="text-slate-600 flex items-center gap-1.5 text-sm font-medium">
                    <i class="ph-fill ph-map-pin text-[#F59E0B]"></i>
                    <%= property.address %>, <%= property.commune %>
                </p>
            </div>

            <div class="grid grid-cols-3 gap-3 mb-8">
                <div class="bg-slate-50 p-3 rounded-2xl border border-slate-200 text-center">
                    <i class="ph-duotone ph-bed text-2xl text-slate-500 mb-1"></i>
                    <p class="font-bold text-[#0B1120] text-lg"><%= property.bedrooms || '-' %></p>
                    <p class="text-[10px] text-slate-500 font-bold uppercase tracking-wide">Chambres</p>
                </div>
                <div class="bg-slate-50 p-3 rounded-2xl border border-slate-200 text-center">
                    <i class="ph-duotone ph-shower text-2xl text-slate-500 mb-1"></i>
                    <p class="font-bold text-[#0B1120] text-lg"><%= property.bathrooms || '-' %></p>
                    <p class="text-[10px] text-slate-500 font-bold uppercase tracking-wide">Douches</p>
                </div>
                <div class="bg-slate-50 p-3 rounded-2xl border border-slate-200 text-center">
                    <i class="ph-duotone ph-ruler text-2xl text-slate-500 mb-1"></i>
                    <p class="font-bold text-[#0B1120] text-lg"><%= property.surface || '-' %></p>
                    <p class="text-[10px] text-slate-500 font-bold uppercase tracking-wide">m²</p>
                </div>
            </div>

            <div class="mb-10">
                <h3 class="font-bold text-[#0B1120] mb-3 text-lg">À propos de ce bien</h3>
                <p class="text-sm text-slate-600 leading-relaxed">
                    <%= property.description || "Ce bien dispose de toutes les commodités nécessaires pour un confort optimal. Situé dans une zone accessible et sécurisée. Contactez-nous pour une visite." %>
                </p>
            </div>

            <div class="mt-8 mb-8">
                <h3 class="font-bold text-[#0B1120] mb-4 text-lg flex items-center gap-2">
                    <i class="ph-fill ph-map-trifold text-[#F59E0B]"></i> Le Quartier
                </h3>

                <div id="propertyMap" class="h-72 w-full rounded-2xl shadow-lg border border-slate-100 z-0 mb-6"></div>

                <div id="poiList" class="grid grid-cols-2 gap-3 text-sm">
                    <div class="col-span-2 text-center text-slate-400 py-2 text-xs">
                        <i class="ph-duotone ph-spinner animate-spin"></i> Recherche des commodités à proximité...
                    </div>
                </div>
            </div>
            <hr class="border-dashed border-slate-200 my-8">

            <div id="applyForm" class="bg-gradient-to-br from-slate-50 to-white border border-slate-200 rounded-3xl p-6 relative overflow-hidden shadow-sm">
                <div class="absolute top-0 right-0 w-32 h-32 bg-[#F59E0B]/5 rounded-full blur-3xl -mr-10 -mt-10 pointer-events-none"></div>
                
                <h2 class="font-black text-xl mb-2 relative z-10 text-[#0B1120]">Ce bien vous intéresse ?</h2>
                <p class="text-xs text-slate-500 mb-6 relative z-10 font-medium">Remplissez ce formulaire. Notre IA analyse votre dossier en <span class="text-[#F59E0B] font-bold">temps réel</span>.</p>

                <form action="/apply/<%= property.id %>" method="POST" class="space-y-4 relative z-10">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    
                    <div>
                        <label for="name" class="sr-only">Nom complet</label>
                        <div class="relative group">
                            <i class="ph-duotone ph-user absolute left-3 top-3.5 text-slate-400 group-focus-within:text-[#F59E0B] transition"></i>
                            <input type="text" id="name" name="name" required placeholder="Votre Nom Complet" 
                                   class="w-full bg-white border border-slate-200 rounded-xl p-3 pl-10 text-sm text-slate-900 placeholder-slate-400 focus:border-[#F59E0B] focus:ring-1 focus:ring-[#F59E0B] outline-none transition shadow-sm">
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label for="phone" class="sr-only">Téléphone</label>
                            <div class="relative group">
                                <i class="ph-duotone ph-phone absolute left-3 top-3.5 text-slate-400 group-focus-within:text-[#F59E0B] transition"></i>
                                <input type="tel" id="phone" name="phone" required pattern="[0-9]{10}" title="Veuillez entrer un numéro à 10 chiffres (ex: 0707123456)" placeholder="07 07..." 
                                       class="w-full bg-white border border-slate-200 rounded-xl p-3 pl-10 text-sm text-slate-900 placeholder-slate-400 focus:border-[#F59E0B] focus:ring-1 focus:ring-[#F59E0B] outline-none transition shadow-sm">
                            </div>
                        </div>
                        <div>
                            <label for="email" class="sr-only">Email</label>
                            <div class="relative group">
                                <i class="ph-duotone ph-envelope absolute left-3 top-3.5 text-slate-400 group-focus-within:text-[#F59E0B] transition"></i>
                                <input type="email" id="email" name="email" required placeholder="Email" 
                                       class="w-full bg-white border border-slate-200 rounded-xl p-3 pl-10 text-sm text-slate-900 placeholder-slate-400 focus:border-[#F59E0B] focus:ring-1 focus:ring-[#F59E0B] outline-none transition shadow-sm">
                            </div>
                        </div>
                    </div>

                    <div>
                        <label for="income" class="sr-only">Revenus Mensuels</label>
                        <div class="relative group">
                            <i class="ph-duotone ph-money absolute left-3 top-3.5 text-slate-400 group-focus-within:text-[#F59E0B] transition"></i>
                            <input type="number" id="income" name="income" required min="10000" placeholder="Revenus Mensuels (FCFA)" 
                                   class="w-full bg-white border border-slate-200 rounded-xl p-3 pl-10 text-sm text-slate-900 placeholder-slate-400 focus:border-[#F59E0B] focus:ring-1 focus:ring-[#F59E0B] outline-none transition shadow-sm">
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-3 mt-2">
                        <input type="checkbox" required id="consent" class="mt-1 w-4 h-4 text-[#F59E0B] border-slate-300 rounded focus:ring-[#F59E0B]">
                        <label for="consent" class="text-xs text-slate-600 leading-tight">
                            Je certifie l'exactitude des informations. Des justificatifs (Wave/Orange Money ou bulletins) seront demandés.
                        </label>
                    </div>

                    <button type="submit" class="w-full bg-[#0B1120] text-white font-bold py-4 rounded-xl hover:bg-slate-800 transition flex items-center justify-center gap-2 shadow-lg shadow-black/10 transform active:scale-[0.98]">
                        <i class="ph-bold ph-paper-plane-right"></i> Vérifier mon éligibilité
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="fixed bottom-0 left-0 w-full bg-white/90 backdrop-blur-md border-t border-slate-200 p-4 pb-6 md:hidden flex items-center justify-between z-50 shadow-[0_-5px_20px_rgba(0,0,0,0.05)]">
        <div>
            <p class="text-[10px] text-slate-500 font-bold uppercase tracking-wide">Loyer / Mois</p>
            <p class="text-xl font-black text-[#0B1120]"><%= property.price.toLocaleString('fr-FR') %> F</p>
        </div>
        <button onclick="document.getElementById('applyForm').scrollIntoView({behavior: 'smooth'})" class="bg-[#F59E0B] text-black px-6 py-3 rounded-xl font-bold text-sm shadow-lg shadow-orange-500/20 active:scale-95 transition">
            Postuler
        </button>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        // --- 0. GESTION DE LA CARTE ET OVERPASS (API) ---
        // Cette partie s'exécute automatiquement pour charger la carte
        document.addEventListener('DOMContentLoaded', () => {
            const lat = <%= property.latitude || 5.359952 %>;
            const lng = <%= property.longitude || -4.008256 %>;

            // 1. AFFICHER LA CARTE
            // On vérifie si le conteneur map existe pour éviter les erreurs
            if (document.getElementById('propertyMap')) {
                const map = L.map('propertyMap').setView([lat, lng], 15); // Zoom 15 pour voir les rues
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
                
                // Le bien est marqué par un cercle rouge (plus élégant qu'un marqueur bleu standard)
                L.circleMarker([lat, lng], {
                    color: '#F59E0B',
                    fillColor: '#F59E0B',
                    fillOpacity: 0.8,
                    radius: 12
                }).addTo(map).bindPopup("<b><%= property.title %></b>").openPopup();

                // 2. CHERCHER LES POINTS D'INTÉRÊT (API OVERPASS)
                // On cherche : Pharmacy, School, Restaurant, Bank dans un rayon de 800m
                const query = `
                    [out:json];
                    (
                    node["amenity"~"pharmacy|school|restaurant|bank|marketplace"](around:800, ${lat}, ${lng});
                    );
                    out 5; 
                `;

                fetch('https://overpass-api.de/api/interpreter', {
                    method: 'POST',
                    body: query
                })
                .then(response => response.json())
                .then(data => {
                    const poiContainer = document.getElementById('poiList');
                    poiContainer.innerHTML = ''; // Vider le loader

                    if (data.elements.length === 0) {
                        poiContainer.innerHTML = '<p class="text-xs text-slate-400 col-span-2">Aucun point d\'intérêt majeur détecté à proximité immédiate.</p>';
                        return;
                    }

                    data.elements.forEach(poi => {
                        let icon = '📍';
                        let type = 'Lieu';
                        
                        // Icones sympas selon le type
                        if (poi.tags.amenity === 'pharmacy') { icon = '💊'; type = 'Pharmacie'; }
                        if (poi.tags.amenity === 'school') { icon = '🎓'; type = 'École'; }
                        if (poi.tags.amenity === 'restaurant') { icon = '🍽️'; type = 'Resto/Maquis'; }
                        if (poi.tags.amenity === 'bank') { icon = '🏦'; type = 'Banque'; }
                        if (poi.tags.amenity === 'marketplace') { icon = '🛒'; type = 'Marché'; }

                        const html = `
                            <div class="flex items-center gap-3 bg-slate-50 p-3 rounded-xl border border-slate-100">
                                <div class="text-xl">${icon}</div>
                                <div>
                                    <p class="font-bold text-[#0B1120] text-xs truncate w-32">${poi.tags.name || type}</p>
                                    <p class="text-[10px] text-slate-500 uppercase">${type}</p>
                                </div>
                            </div>
                        `;
                        poiContainer.insertAdjacentHTML('beforeend', html);
                        
                        // Ajouter aussi sur la carte en petit
                        L.marker([poi.lat, poi.lon], { opacity: 0.6 }).addTo(map).bindPopup(poi.tags.name || type);
                    });
                })
                .catch(err => {
                    console.error("Erreur POI", err);
                    document.getElementById('poiList').innerHTML = ''; // Cacher l'erreur silencieusement
                });
            }
        });

        // --- 1. GESTION DU CARROUSEL ---
        const slider = document.getElementById('imageSlider');
        const counter = document.getElementById('slideCounter');
        
        if (slider) {
            slider.addEventListener('scroll', () => {
                const scrollPosition = slider.scrollLeft;
                const width = slider.offsetWidth;
                // Calcul de l'index actuel (arrondi)
                const currentIndex = Math.round(scrollPosition / width) + 1;
                counter.innerText = currentIndex;
            });
        }

        // --- 2. PARTAGE SOCIAL ---
        function shareProperty() {
            if (navigator.share) {
                navigator.share({
                    title: '<%= property.title %>',
                    text: 'Regarde ce bien sur ImmoFacile ! Loyer: <%= property.price.toLocaleString("fr-FR") %> F',
                    url: window.location.href,
                }).catch(err => console.log('Partage annulé'));
            } else {
                // Fallback pour Desktop
                navigator.clipboard.writeText(window.location.href);
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: 'Lien copié !',
                    showConfirmButton: false,
                    timer: 2000
                });
            }
        }

        // --- 3. GESTION DES MESSAGES SERVEUR (FLASH) ---
        // Vérifie si le serveur a envoyé des messages de succès/erreur via locals
        document.addEventListener('DOMContentLoaded', () => {
            <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
                Swal.fire({
                    title: 'Dossier Reçu ! 🎉',
                    text: "<%= success %>",
                    icon: 'success',
                    confirmButtonText: 'Super',
                    confirmButtonColor: '#0B1120'
                });
            <% } %>

            <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
                Swal.fire({
                    title: 'Oups...',
                    text: "<%= error %>",
                    icon: 'error',
                    confirmButtonText: 'Réessayer',
                    confirmButtonColor: '#ef4444'
                });
            <% } %>
        });

        // --- 4. SERVICE WORKER ---
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js'));
        }
    </script>
</body>
</html>
