<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SUPER ADMIN | ImmoFacile CI</title>
    
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0B1120">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
    </style>
</head>
<body class="bg-[#0B1120] text-slate-200">

    <div class="flex min-h-screen">
        <%- include('partials/sidebar') %>

        <main class="flex-1 md:ml-72 p-6 md:p-10 max-w-7xl mx-auto w-full">
            <header class="flex justify-between items-end mb-10">
                <div>
                    <h1 class="text-3xl font-bold text-white uppercase">Bonjour ADMIN 👋</h1>
                    <p class="text-slate-400 mt-1 flex items-center gap-2 text-sm">
                        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                        Système opérationnel • <%= new Date().toLocaleDateString('fr-FR', {day:'numeric', month:'long'}) %> 
                    </p>
                </div>
                <div class="bg-slate-900 px-5 py-3 rounded-xl border border-slate-800 shadow-sm">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Utilisateurs Totaux</p>
                    <p class="text-2xl font-black text-white"><%= totalUsers %></p> 
                </div>
            </header>

            <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
                <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl relative overflow-hidden group hover:border-slate-700 transition">
                    <div class="flex justify-between mb-2">
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Volume d'Affaires</span>
                        <span class="text-green-400 bg-green-500/10 px-2 py-0.5 rounded text-[10px] font-bold">+12% vs M-1</span> 
                    </div>
                    <p class="text-3xl font-black text-white tracking-tight"><%= volumeAffaires.toLocaleString('fr-FR') %> <span class="text-base font-normal text-slate-400">FCFA</span></p> 
                    <p class="text-xs text-slate-400 mt-2">Loyers totaux encaissés</p>
                </div>

                <div class="bg-gradient-to-br from-[#F59E0B] to-orange-800 p-6 rounded-2xl shadow-lg relative overflow-hidden">
                    <span class="text-xs font-bold text-black/70 uppercase bg-white/30 px-2 py-1 rounded backdrop-blur-sm">Ma Commission (5%)</span> 
                    <p class="text-4xl font-black text-white tracking-tight mt-4"><%= myRevenue.toLocaleString('fr-FR') %></p> 
                    <p class="text-xs text-white/90 mt-1 font-medium">Revenu Net généré</p>
                </div>

                <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl flex flex-col justify-between">
                    <div class="flex justify-between mb-4">
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Biens sous gestion</span>
                        <i class="ph ph-buildings text-slate-500 text-xl"></i> 
                    </div>
                    <p class="text-3xl font-black text-white"><%= totalProperties %></p> 
                    <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden mt-4">
                        <div class="bg-blue-500 h-full rounded-full" style="width: 75%"></div> 
                    </div>
                </div>
            </section>

            <section class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
                <div class="lg:col-span-2 space-y-6">
                    <h3 class="text-lg font-bold flex items-center gap-2 text-white">
                        <i class="ph-fill ph-activity text-[#F59E0B]"></i> Valeur Générée (Live) 
                    </h3>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <div class="bg-slate-900 border border-slate-800 p-4 rounded-2xl text-center">
                            <i class="ph-duotone ph-hand-tap text-2xl text-slate-400 mb-2"></i>
                            <p class="text-2xl font-black text-white"><%= totalInteractions %></p> 
                            <p class="text-slate-400 text-[10px] font-bold uppercase mt-1">Interactions</p>
                        </div>
                        <div class="bg-slate-900 border border-slate-800 p-4 rounded-2xl text-center">
                            <i class="ph-fill ph-whatsapp-logo text-2xl text-green-500 mb-2"></i>
                            <p class="text-2xl font-black text-green-500"><%= whatsappTotal %></p> 
                            <p class="text-slate-500 text-[10px] font-bold uppercase mt-1">Leads WA</p>
                        </div>
                        <div class="bg-slate-900 border border-slate-800 p-4 rounded-2xl text-center">
                            <i class="ph-duotone ph-warning text-2xl text-red-400 mb-2"></i>
                            <p class="text-2xl font-black text-red-400"><%= incidentsTotal %></p> 
                            <p class="text-slate-400 text-[10px] font-bold uppercase mt-1">Alertes</p>
                        </div>
                        <div class="bg-slate-900 border border-slate-800 p-4 rounded-2xl text-center">
                            <i class="ph-duotone ph-users text-2xl text-blue-400 mb-2"></i>
                            <p class="text-2xl font-black text-blue-400"><%= totalUsers > 0 ? (totalInteractions / totalUsers).toFixed(1) : 0 %></p> 
                            <p class="text-slate-400 text-[10px] font-bold uppercase mt-1">Engagement</p>
                        </div>
                    </div>

                    <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl">
                        <h4 class="text-xs font-bold text-slate-400 uppercase mb-4">Aperçu des Revenus</h4>
                        <div class="h-48 w-full">
                            <canvas id="revenueChart"></canvas> 
                        </div>
                    </div>
                </div>

                <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 h-full flex flex-col">
                    <h3 class="text-sm font-bold text-slate-300 uppercase mb-6 flex justify-between items-center">
                        Flux d'activité
                        <span class="flex h-2 w-2 relative"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span></span>
                    </h3>
                    <div class="space-y-4 overflow-y-auto flex-1 custom-scrollbar max-h-[400px]">
                        <% if(locals.recentActivities && recentActivities.length > 0) { %>
                            <% recentActivities.forEach(log => { %>
                                <div class="flex gap-3 text-xs relative pl-4 border-l border-slate-800 pb-2">
                                    <div class="absolute -left-1 top-1 w-2 h-2 rounded-full bg-slate-700 border-2 border-slate-900"></div>
                                    <div>
                                        <div class="flex items-center gap-2 mb-1">
                                            <span class="text-xs font-bold text-slate-200"><%= log.user ? log.user.name : 'Visiteur' %></span> 
                                            <span class="text-[10px] text-slate-500"><%= new Date(log.createdAt).toLocaleTimeString('fr-FR') %></span>
                                        </div>
                                        <p class="text-slate-400"><span class="text-[#F59E0B]"><%= log.action %></span> • <%= log.category %></p> 
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-slate-500 italic text-xs text-center py-10">Aucune activité récente.</p> 
                        <% } %>
                    </div>
                </div>
            </section>

            <section id="tresorerie" class="mb-12 bg-slate-900 border border-slate-800 p-8 rounded-2xl relative overflow-hidden">
                <h3 class="font-bold text-white text-lg mb-6 flex items-center gap-2">
                    <i class="ph-fill ph-credit-card text-[#F59E0B]"></i> Guichet de Rechargement 
                </h3>
                <div class="flex flex-col xl:flex-row gap-8">
                    <form action="/admin/add-credit" method="POST" class="bg-black/40 p-6 rounded-xl border border-slate-700 w-full xl:w-1/3">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="mb-4">
                            <label class="text-xs font-bold text-slate-400 uppercase mb-2 block">Propriétaire Client</label>
                            <select name="ownerId" required class="w-full bg-slate-800 border border-slate-600 rounded-lg p-3 text-white">
                                <% owners.forEach(o => { %>
                                    <option value="<%= o.id %>"><%= o.name %> (Solde: <%= o.walletBalance.toLocaleString('fr-FR') %> F)</option> 
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-6">
                            <label class="text-xs font-bold text-slate-400 uppercase mb-2 block">Montant reçu (FCFA)</label>
                            <input type="number" name="amount" required min="500" class="w-full bg-slate-800 border border-slate-600 rounded-lg p-3 text-white" placeholder="Ex: 50000"> 
                        </div>
                        <button type="submit" class="w-full bg-[#F59E0B] text-black font-bold py-3 rounded-lg hover:bg-orange-500 transition">Créditer le compte</button> 
                    </form>
                    <div class="flex-1 overflow-x-auto border border-slate-800 rounded-xl bg-black/20">
                        <table class="w-full text-sm text-left">
                            <thead class="text-xs text-slate-400 uppercase bg-slate-800/80">
                                <tr><th class="p-4">Client</th><th class="p-4">Solde Actuel</th><th class="p-4">Statut</th><th class="p-4 text-right">Action</th></tr> 
                            </thead>
                            <tbody class="divide-y divide-slate-800">
                                <% owners.forEach(o => { %>
                                    <tr class="hover:bg-slate-800/30 transition">
                                        <td class="p-4 font-bold text-white"><%= o.name %></td> 
                                        <td class="p-4 font-mono <%= o.walletBalance < 2000 ? 'text-red-400' : 'text-green-400' %>"><%= o.walletBalance.toLocaleString('fr-FR') %> F</td> 
                                        <td class="p-4">
                                            <span class="inline-flex items-center gap-1 <%= o.isActive ? 'bg-green-500/10 text-green-500' : 'bg-red-500/10 text-red-400' %> px-2 py-1 rounded text-xs">
                                                <i class="ph-fill <%= o.isActive ? 'ph-check-circle' : 'ph-warning-circle' %>"></i> <%= o.isActive ? 'OK' : 'Bas' %> 
                                            </span>
                                        </td>
                                        <td class="p-4 text-right">
                                            <form action="/admin/toggle-status" method="POST" class="inline">
                                                <input type="hidden" name="userId" value="<%= o.id %>">
                                                <input type="hidden" name="currentStatus" value="<%= o.isActive %>">
                                                <button type="submit" class="<%= o.isActive ? 'text-red-400' : 'text-green-400' %> hover:bg-slate-700 p-2 rounded-lg">
                                                    <i class="ph-bold <%= o.isActive ? 'ph-lock-key' : 'ph-lock-key-open' %>"></i> 
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
                <section id="agents" class="bg-slate-900 border border-slate-800 rounded-2xl p-6">
                    <h3 class="font-bold text-slate-400 uppercase text-xs mb-4 flex items-center gap-2"><i class="ph-fill ph-users-three"></i> Performance Agents</h3> 
                    <table class="w-full text-left text-sm">
                        <tbody class="divide-y divide-slate-800">
                            <% agents.forEach(agent => { %>
                                <tr>
                                    <td class="p-4 font-bold text-slate-200"><%= agent.name %></td> 
                                    <td class="p-4 text-slate-300"><%= agent.leads.length %> leads</td>
                                    <td class="p-4 text-right font-mono text-[#F59E0B]"><%= (agent.leads.length * 5000).toLocaleString() %> F</td> 
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </section>
                <section id="alertes" class="space-y-3">
                    <h3 class="font-bold text-slate-400 uppercase text-xs mb-4 flex items-center gap-2"><i class="ph-fill ph-bell-ringing"></i> Alertes Système</h3> 
                    <% if (activeIncidents.length === 0) { %>
                        <div class="p-6 bg-green-500/5 border border-green-500/10 rounded-xl text-center"><p class="text-green-400 text-sm font-bold">R.A.S.</p></div> 
                    <% } %>
                    <% activeIncidents.forEach(inc => { %>
                        <div class="p-4 bg-red-500/5 border border-red-500/20 rounded-xl flex justify-between items-center">
                            <div class="flex items-start gap-3"><i class="ph-fill ph-warning-octagon text-red-500 text-xl"></i><div><p class="text-red-400 font-bold text-sm"><%= inc.title %></p></div></div> 
                        </div>
                    <% }) %>
                </section>
            </div>

            <div class="bg-white rounded-3xl p-8 border border-slate-100 shadow-xl text-slate-900 mb-12">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-black flex items-center gap-2"><i class="ph-duotone ph-toolbox text-2xl text-orange-500"></i> Annuaire des Artisans</h2> 
                    <button onclick="document.getElementById('artisanModal').classList.remove('hidden')" class="bg-[#0B1120] text-white px-5 py-2.5 rounded-xl font-bold text-sm">Ajouter un Pro</button> 
                </div>
                <table class="w-full text-left">
                    <thead class="text-xs font-bold text-slate-400 uppercase border-b border-slate-100">
                        <tr><th class="p-3 pl-0">Nom</th><th class="p-3">Métier</th><th class="p-3">Secteur</th><th class="p-3">Contact</th><th class="p-3 text-right">Action</th></tr> 
                    </thead>
                    <tbody class="text-sm">
                        <% artisans.forEach(a => { %>
                            <tr class="border-b border-slate-50 hover:bg-slate-50 transition">
                                <td class="p-3 pl-0 font-bold"><%= a.name %></td> 
                                <td class="p-3"><span class="bg-orange-100 text-orange-800 px-2 py-1 rounded text-xs font-bold"><%= a.job %></span></td> 
                                <td class="p-3 text-slate-500"><%= a.location %></td> 
                                <td class="p-3 font-mono"><%= a.phone %></td> 
                                <td class="p-3 text-right">
                                    <form action="/admin/delete-artisan" method="POST"><input type="hidden" name="artisanId" value="<%= a.id %>"><button type="submit" class="text-slate-300 hover:text-red-500"><i class="ph-bold ph-trash text-lg"></i></button></form> 
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('revenueChart').getContext('2d');
            const chartData = <%- JSON.stringify([volumeAffaires * 0.7, volumeAffaires * 0.85, volumeAffaires * 0.6, volumeAffaires]) %>; 
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Sem-3', 'Sem-2', 'Sem-1', 'Aujourd\'hui'],
                    datasets: [{ label: 'Revenus (FCFA)', data: chartData, borderColor: '#F59E0B', tension: 0.4 }] 
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
            });
        });
    </script>
</body>
</html>
