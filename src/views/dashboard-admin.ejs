<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SUPER ADMIN | ImmoFacile CI</title>
    
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#000000">
    <link rel="apple-touch-icon" href="/images/icon-192.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>html { scroll-behavior: smooth; }</style>
</head>
<body class="bg-black text-white font-['Plus_Jakarta_Sans']">

    <div class="flex min-h-screen">
        <aside id="adminSidebar" class="w-64 border-r border-slate-800 p-6 hidden md:flex flex-col fixed h-full overflow-y-auto z-50 bg-black transition-all">   
            <div class="md:hidden flex justify-end mb-4">
                <button onclick="toggleAdminMenu()" class="text-white text-xl">✕</button>
                <img src="/images/immo_logo.png" alt="ImmoFacile CI" class="h-16 object-contain">
            </div>

            <nav class="space-y-2 flex-1">
                <a href="/dashboard-admin" class="block p-3 bg-white/10 rounded-lg font-bold text-white hover:bg-white/20 transition-all">
                    Vue Globale
                </a>

                <a href="#tresorerie" class="block p-3 font-semibold text-slate-300 hover:text-white hover:bg-white/10 rounded-lg transition-all">
                    Trésorerie & Guichet
                </a>

                <a href="#agents" class="block p-3 font-semibold text-slate-300 hover:text-white hover:bg-white/10 rounded-lg transition-all">
                    Agents & Sales
                </a>

                <a href="#alertes" class="block p-3 font-semibold text-slate-300 hover:text-white hover:bg-white/10 rounded-lg transition-all">
                    Alertes Système
                </a>

                <a href="/logout" class="block p-3 font-semibold text-red-500 mt-10 hover:bg-red-500/10 rounded-lg transition-all">
                    Déconnexion
                </a>
            </nav>

            <div class="mt-auto pt-6 border-t border-slate-800 text-center md:text-left">
                <p class="text-[10px] text-slate-500 uppercase tracking-widest mb-2">Développé par</p>
                <img src="/images/logo_webappci.png" alt="WebApp CI" class="h-8 object-contain opacity-80 hover:opacity-100 transition mb-2">
                <div class="flex flex-col gap-1">
                    <a href="mailto:contact@webappci.com" class="text-[10px] text-slate-400 hover:text-white">contact@webappci.com</a>
                    <a href="/privacy" class="text-[10px] text-[#F59E0B] hover:underline">Confidentialité</a>
                </div>
            </div>
        </aside>

        <main class="flex-1 md:ml-64 p-10">
            
            <header class="flex justify-between items-end mb-10">
                <div class="flex items-center gap-4">
                    <button onclick="toggleAdminMenu()" class="md:hidden text-white bg-slate-800 p-2 rounded-lg">
                        ☰
                    </button>
                    <div>
                        <h1 class="text-3xl font-bold">Bonjour ADMIN 👋</h1>
                        <p class="text-slate-500">Voici la situation du business aujourd'hui.</p>
                    </div>
                </div>
                <div class="text-right hidden sm:block">
                    <p class="text-xs font-bold text-slate-500 uppercase">Utilisateurs Totaux</p>
                    <p class="text-2xl font-black"><%= totalUsers %></p>
                </div>
            </header>

            <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
                <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl">
                    <div class="flex justify-between mb-4">
                        <span class="text-xs font-bold text-slate-400 uppercase">Volume d'Affaires (GMV)</span>
                        <span class="text-green-500 bg-green-500/10 px-2 rounded text-xs">▲ +12%</span>
                    </div>
                    <p class="text-3xl font-black text-white"><%= volumeAffaires.toLocaleString('fr-FR') %></p>
                    <p class="text-xs text-slate-500">FCFA encaissés (Loyers)</p>
                </div>

                <div class="bg-gradient-to-br from-[#F59E0B] to-orange-700 p-6 rounded-2xl shadow-[0_0_20px_rgba(245,158,11,0.3)]">
                    <div class="flex justify-between mb-4">
                        <span class="text-xs font-bold text-black/60 uppercase">MA COMMISSION (5%)</span>
                    </div>
                    <p class="text-4xl font-black text-white"><%= myRevenue.toLocaleString('fr-FR') %></p>
                    <p class="text-xs text-white/80">FCFA Net dans votre poche</p>
                </div>

                <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl">
                    <div class="flex justify-between mb-4">
                        <span class="text-xs font-bold text-slate-400 uppercase">Biens sous gestion</span>
                    </div>
                    <p class="text-3xl font-black text-white"><%= totalProperties %></p>
                    <p class="text-xs text-slate-500">Appartements actifs</p>
                </div>
            </section>

            <section class="mb-12">
                <h3 class="text-xl font-bold mb-6 flex items-center gap-2 text-white">
                    📈 Valeur Générée (Tracking Live)
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
                    <div class="bg-slate-900 border border-slate-800 p-5 rounded-2xl">
                        <p class="text-slate-500 text-xs font-bold uppercase">Interactions totales</p>
                        <p class="text-2xl font-black text-white"><%= totalInteractions %></p>
                    </div>
            
                    <div class="bg-slate-900 border border-slate-800 p-5 rounded-2xl border-l-4 border-green-500">
                        <p class="text-slate-500 text-xs font-bold uppercase">Mises en relation WA</p>
                        <p class="text-2xl font-black text-green-500"><%= whatsappTotal %></p>
                    </div>
            
                    <div class="bg-slate-900 border border-slate-800 p-5 rounded-2xl border-l-4 border-red-500">
                        <p class="text-slate-500 text-xs font-bold uppercase">Alertes traitées</p>
                        <p class="text-2xl font-black text-red-500"><%= incidentsTotal %></p>
                    </div>
            
                    <div class="bg-slate-900 border border-slate-800 p-5 rounded-2xl">
                        <p class="text-slate-500 text-xs font-bold uppercase">Engagement / User</p>
                        <p class="text-2xl font-black text-blue-400">
                            <%= totalUsers > 0 ? (totalInteractions / totalUsers).toFixed(1) : 0 %>
                        </p>
                    </div>
                </div>

                <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6">
                    <h3 class="text-sm font-bold text-slate-400 uppercase mb-4">Flux d'activité en temps réel</h3>
                    <div class="space-y-3">
                        <% if(locals.recentActivities && recentActivities.length > 0) { %>
                            <% recentActivities.forEach(log => { %>
                                <div class="flex items-center justify-between text-xs p-3 bg-black/20 rounded-lg border border-slate-800">
                                    <div class="flex items-center gap-3">
                                        <span class="px-2 py-0.5 rounded bg-slate-800 text-slate-400 font-bold uppercase" style="font-size: 8px;">
                                            <%= log.category %>
                                        </span>
                                        <span class="text-white">
                                            <strong><%= log.user ? log.user.name : 'Visiteur' %></strong> a déclenché 
                                            <span class="text-[#F59E0B]"><%= log.action %></span>
                                        </span>
                                    </div>
                                    <span class="text-slate-600">
                                        <%= new Date(log.createdAt).toLocaleTimeString('fr-FR') %>
                                    </span>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-slate-500 italic text-sm">Aucune activité récente.</p>
                        <% } %>
                    </div>
                </div>
            </section>

            <section id="tresorerie" class="mb-12 bg-slate-900 border border-slate-800 p-6 rounded-2xl">
                <h3 class="font-bold text-[#F59E0B] uppercase text-sm mb-6 flex items-center gap-2">
                    💳 Guichet de Rechargement / Trésorerie
                    <span class="text-xs text-slate-500 normal-case hidden md:inline">(Quand vous recevez un Wave, ajoutez le crédit ici)</span>
                </h3>

                <div class="flex flex-col md:flex-row gap-6">
                    <form action="/admin/add-credit" method="POST" class="bg-black/30 p-4 rounded-xl border border-slate-700 w-full md:w-1/3">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>"> 
                        <div class="mb-3">
                            <label class="text-xs font-bold text-slate-400">Propriétaire Client</label>
                            <select name="ownerId" class="w-full bg-slate-800 border border-slate-600 rounded p-2 text-white text-sm mt-1">
                                <% owners.forEach(o => { %>
                                    <option value="<%= o.id %>"><%= o.name %> (Solde: <%= o.walletBalance.toLocaleString('fr-FR') %> F)</option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="text-xs font-bold text-slate-400">Montant reçu (FCFA)</label>
                            <input type="number" name="amount" placeholder="Ex: 10000" class="w-full bg-slate-800 border border-slate-600 rounded p-2 text-white text-sm mt-1">
                        </div>
                        <button type="submit" class="w-full bg-[#F59E0B] text-black font-bold py-2 rounded hover:bg-orange-500">Créditer le compte</button>
                    </form>

                    <div class="flex-1 overflow-y-auto max-h-60">
                        <table class="w-full text-sm text-left">
                            <thead class="text-xs text-slate-500 uppercase bg-slate-800 sticky top-0">
                                <tr>
                                    <th class="p-2">Client</th>
                                    <th class="p-2">Solde Actuel</th>
                                    <th class="p-2">Statut</th>
                                    <th class="p-2">Action</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-700">
                                <% owners.forEach(o => { %>
                                    <tr>
                                        <td class="p-2 font-bold"><%= o.name %></td>
                                        <td class="p-2 font-mono <%= o.walletBalance < 2000 ? 'text-red-500' : 'text-green-400' %>"><%= o.walletBalance.toLocaleString('fr-FR') %> FCFA</td>
                                        <td class="p-2">
                                            <% if (o.walletBalance < 2000) { %>
                                                <span class="bg-red-500/20 text-red-500 px-2 py-1 rounded text-xs">Bloqué bientôt</span>
                                            <% } else { %>
                                                <span class="bg-green-500/20 text-green-500 px-2 py-1 rounded text-xs">OK</span>
                                            <% } %>
                                        </td>
                                        <td class="p-2">
                                            <form action="/admin/toggle-status" method="POST">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>"> 
                                                <input type="hidden" name="userId" value="<%= o.id %>">
                                                <input type="hidden" name="currentStatus" value="<%= o.isActive %>">
                                                
                                                <% if (o.isActive) { %>
                                                    <button type="submit" class="bg-red-500/20 text-red-500 hover:bg-red-500 hover:text-white px-3 py-1 rounded text-xs font-bold transition">
                                                        Bloquer 🔒
                                                    </button>
                                                <% } else { %>
                                                    <button type="submit" class="bg-green-500/20 text-green-500 hover:bg-green-500 hover:text-white px-3 py-1 rounded text-xs font-bold transition">
                                                        Activer ✅
                                                    </button>
                                                <% } %>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
                
                <section id="agents">
                    <h3 class="font-bold text-slate-400 uppercase text-xs mb-4">Performance Agents</h3>
                    <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden">
                        <table class="w-full text-left text-sm">
                            <thead class="bg-slate-800 text-slate-400 text-xs uppercase">
                                <tr>
                                    <th class="p-4">Agent</th>
                                    <th class="p-4">Leads</th>
                                    <th class="p-4 text-right">Commission due</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-800">
                                <% agents.forEach(agent => { %>
                                    <tr>
                                        <td class="p-4 font-bold"><%= agent.name %></td>
                                        <td class="p-4"><%= agent.leads.length %> immeubles</td>
                                        <td class="p-4 text-right font-mono text-[#F59E0B]">
                                            <%= (agent.leads.length * 5000).toLocaleString('fr-FR') %> FCFA
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </section>

                <section id="alertes">
                    <h3 class="font-bold text-slate-400 uppercase text-xs mb-4">Alertes Système</h3>
                    <div class="space-y-3">
                        <% if (activeIncidents.length === 0) { %>
                            <div class="p-4 bg-green-500/10 border border-green-500/20 rounded-xl text-green-400 text-sm">
                                ✅ R.A.S. Système sain.
                            </div>
                        <% } %>

                        <% activeIncidents.forEach(inc => { %>
                            <div class="p-4 bg-red-500/10 border border-red-500/20 rounded-xl flex justify-between items-center">
                                <div>
                                    <p class="text-red-400 font-bold text-sm">🚨 <%= inc.priority %> : <%= inc.title %></p>
                                    <p class="text-slate-500 text-xs"><%= inc.property ? inc.property.title : 'Immeuble inconnu' %></p>
                                </div>
                                <button class="bg-red-500 text-white px-3 py-1 rounded text-xs font-bold">Intervenir</button>
                            </div>
                        <% }) %>
                    </div>
                </section>
            </div>

            <div class="bg-white rounded-3xl p-8 border border-slate-100 shadow-sm">
                
                <div class="flex justify-between items-center mb-6">
                    <div>
                        <h2 class="text-xl font-black text-[#0B1120]">Annuaire des Artisans</h2>
                        <p class="text-slate-500 text-sm">Gérez les contacts visibles par les propriétaires.</p>
                    </div>
                    <button onclick="document.getElementById('artisanModal').classList.remove('hidden')" class="bg-[#0B1120] text-white px-4 py-2 rounded-xl font-bold text-sm hover:bg-slate-800 transition flex items-center gap-2">
                        <span>➕</span> Ajouter un Pro
                    </button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="text-xs font-bold text-slate-400 uppercase border-b border-slate-100">
                                <th class="p-3">Nom</th>
                                <th class="p-3">Métier</th>
                                <th class="p-3">Secteur</th>
                                <th class="p-3">Contact</th>
                                <th class="p-3 text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm">
                            <% if (locals.artisans && artisans.length > 0) { %>
                                <% artisans.forEach(a => { %>
                                    <tr class="border-b border-slate-50 hover:bg-slate-50">
                                        <td class="p-3 font-bold text-[#0B1120]"><%= a.name %></td>
                                        <td class="p-3"><span class="bg-orange-100 text-orange-700 px-2 py-1 rounded text-xs font-bold"><%= a.job %></span></td>
                                        <td class="p-3 text-slate-500"><%= a.location %></td>
                                        <td class="p-3 font-mono text-slate-700"><%= a.phone %></td>
                                        <td class="p-3 text-right">
                                            <form action="/admin/delete-artisan" method="POST" onsubmit="return confirm('Supprimer cet artisan ?');">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>"> 
                                                <input type="hidden" name="artisanId" value="<%= a.id %>">
                                                <button type="submit" class="text-red-400 hover:text-red-600 font-bold text-xs">🗑 Supprimer</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="p-8 text-center text-slate-400 italic">Aucun artisan enregistré.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </main>
    </div>

    <div id="artisanModal" class="hidden fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white rounded-3xl p-8 max-w-md w-full relative">
            <button onclick="document.getElementById('artisanModal').classList.add('hidden')" class="absolute top-4 right-4 text-slate-400 hover:text-black text-xl font-bold">✕</button>
            
            <h3 class="text-xl font-black text-[#0B1120] mb-6">Nouveau Partenaire</h3>
             
            <form action="/admin/add-artisan" method="POST" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>"> 
                
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Nom de l'entreprise / Artisan</label>
                    <input type="text" name="name" required 
                           class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-slate-900 placeholder-slate-400 focus:outline-none focus:border-[#F59E0B]" 
                           placeholder="Ex: Kouamé Élec">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Métier</label>
                        <select name="job" class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-slate-900 focus:outline-none focus:border-[#F59E0B]">
                            <option>Plombier</option>
                            <option>Électricien</option>
                            <option>Menuisier</option>
                            <option>Peintre</option>
                            <option>Serrurier</option>
                            <option>Climatisation</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Secteur</label>
                        <input type="text" name="location" required 
                               class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-slate-900 placeholder-slate-400 focus:outline-none focus:border-[#F59E0B]" 
                               placeholder="Ex: Cocody">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Téléphone</label>
                    <input type="tel" name="phone" required 
                           class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-slate-900 placeholder-slate-400 focus:outline-none focus:border-[#F59E0B]" 
                           placeholder="07 07 ...">
                </div>

                <button type="submit" class="w-full bg-[#0B1120] text-white font-bold py-4 rounded-xl hover:bg-slate-800 transition mt-2">
                    Enregistrer
                </button>
            </form>
        </div>
    </div>

    <script>
        function toggleAdminMenu() {
            const sidebar = document.getElementById('adminSidebar');
            sidebar.classList.toggle('hidden');
            sidebar.classList.toggle('flex');
        }

        // PWA SERVICE WORKER REGISTRATION
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(registration => {
                        console.log('SW enregistré:', registration);
                    })
                    .catch(error => {
                        console.log('Echec SW:', error);
                    });
            });
        }
    </script>

</body>
</html>
