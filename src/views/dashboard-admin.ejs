<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SUPER ADMIN | ImmoFacile CI</title>
    
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0B1120">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
        @keyframes wave { 0%, 100% { transform: rotate(0deg); } 50% { transform: rotate(20deg); } }
        .animate-wave { animation: wave 2s infinite; transform-origin: 70% 70%; }
    </style>
</head>
<body class="bg-[#0B1120] text-slate-200">

    <div class="flex min-h-screen">
        <aside id="adminSidebar" class="w-72 border-r border-slate-800 p-6 hidden md:flex flex-col fixed h-full bg-[#0B1120] z-50 transition-all">   
            <div class="mb-10 flex items-center gap-3">
                <img src="/images/immo_logo.png" alt="Logo" class="h-10">
                <span class="font-bold text-white uppercase tracking-tighter">ImmoFacile<span class="text-[#F59E0B]">.V4</span></span>
            </div>

            <nav class="space-y-1 flex-1">
                <a href="/admin/dashboard" class="flex items-center gap-3 p-3 bg-white/5 border border-white/10 rounded-xl font-bold text-white shadow-lg shadow-black/20">
                    <i class="ph-fill ph-squares-four text-[#F59E0B] text-xl"></i> Vue Globale
                </a>

                <div class="pt-6 pb-2 text-[10px] uppercase font-bold text-slate-500 tracking-wider">Gestion Trésorerie</div>
                <a href="#tresorerie" class="flex items-center gap-3 p-3 font-medium text-slate-400 hover:text-white hover:bg-white/5 rounded-xl transition group">
                    <i class="ph ph-wallet text-xl group-hover:text-[#F59E0B]"></i> Rechargements
                </a>

                <div class="pt-6 pb-2 text-[10px] uppercase font-bold text-slate-500 tracking-wider">Système</div>
                <a href="/admin/logs" class="flex items-center gap-3 p-3 font-medium text-slate-400 hover:text-white hover:bg-white/5 rounded-xl transition group">
                    <i class="ph ph-scroll text-xl group-hover:text-purple-400"></i> Logs d'audit
                </a>

                <button onclick="checkSystemHealth()" class="w-full text-left flex items-center gap-3 p-3 font-medium text-slate-400 hover:text-white hover:bg-white/5 rounded-xl transition group">
                    <i class="ph ph-activity text-xl text-emerald-400 group-hover:animate-pulse"></i> Santé Système
                </button>

                <a href="/logout" class="flex items-center gap-3 p-3 font-medium text-red-400 mt-10 hover:bg-red-500/10 rounded-xl transition">
                    <i class="ph ph-sign-out text-xl"></i> Déconnexion
                </a>
            </nav>
        </aside>

        <main class="flex-1 md:ml-72 p-6 md:p-10 max-w-7xl mx-auto w-full">
            <header class="flex justify-between items-end mb-10">
                <div>
                    <h1 class="text-3xl font-bold text-white">Bonjour ADMIN <span class="inline-block animate-wave">👋</span></h1>
                    <p class="text-slate-400 mt-1 flex items-center gap-2 text-sm">
                        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                        Système opérationnel • <%= new Date().toLocaleDateString('fr-FR', {day:'numeric', month:'long'}) %>
                    </p>
                </div>
                <div class="bg-slate-900 px-5 py-3 rounded-xl border border-slate-800">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Utilisateurs Totaux</p>
                    <p class="text-2xl font-black text-white"><%= totalUsers %></p>
                </div>
            </header>

            <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
                <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl group transition hover:border-slate-700">
                    <p class="text-xs font-bold text-slate-400 uppercase mb-2">Volume d'Affaires</p>
                    <p class="text-3xl font-black text-white"><%= volumeAffaires.toLocaleString() %> <span class="text-sm font-normal text-slate-500">FCFA</span></p>
                </div>
                <div class="bg-gradient-to-br from-[#F59E0B] to-orange-700 p-6 rounded-2xl shadow-lg">
                    <p class="text-xs font-bold text-black/60 uppercase mb-2">Commission (5%)</p>
                    <p class="text-3xl font-black text-white"><%= myRevenue.toLocaleString() %></p>
                </div>
                <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl">
                    <p class="text-xs font-bold text-slate-400 uppercase mb-2">Biens sous gestion</p>
                    <p class="text-3xl font-black text-white"><%= totalProperties %></p>
                </div>
            </section>

            <section class="grid grid-cols-1 lg:grid-cols-4 gap-4 mb-12">
                <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center">
                    <i class="ph ph-hand-tap text-2xl text-slate-500 mb-1"></i>
                    <p class="text-xl font-bold text-white"><%= totalInteractions %></p>
                    <p class="text-[10px] font-bold text-slate-500 uppercase">Interactions</p>
                </div>
                <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center">
                    <i class="ph ph-whatsapp-logo text-2xl text-emerald-500 mb-1"></i>
                    <p class="text-xl font-bold text-emerald-500"><%= whatsappTotal %></p>
                    <p class="text-[10px] font-bold text-slate-500 uppercase">Leads WA</p>
                </div>
                <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center">
                    <i class="ph ph-warning-octagon text-2xl text-red-500 mb-1"></i>
                    <p class="text-xl font-bold text-red-500"><%= incidentsTotal %></p>
                    <p class="text-[10px] font-bold text-slate-500 uppercase">Alertes</p>
                </div>
                <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center">
                    <i class="ph ph-users text-2xl text-blue-400 mb-1"></i>
                    <p class="text-xl font-bold text-blue-400"><%= totalUsers > 0 ? (totalInteractions / totalUsers).toFixed(1) : 0 %></p>
                    <p class="text-[10px] font-bold text-slate-500 uppercase">Engagement</p>
                </div>
            </section>

            <section id="tresorerie" class="bg-slate-900 border border-slate-800 p-8 rounded-2xl mb-12 relative overflow-hidden">
                <h3 class="font-bold text-white text-lg mb-6 flex items-center gap-2">
                    <i class="ph ph-credit-card text-[#F59E0B]"></i> Guichet de Rechargement (V4)
                </h3>
                <div class="flex flex-col lg:flex-row gap-8">
                    <form action="/admin/add-credit" method="POST" class="bg-black/40 p-6 rounded-xl border border-slate-700 w-full lg:w-1/3">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="mb-4">
                            <label class="text-[10px] font-bold text-slate-500 uppercase mb-2 block">Choisir Propriétaire</label>
                            <select name="ownerId" required class="w-full bg-slate-800 border border-slate-600 rounded-lg p-3 text-white text-sm">
                                <% owners.forEach(o => { %>
                                    <option value="<%= o.id %>"><%= o.name %> (Solde: <%= o.walletBalance %> F)</option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-6">
                            <label class="text-[10px] font-bold text-slate-500 uppercase mb-2 block">Montant reçu (FCFA)</label>
                            <input type="number" name="amount" required min="500" class="w-full bg-slate-800 border border-slate-600 rounded-lg p-3 text-white text-sm" placeholder="Ex: 5000">
                        </div>
                        <button type="submit" class="w-full bg-[#F59E0B] text-black font-bold py-3 rounded-lg hover:bg-orange-500 transition">Créditer le compte</button>
                    </form>

                    <div class="flex-1 overflow-x-auto">
                        <table class="w-full text-sm text-left border border-slate-800">
                            <thead class="bg-slate-800 text-slate-400 text-xs uppercase font-bold">
                                <tr><th class="p-4">Propriétaire</th><th class="p-4">Solde</th><th class="p-4">Action</th></tr>
                            </thead>
                            <tbody class="divide-y divide-slate-800">
                                <% owners.forEach(o => { %>
                                    <tr>
                                        <td class="p-4 font-bold text-white"><%= o.name %></td>
                                        <td class="p-4 font-mono <%= o.walletBalance < 2000 ? 'text-red-400' : 'text-emerald-400' %>"><%= o.walletBalance.toLocaleString() %> F</td>
                                        <td class="p-4">
                                            <form action="/admin/toggle-status" method="POST">
                                                <input type="hidden" name="userId" value="<%= o.id %>">
                                                <input type="hidden" name="currentStatus" value="<%= o.isActive %>">
                                                <button type="submit" class="<%= o.isActive ? 'text-red-400' : 'text-green-400' %> text-lg hover:scale-110 transition">
                                                    <i class="ph-bold <%= o.isActive ? 'ph-lock' : 'ph-lock-open' %>"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script>
        async function checkSystemHealth() {
            Swal.fire({ title: 'Analyse...', text: 'Dispatcher en cours...', didOpen: () => Swal.showLoading() });
            try {
                const res = await fetch('/api/system/status');
                const data = await res.json();
                if (data.success) {
                    Swal.fire({
                        title: 'Système OK ✅',
                        html: `<div class="text-left text-xs bg-slate-900 p-4 rounded">
                            DB: Stable | Users: ${data.stats.users} | Baux: ${data.stats.unpaidBails}
                        </div>`,
                        icon: 'success', background: '#0B1120', color: '#fff'
                    });
                }
            } catch (e) { Swal.fire('Erreur', 'Dispatcher indisponible', 'error'); }
        }


    let lastLogId = null;

    async function pollNotifications() {
        try {
            // On vérifie les 1 derniers logs via le Dispatcher
            const res = await fetch('/api/system/status'); 
            const data = await res.json();
            
            // Si une nouvelle activité critique est détectée (ex: FINANCE ou WHATSAPP)
            // On affiche un "Toast" élégant avec SweetAlert2
            if (data.success && data.stats.unpaidBails > 0) {
                 const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3000,
                    timerProgressBar: true
                });

                Toast.fire({
                    icon: 'warning',
                    title: `Alerte : ${data.stats.unpaidBails} nouveaux baux en attente !`
                });
            }
        } catch (e) {
            console.error("Polling error");
        }
    }

    // Lancement du monitoring toutes les 30 secondes pour économiser les ressources Vercel
    setInterval(pollNotifications, 30000);

        // Setup Chart
        document.addEventListener('DOMContentLoaded', () => {
            const ctx = document.getElementById('revenueChart');
            if(ctx) {
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: ['Sem-3', 'Sem-2', 'Sem-1', 'Aujourd\'hui'],
                        datasets: [{ label: 'Revenus', data: [10, 25, 15, 30], borderColor: '#F59E0B', tension: 0.4 }]
                    },
                    options: { responsive: true, plugins: { legend: { display: false } } }
                });
            }
        });
    </script>
</body>
</html>
