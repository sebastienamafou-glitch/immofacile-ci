<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Espace Agent | ImmoFacile CI</title>
    
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0B1120">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="apple-touch-icon" href="/icon.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; -webkit-tap-highlight-color: transparent; }
        .glass { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .floating-action-btn { box-shadow: 0 10px 30px -10px rgba(245, 158, 11, 0.5); }
        
        /* Animation pour l'état vide */
        @keyframes gentle-pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.4); transform: scale(1); }
            50% { box-shadow: 0 0 0 15px rgba(245, 158, 11, 0); transform: scale(1.02); }
        }
        .cta-pulse { animation: gentle-pulse 2s infinite; border: 2px solid #F59E0B; }
    </style>
</head>
<body class="bg-[#0B1120] text-slate-200 pb-24 min-h-screen">

    <header class="bg-gradient-to-b from-[#F59E0B] to-orange-600 p-6 pt-10 rounded-b-[2.5rem] shadow-2xl relative overflow-hidden text-white">
        <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full blur-2xl -mr-8 -mt-8 pointer-events-none"></div>
        
        <div class="flex justify-between items-start mb-6 relative z-10">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center text-xl font-bold border border-white/20">
                    <%= user.name.charAt(0).toUpperCase() %>
                </div>
                <div>
                    <p class="text-[10px] font-bold uppercase opacity-80 tracking-wider">Agent Terrain</p>
                    <h1 class="font-black text-xl leading-tight"><%= user.name %></h1>
                </div>
            </div>
            <a href="/logout" class="bg-black/20 hover:bg-black/30 backdrop-blur-md p-2 rounded-lg transition">
                <i class="ph-bold ph-sign-out text-xl"></i>
            </a>
        </div>

        <div class="flex gap-4 relative z-10">
            <div class="flex-1 bg-black/20 backdrop-blur-md rounded-2xl p-4 border border-white/10">
                <p class="text-[10px] font-bold uppercase opacity-70 mb-1">Commissions</p>
                <p class="text-2xl font-black tracking-tight"><%= commission.toLocaleString('fr-FR') %></p>
                <p class="text-[10px] opacity-70">FCFA Estimés</p>
            </div>
            <div class="flex-1 bg-black/20 backdrop-blur-md rounded-2xl p-4 border border-white/10">
                <p class="text-[10px] font-bold uppercase opacity-70 mb-1">Chasse</p>
                <p class="text-2xl font-black tracking-tight"><%= leads.length %></p>
                <p class="text-[10px] opacity-70">Immeubles</p>
            </div>
        </div>
    </header>

    <div class="px-6 -mt-8 relative z-20">
        <button onclick="openModal()" class="w-full bg-white text-[#0B1120] p-5 rounded-2xl shadow-xl floating-action-btn flex items-center justify-between group active:scale-95 transition-transform duration-200 border border-slate-100 <%= leads.length === 0 ? 'cta-pulse' : '' %>">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-[#F59E0B]/10 rounded-full flex items-center justify-center text-[#F59E0B]">
                    <i class="ph-fill ph-crosshair text-2xl"></i>
                </div>
                <div class="text-left">
                    <p class="font-black text-lg leading-none">NOUVEAU LEAD</p>
                    <p class="text-xs text-slate-500 font-medium mt-1">Signaler un bien repéré</p>
                </div>
            </div>
            <div class="w-10 h-10 bg-[#0B1120] text-white rounded-full flex items-center justify-center shadow-lg group-hover:rotate-90 transition-transform duration-300">
                <i class="ph-bold ph-plus text-lg"></i>
            </div>
        </button>
    </div>

    <div class="px-6 mt-8">
        <div class="flex justify-between items-end mb-4">
            <h2 class="text-sm font-bold text-slate-400 uppercase tracking-widest">Historique Récent</h2>
            <span class="text-[10px] bg-slate-800 px-2 py-1 rounded text-slate-400"><%= leads.length %> dossiers</span>
        </div>
        
        <div class="space-y-3 pb-20">
            <% if (leads.length === 0) { %>
                <div class="glass p-8 rounded-2xl text-center border-dashed border-slate-700 mt-4">
                    <div class="animate-bounce mb-4">
                        <i class="ph-duotone ph-arrow-up text-3xl text-[#F59E0B]"></i>
                    </div>
                    <p class="text-slate-200 font-bold mb-1 text-lg">C'est calme ici...</p>
                    <p class="text-xs text-slate-500 max-w-[200px] mx-auto leading-relaxed">Appuyez sur le bouton ci-dessus pour ajouter votre premier repérage ! 🚀</p>
                </div>
            <% } %>

            <% leads.forEach(function(lead) { %>
                <div class="glass p-3 rounded-2xl flex gap-3 items-center active:bg-slate-800/80 transition">
                    <div class="w-16 h-16 bg-slate-800 rounded-xl overflow-hidden flex-shrink-0 border border-slate-700 relative">
                        <% if (lead.photo) { %>
                            <img src="<%= lead.photo %>" class="w-full h-full object-cover" loading="lazy">
                        <% } else { %>
                            <div class="w-full h-full flex items-center justify-center text-slate-600">
                                <i class="ph-fill ph-buildings text-2xl"></i>
                            </div>
                        <% } %>
                    </div>
                    
                    <div class="flex-1 min-w-0">
                        <div class="flex justify-between items-start">
                            <h3 class="font-bold text-white truncate pr-2"><%= lead.name %></h3>
                            <% if (lead.status === 'SIGNÉ') { %>
                                <span class="bg-green-500/20 text-green-400 border border-green-500/30 text-[10px] font-bold px-1.5 py-0.5 rounded flex items-center gap-1 shrink-0">
                                    <i class="ph-fill ph-check-circle"></i> SIGNÉ
                                </span>
                            <% } else { %>
                                <span class="bg-slate-700 text-slate-300 border border-slate-600 text-[10px] font-bold px-1.5 py-0.5 rounded flex items-center gap-1 shrink-0">
                                    <i class="ph-bold ph-clock"></i> EN COURS
                                </span>
                            <% } %>
                        </div>
                        <p class="text-xs text-slate-400 truncate mt-0.5 flex items-center gap-1">
                            <i class="ph-fill ph-map-pin text-slate-600"></i>
                            <%= lead.address || 'Localisation inconnue' %>
                        </p>
                        <p class="text-xs text-[#F59E0B] font-mono mt-1 flex items-center gap-1">
                            <i class="ph-fill ph-phone"></i> <%= lead.phone %>
                        </p>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>

    <div id="leadModal" class="hidden fixed inset-0 z-50">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm transition-opacity" onclick="closeModal()"></div>
        
        <div class="absolute bottom-0 left-0 w-full bg-[#0F172A] rounded-t-[2rem] p-6 shadow-2xl border-t border-slate-800 transform transition-transform duration-300 translate-y-0 max-h-[90vh] overflow-y-auto">
            
            <div class="w-12 h-1 bg-slate-700 rounded-full mx-auto mb-6"></div>
            
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-black text-white flex items-center gap-2">
                    <i class="ph-fill ph-crosshair text-[#F59E0B]"></i> Nouveau Repérage
                </h2>
                <button onclick="closeModal()" class="bg-slate-800 p-2 rounded-full text-slate-400 hover:text-white transition">
                    <i class="ph-bold ph-x"></i>
                </button>
            </div>
            
            <form id="addLeadForm" action="/agent/add-lead?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data" class="space-y-5">
                
                <div class="relative group">
                    <input type="file" id="photoInput" name="leadPhoto" accept="image/*" capture="environment" required class="hidden" onchange="previewImage(event)">
                    <label for="photoInput" class="block w-full aspect-video bg-slate-800 border-2 border-dashed border-slate-600 rounded-2xl flex flex-col items-center justify-center cursor-pointer hover:border-[#F59E0B] hover:bg-slate-800/50 transition relative overflow-hidden">
                        <div id="uploadPlaceholder" class="text-center">
                            <div class="w-12 h-12 bg-[#F59E0B]/10 text-[#F59E0B] rounded-full flex items-center justify-center mx-auto mb-2">
                                <i class="ph-fill ph-camera text-2xl"></i>
                            </div>
                            <p class="text-sm font-bold text-white">Prendre une photo</p>
                            <p class="text-[10px] text-slate-500">Immeuble ou devanture</p>
                        </div>
                        <img id="imagePreview" class="absolute inset-0 w-full h-full object-cover hidden">
                        <div id="changePhotoBtn" class="absolute bottom-2 right-2 bg-black/60 text-white text-xs px-2 py-1 rounded-lg backdrop-blur hidden flex items-center gap-1">
                            <i class="ph-bold ph-arrows-clockwise"></i> Changer
                        </div>
                    </label>
                </div>

                <div class="space-y-4">
                    <div>
                        <label class="text-xs font-bold text-slate-400 uppercase ml-1">Propriétaire / Contact</label>
                        <div class="relative mt-1">
                            <i class="ph-duotone ph-user absolute left-4 top-3.5 text-slate-500 text-lg"></i>
                            <input type="text" name="name" placeholder="Nom du contact" required class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 pl-11 text-white focus:border-[#F59E0B] focus:ring-1 focus:ring-[#F59E0B] outline-none transition">
                        </div>
                    </div>
    
                    <div>
                        <label class="text-xs font-bold text-slate-400 uppercase ml-1">Téléphone</label>
                        <div class="relative mt-1">
                            <i class="ph-duotone ph-phone absolute left-4 top-3.5 text-slate-500 text-lg"></i>
                            <input type="tel" name="phone" placeholder="07 07 ..." required class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 pl-11 text-white focus:border-[#F59E0B] focus:ring-1 focus:ring-[#F59E0B] outline-none transition">
                        </div>
                    </div>
               
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <label class="text-xs font-bold text-slate-400 uppercase ml-1">Localisation</label>
                            <button type="button" onclick="geoLocate()" class="text-[10px] font-bold text-[#F59E0B] flex items-center gap-1 hover:bg-[#F59E0B]/10 px-2 py-0.5 rounded transition">
                                <i class="ph-fill ph-navigation-arrow"></i> Ma position
                            </button>
                        </div>
                        <div class="relative">
                            <i class="ph-duotone ph-map-pin absolute left-4 top-3.5 text-slate-500 text-lg"></i>
                            <input type="text" id="addressInput" name="address" placeholder="Quartier, Rue..." required class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 pl-11 text-white focus:border-[#F59E0B] focus:ring-1 focus:ring-[#F59E0B] outline-none transition">
                        </div>
                    </div>
                </div>

                <button type="submit" class="w-full bg-[#F59E0B] hover:bg-orange-500 text-[#0B1120] font-black py-4 rounded-xl shadow-lg shadow-orange-500/20 active:scale-95 transition flex items-center justify-center gap-2 text-lg">
                    <i class="ph-bold ph-paper-plane-right"></i> ENREGISTRER
                </button>
            </form>
        </div>
    </div>

    <script>
        // 1. MODAL LOGIC
        function openModal() {
            document.getElementById('leadModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden'; 
        }

        function closeModal() {
            document.getElementById('leadModal').classList.add('hidden');
            document.body.style.overflow = '';
        }

        // 2. IMAGE PREVIEW
        function previewImage(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const img = document.getElementById('imagePreview');
                    img.src = e.target.result;
                    img.classList.remove('hidden');
                    document.getElementById('uploadPlaceholder').classList.add('hidden');
                    document.getElementById('changePhotoBtn').classList.remove('hidden');
                }
                reader.readAsDataURL(file);
            }
        }

        // 3. GEOLOCATION AVEC REVERSE GEOCODING (NOMINATIM)
        function geoLocate() {
            const input = document.getElementById('addressInput');
            
            if (!navigator.geolocation) {
                Swal.fire({ icon: 'error', title: 'Erreur', text: 'La géolocalisation n\'est pas supportée.' });
                return;
            }

            input.placeholder = "Localisation en cours...";
            
            navigator.geolocation.getCurrentPosition(
                async (position) => {
                    const lat = position.coords.latitude;
                    const lon = position.coords.longitude;
                    
                    try {
                        // Feedback visuel temporaire
                        input.value = `GPS: ${lat.toFixed(5)}, ${lon.toFixed(5)} (Recherche adresse...)`;

                        // Appel API OpenStreetMap (Nominatim)
                        const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`);
                        const data = await response.json();

                        if (data && data.display_name) {
                            // On simplifie l'adresse pour qu'elle ne soit pas trop longue
                            // On prend souvent les 3 premiers segments
                            let simpleAddress = data.display_name.split(',').slice(0, 3).join(',');
                            input.value = simpleAddress;
                            
                            Swal.fire({
                                toast: true,
                                position: 'top-end',
                                icon: 'success',
                                title: 'Adresse trouvée !',
                                showConfirmButton: false,
                                timer: 2000
                            });
                        } else {
                            // Fallback si pas d'adresse trouvée
                            input.value = `GPS: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
                        }
                    } catch (error) {
                        console.error('Erreur Geocoding:', error);
                        input.value = `GPS: ${lat.toFixed(5)}, ${lon.toFixed(5)}`; // Fallback en cas d'erreur réseau
                    }
                },
                (error) => {
                    input.placeholder = "Impossible de localiser";
                    Swal.fire({ icon: 'error', title: 'Erreur GPS', text: 'Vérifiez que la localisation est activée.' });
                },
                { enableHighAccuracy: true, timeout: 5000 }
            );
        }

        // 4. FEEDBACK FORMULAIRE (FLASH MESSAGES & LOADING)
        
        // Animation lors de la soumission
        document.getElementById('addLeadForm').addEventListener('submit', function(e) {
            const btn = this.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;
            
            btn.innerHTML = '<i class="ph-bold ph-spinner animate-spin"></i> ENVOI EN COURS...';
            btn.disabled = true;
            btn.classList.add('opacity-75', 'cursor-not-allowed');
            
            // Note: Si le serveur redirige, la page va recharger et le loader disparaîtra naturellement.
        });

        // Affichage des messages Flash au chargement
        document.addEventListener('DOMContentLoaded', () => {
            <% if (typeof locals.success !== 'undefined' && locals.success && locals.success.length > 0) { %>
                Swal.fire({
                    title: 'Excellent travail ! 🎯',
                    text: "<%= locals.success %>",
                    icon: 'success',
                    confirmButtonColor: '#F59E0B',
                    confirmButtonText: 'Continuer',
                    background: '#1e293b',
                    color: '#fff'
                });
            <% } %>

            <% if (typeof locals.error !== 'undefined' && locals.error && locals.error.length > 0) { %>
                Swal.fire({
                    title: 'Erreur',
                    text: "<%= locals.error %>",
                    icon: 'error',
                    confirmButtonColor: '#ef4444',
                    background: '#1e293b',
                    color: '#fff'
                });
            <% } %>
        });

        // 5. SERVICE WORKER
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js'));
        }
    </script>
</body>
</html>
