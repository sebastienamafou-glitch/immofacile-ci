<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Propriétaire | ImmoFacile CI</title>
    
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0B1120">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="icon" type="image/png" href="/images/immo_logo.png">
    <link rel="apple-touch-icon" href="/images/immo_logo.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        html { scroll-behavior: smooth; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        #sidebar { transition: transform 0.3s ease-in-out; }
        @media (max-width: 768px) {
            #sidebar.closed { transform: translateX(-100%); }
            #sidebar.open { transform: translateX(0); }
        }
    </style>
</head>
<body class="bg-[#0B1120] text-white font-['Plus_Jakarta_Sans']">

    <% 
    /* --- FONCTIONS UTILITAIRES EJS --- */
    // Fonction pour formater le numéro WhatsApp proprement (DRY)
    const formatWaLink = (phone, text = '') => {
        if (!phone) return '#';
        let clean = phone.replace(/\s+/g, '').replace(/^(\+)?/, '');
        if (!clean.startsWith('225')) clean = '225' + clean;
        return `https://wa.me/${clean}${text ? '?text=' + encodeURIComponent(text) : ''}`;
    };

    // Formatage monétaire
    const formatMoney = (amount) => {
        return (amount || 0).toLocaleString('fr-FR');
    };
    %>

    <div class="md:hidden flex items-center justify-between p-4 bg-[#0B1120] border-b border-slate-800 sticky top-0 z-50">
        <img src="/images/immo_logo.png" alt="Logo" class="h-8">
        <button onclick="toggleMenu()" class="text-white p-2 focus:outline-none rounded-lg hover:bg-slate-800 transition" id="burgerBtn">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path id="burgerPath" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
            </svg>
        </button>
    </div>

    <div class="flex min-h-screen">
        
        <aside id="sidebar" class="fixed inset-y-0 left-0 w-64 border-r border-slate-800 p-6 bg-[#0B1120] overflow-y-auto z-40 md:translate-x-0 closed shadow-2xl md:shadow-none flex flex-col">
            <div class="mb-10 text-center md:text-left hidden md:block">
                <img src="/images/immo_logo.png" alt="ImmoFacile CI" class="h-16 object-contain">
            </div>

            <nav class="space-y-4 flex-1">
                <a href="#dashboard" onclick="closeMenuMobile()" class="block p-3 bg-blue-600 rounded-xl text-white font-bold hover:bg-blue-700 transition flex items-center gap-3">
                    <span>📊</span> Tableau de bord
                </a>
                <a href="#biens" onclick="closeMenuMobile()" class="block p-3 text-slate-400 hover:text-white hover:bg-slate-900 rounded-xl transition flex items-center gap-3">
                    <span>🏠</span> Mes Biens
                </a>
                <a href="#locataires" onclick="closeMenuMobile()" class="block p-3 text-slate-400 hover:text-white hover:bg-slate-900 rounded-xl transition flex items-center gap-3">
                    <span>👥</span> Locataires
                </a>
                <a href="#documents" onclick="closeMenuMobile()" class="block p-3 text-slate-400 hover:text-white hover:bg-slate-900 rounded-xl transition flex items-center gap-3">
                    <span>📂</span> Documents
                </a>
                <a href="#artisans" onclick="closeMenuMobile()" class="block p-3 text-slate-400 hover:text-white hover:bg-slate-900 rounded-xl transition flex items-center gap-3">
                    <span>🔨</span> Artisans
                </a>
                <a href="/logout" class="block p-3 text-red-400 hover:text-red-500 mt-4 hover:bg-red-500/10 rounded-xl transition flex items-center gap-3">
                    <span>🚪</span> Déconnexion
                </a>
            </nav>

            <div class="mt-auto pt-6 border-t border-slate-800">
                <p class="text-[10px] text-slate-500 uppercase tracking-widest mb-2">Développé par</p>
                <img src="/images/logo_webappci.png" alt="WebApp CI" class="h-8 object-contain opacity-80 mb-2">
                <div class="flex flex-col gap-1">
                    <a href="mailto:contact@webappci.com" class="text-[10px] text-slate-400 hover:text-white">contact@webappci.com</a>
                    <a href="/privacy" class="text-[10px] text-[#F59E0B] hover:underline">Confidentialité</a>
                </div>
            </div>
        </aside>

        <div id="overlay" onclick="toggleMenu()" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden backdrop-blur-sm transition-opacity"></div>

        <main class="flex-1 p-4 md:p-8 md:ml-64 w-full">
            
            <header id="dashboard" class="mb-10 pt-4">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
                    <h2 class="text-sm font-bold text-slate-400 uppercase tracking-widest">La Météo des Revenus</h2>
                    <div class="w-full md:w-auto relative">
                        <input type="text" id="globalSearch" onkeyup="filterAll()" placeholder="🔍 Chercher un bien, locataire..." 
                               class="w-full md:w-64 bg-slate-900 border border-slate-800 rounded-full px-4 py-2 text-sm text-white focus:border-blue-500 outline-none transition">
                    </div>
                </div>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
                    <div class="bg-slate-900 border border-slate-800 p-5 rounded-[2rem]">
                        <p class="text-slate-400 text-xs mb-1">Revenus Bruts</p>
                        <p class="text-2xl font-black text-white">
                            <%= formatMoney(typeof totalRent !== 'undefined' ? totalRent : 0) %> 
                            <span class="text-xs text-slate-500 font-normal">FCFA</span>
                        </p>
                    </div>

                    <div class="bg-slate-900 border border-slate-800 p-5 rounded-[2rem]">
                        <p class="text-slate-400 text-xs mb-1">Dépenses du mois</p>
                        <p class="text-2xl font-black text-red-500">
                            - <%= formatMoney(typeof totalExpenses !== 'undefined' ? totalExpenses : 0) %>
                        </p>
                    </div>

                    <div class="bg-gradient-to-br from-blue-900 to-slate-900 border border-blue-500/30 p-5 rounded-[2rem]">
                        <p class="text-blue-200 text-xs mb-1 font-bold">BÉNÉFICE NET</p>
                        <p class="text-2xl font-black text-white">
                            <%= formatMoney(typeof netIncome !== 'undefined' ? netIncome : 0) %>
                        </p>
                    </div>

                    <div class="bg-slate-900 border border-slate-800 p-5 rounded-[2rem]">
                        <p class="text-slate-400 text-xs mb-1">Séquestre (Caution)</p>
                        <p class="text-2xl font-black text-[#F59E0B]">
                            <%= formatMoney(typeof totalDeposit !== 'undefined' ? totalDeposit : 0) %>
                        </p>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
                    <div class="lg:col-span-2 bg-slate-900 border border-slate-800 p-6 rounded-[2rem]">
                        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Analyse Financière du Mois</h3>
                        <div class="h-48 w-full">
                            <canvas id="financeChart"></canvas>
                        </div>
                    </div>

                    <div class="p-6 bg-gradient-to-br from-[#F59E0B] to-orange-600 rounded-[2rem] shadow-xl text-white relative overflow-hidden flex flex-col justify-between">
                        <div class="relative z-10">
                            <p class="text-xs font-bold uppercase tracking-widest opacity-80 mb-2">Solde Disponible</p>
                            <div class="flex items-baseline gap-1 mb-4">
                                <span class="text-4xl font-black"><%= formatMoney(user.walletBalance) %></span>
                                <span class="text-sm font-bold opacity-80">FCFA</span>
                            </div>
                            <% if (user.walletBalance < 2000) { %>
                                <p class="text-xs bg-black/20 inline-block px-2 py-1 rounded font-bold text-red-100">⚠️ Solde critique</p>
                            <% } %>
                        </div>
                        <button onclick="document.getElementById('rechargeModal').classList.remove('hidden')" class="w-full bg-white text-orange-600 px-6 py-3 rounded-xl font-bold shadow-lg hover:scale-105 transition flex items-center justify-center gap-2">
                            <span>⚡️</span> Recharger
                        </button>
                    </div>
                </div>
            </header>

            <% if (typeof activeIncidentsCount !== 'undefined' && activeIncidentsCount > 0) { %>
            <section class="mb-10 animate-pulse-slow">
                <h3 class="text-xl font-bold mb-4 text-red-500 flex items-center gap-2">🚨 Urgences en cours (<%= activeIncidentsCount %>)</h3>
                <div class="grid gap-4">
                    <% properties.forEach(function(prop) { %>
                        <% prop.incidents.forEach(function(inc) { %>
                            <% if (inc.status !== 'RESOLVED') { %>
                                <div class="bg-red-500/10 border border-red-500/30 p-5 rounded-2xl flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                                    <div class="flex-1">
                                        <div class="flex items-center gap-2 mb-1">
                                            <span class="bg-red-500 text-white text-[10px] font-bold px-2 py-1 rounded uppercase"><%= inc.priority %></span>
                                            <p class="font-bold text-white"><%= inc.title %></p>
                                        </div>
                                        <p class="text-sm text-slate-400">Signalé par <%= inc.reporter.name %> • <%= prop.title %></p>
                                        <p class="text-xs text-slate-500 mt-2 italic">"<%= inc.description %>"</p>
                                    </div>
                                    <form action="/owner/resolve-incident" method="POST">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <input type="hidden" name="incidentId" value="<%= inc.id %>">
                                        <button type="submit" class="w-full sm:w-auto bg-green-600 hover:bg-green-700 text-white text-xs font-bold px-4 py-2 rounded-lg transition shadow-lg shadow-green-900/20">✅ Résoudre</button>
                                    </form>
                                </div>
                            <% } %>
                        <% }); %>
                    <% }); %>
                </div>
            </section>
            <% } %>

            <section id="biens" class="mb-10 pt-10 border-t border-slate-800">
                <h3 class="text-xl font-bold mb-6 flex items-center gap-2">🏠 Mes Biens</h3>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                    <% properties.forEach(function(prop) { %>
                        <% const activeLease = prop.leases.find(l => l.isActive === true); %>
                        <div class="searchable-item bg-slate-900/50 border border-slate-800 p-5 rounded-2xl hover:border-slate-700 transition">
                            <div class="flex justify-between items-start mb-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-3 h-3 <%= activeLease ? 'bg-green-500' : 'bg-slate-600' %> rounded-full shadow-[0_0_8px_rgba(34,197,94,0.5)]"></div>
                                    <div>
                                        <p class="font-bold text-white text-sm searchable-text"><%= prop.title %></p>
                                        <p class="text-xs text-slate-500"><%= prop.commune %> • 
                                            <span class="<%= activeLease ? 'text-green-400' : 'text-slate-500' %> searchable-text">
                                                <%= activeLease ? 'Loué à ' + activeLease.tenant.name : 'Vacant' %>
                                            </span>
                                        </p>
                                    </div>
                                </div>
                                <span class="text-xs font-bold <%= activeLease ? 'text-green-400' : 'text-slate-500' %>">
                                    <%= activeLease ? '+' : '' %> <%= formatMoney(prop.price) %> FCFA
                                    <%= activeLease ? '' : '(Estimé)' %>
                                </span>
                            </div>

                            <% if (activeLease) { %>
                                <div class="mt-4 pt-4 border-t border-slate-800 space-y-4">
                                    <div class="flex justify-between items-center text-xs">
                                        <span class="text-slate-500">📅 Entrée : <%= new Date(activeLease.startDate).toLocaleDateString('fr-FR') %></span>
                                        <div class="flex gap-3">
                                            <a href="/owner/contract/<%= activeLease.id %>" target="_blank" class="text-[#F59E0B] font-bold hover:underline">📜 Contrat</a>
                                            <a href="/owner/inventory/<%= activeLease.id %>?type=ENTREE" target="_blank" class="text-slate-400 hover:text-white">📥 EDL</a>
                                        </div>
                                    </div>

                                    <div class="grid grid-cols-2 gap-2">
                                        <a href="/owner/formal-notice/<%= activeLease.id %>" target="_blank" class="text-center bg-red-600/20 text-red-500 border border-red-500/50 text-[10px] font-bold py-2 rounded-lg uppercase hover:bg-red-600/30 transition">⚖️ Huissier</a>
                                        <button onclick="openExitModal('<%= activeLease.id %>', '<%= activeLease.tenant.name %>', '<%= activeLease.depositAmount %>')" class="bg-slate-800 text-slate-300 text-[10px] font-bold py-2 rounded-lg uppercase border border-slate-600 hover:bg-slate-700 transition">🚪 Sortie</button>
                                    </div>

                                    <% 
                                        const dateOptions = { month: 'long', year: 'numeric', timeZone: 'Africa/Abidjan' };
                                        const currentMonthStr = new Date().toLocaleString('fr-FR', dateOptions);
                                        const lastPayment = (activeLease.payments && activeLease.payments.length > 0) ? activeLease.payments[activeLease.payments.length - 1] : null;
                                        const isPaidThisMonth = lastPayment && lastPayment.month.toLowerCase().includes(new Date().toLocaleString('fr-FR', { month: 'long' }).toLowerCase());
                                    %>

                                    <% if (isPaidThisMonth) { %>
                                        <div class="flex items-center justify-between bg-green-500/10 p-2 rounded-lg border border-green-500/20">
                                            <span class="text-green-400 text-xs font-bold">✅ Loyer à jour</span>
                                            <a href="/owner/receipt/<%= lastPayment.id %>" target="_blank" class="text-slate-400 text-xs underline hover:text-white">Quittance</a>
                                        </div>
                                    <% } else { %>
                                        <div class="flex flex-col gap-2">
                                            <form action="/owner/pay-rent" method="POST">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <input type="hidden" name="amount" value="<%= activeLease.monthlyRent %>">
                                                <input type="hidden" name="month" value="<%= currentMonthStr %>">
                                                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 py-2 rounded-lg text-xs font-bold transition">
                                                    💰 Encaisser <%= new Date().toLocaleString('fr-FR', { month: 'long' }) %>
                                                </button>
                                            </form>
                                            
                                            <a href="<%= formatWaLink(activeLease.tenant.phone, `Bonjour ${activeLease.tenant.name}, le loyer de ${new Date().toLocaleString('fr-FR', { month: 'long' })} est attendu.`) %>"
                                               target="_blank" class="w-full bg-[#25D366] hover:bg-[#20bd5a] py-2 rounded-lg text-xs font-bold text-center transition flex items-center justify-center gap-2">
                                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                                                Relance
                                            </a>
                                        </div>
                                    <% } %>
                                </div>
                            <% } else { %>
                                <div class="mt-4 pt-4 border-t border-slate-800">
                                    <a href="/owner/add-tenant" class="flex items-center justify-center gap-2 w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl transition shadow-lg shadow-blue-900/20">
                                        <span>👤</span> Ajouter un Locataire
                                    </a>
                                </div>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
            </section>

            <section id="locataires" class="mb-10 pt-10 border-t border-slate-800">
                <h3 class="text-xl font-bold mb-6">👤 Annuaire Locataires</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <% let hasTenants = false; %>
                    <% properties.forEach(function(prop) { 
                        prop.leases.forEach(function(lease) { 
                            if (lease.isActive) { 
                                hasTenants = true; 
                    %>
                        <div class="searchable-item bg-slate-900 border border-slate-800 p-4 rounded-2xl flex items-center justify-between hover:border-slate-700 transition group">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center font-bold text-white shadow-lg group-hover:scale-110 transition">
                                    <%= lease.tenant.name.charAt(0) %>
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-white searchable-text"><%= lease.tenant.name %></p>
                                    <p class="text-[10px] text-slate-400"><%= lease.tenant.phone %></p>
                                    <p class="text-[10px] text-slate-500 hidden searchable-text"><%= prop.title %></p> </div>
                            </div>
                            <a href="<%= formatWaLink(lease.tenant.phone) %>" target="_blank" class="bg-[#25D366] p-2 rounded-full hover:scale-110 transition shadow-lg">
                                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.017-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
                            </a>
                        </div>
                    <% } }); }); %>
                    
                    <% if (!hasTenants) { %> 
                        <div class="col-span-full flex flex-col items-center justify-center py-8 border-2 border-dashed border-slate-800 rounded-2xl bg-slate-900/30">
                            <p class="text-3xl mb-2">👻</p>
                            <p class="text-slate-500 italic">Aucun locataire actif</p>
                        </div> 
                    <% } %>
                </div>
            </section>

            <section id="documents" class="mb-10 pt-10 border-t border-slate-800">
                <h3 class="text-xl font-bold mb-6">📂 Documents Administratifs (Actifs)</h3>
                <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden overflow-x-auto">
                    <table class="w-full text-left text-sm min-w-[600px]">
                        <thead class="bg-slate-800 text-slate-400 text-xs uppercase font-bold">
                            <tr>
                                <th class="px-4 py-3">Document</th>
                                <th class="px-4 py-3">Locataire</th>
                                <th class="px-4 py-3 text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-800">
                            <% properties.forEach(prop => { 
                                prop.leases.forEach(lease => { 
                                    if(lease.isActive) { %>
                                <tr class="searchable-item hover:bg-slate-800/50 transition">
                                    <td class="px-4 py-3 flex items-center gap-2 searchable-text">
                                        📜 Contrat de bail <span class="text-slate-500 text-xs">- <%= prop.title %></span>
                                    </td>
                                    <td class="px-4 py-3 text-slate-400 searchable-text"><%= lease.tenant.name %></td>
                                    <td class="px-4 py-3 text-right">
                                        <a href="/owner/contract/<%= lease.id %>" target="_blank" class="text-blue-400 font-bold hover:underline bg-blue-400/10 px-3 py-1 rounded-lg">Voir</a>
                                    </td>
                                </tr>
                                <tr class="searchable-item hover:bg-slate-800/50 transition">
                                    <td class="px-4 py-3">📥 État des lieux entrée</td>
                                    <td class="px-4 py-3 text-slate-400 searchable-text"><%= lease.tenant.name %></td>
                                    <td class="px-4 py-3 text-right">
                                        <a href="/owner/inventory/<%= lease.id %>?type=ENTREE" target="_blank" class="text-blue-400 font-bold hover:underline bg-blue-400/10 px-3 py-1 rounded-lg">Voir</a>
                                    </td>
                                </tr>
                                <% if (lease.payments && lease.payments.length > 0) { %>
                                    <tr class="searchable-item hover:bg-slate-800/50 transition">
                                        <td class="px-4 py-3">💰 Dernière Quittance</td>
                                        <td class="px-4 py-3 text-slate-400 searchable-text"><%= lease.tenant.name %></td>
                                        <td class="px-4 py-3 text-right">
                                            <a href="/owner/receipt/<%= lease.payments[lease.payments.length-1].id %>" target="_blank" class="text-blue-400 font-bold hover:underline bg-blue-400/10 px-3 py-1 rounded-lg">Voir</a>
                                        </td>
                                    </tr>
                                <% } %>
                            <% } }) }) %>
                        </tbody>
                    </table>
                </div>
            </section>

            <section id="artisans" class="mb-10 pt-10 border-t border-slate-800">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold">🔨 Artisans Agréés</h3>
                    <button onclick="document.getElementById('artisanModal').classList.remove('hidden')" class="text-blue-400 text-sm font-bold hover:text-blue-300 transition bg-blue-400/10 px-4 py-2 rounded-lg">+ Ajouter</button>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                    <% if (locals.artisans && artisans.length > 0) { %>
                        <% artisans.forEach(artisan => { %>
                            <div class="searchable-item bg-slate-900 border border-slate-800 p-5 rounded-2xl group transition hover:border-[#F59E0B]/50 hover:bg-slate-800">
                                <div class="flex justify-between items-start mb-2">
                                    <h4 class="font-bold text-white group-hover:text-[#F59E0B] transition searchable-text"><%= artisan.name %></h4>
                                    <% if (artisan.isVerified) { %> <span class="bg-green-500/20 text-green-400 text-[8px] px-2 py-1 rounded-full uppercase">Vérifié</span> <% } %>
                                </div>
                                <p class="text-[#F59E0B] text-xs mb-1 searchable-text"><%= artisan.job %></p>
                                <p class="text-slate-500 text-[10px] mb-4 searchable-text">📍 <%= artisan.location %></p>
                                <a href="tel:<%= artisan.phone %>" class="flex items-center justify-center gap-2 w-full bg-slate-800 py-2 rounded-lg text-xs font-bold hover:bg-blue-600 hover:text-white transition text-slate-300">📞 Appeler</a>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-span-full flex flex-col items-center justify-center py-10 border-2 border-dashed border-slate-800 rounded-3xl bg-slate-900/30">
                            <p class="text-4xl mb-2">👨‍🔧</p>
                            <p class="text-slate-500 font-medium mb-4">Aucun artisan partenaire</p>
                            <button onclick="document.getElementById('artisanModal').classList.remove('hidden')" class="text-blue-400 font-bold hover:underline">
                                + Ajouter mon premier artisan
                            </button>
                        </div>
                    <% } %>
                </div>
            </section>

        </main>
    </div>

    <div class="fixed bottom-6 right-6 flex flex-col items-end gap-3 z-30">
        <button onclick="document.getElementById('expenseModal').classList.remove('hidden')" class="bg-red-500 text-white p-4 rounded-2xl shadow-2xl flex items-center gap-2 font-bold text-sm hover:scale-105 transition hover:bg-red-600">
            <span>💸</span> <span class="hidden sm:inline">Dépense</span>
        </button>
        <a href="/owner/add-property" class="bg-[#F59E0B] text-[#0B1120] p-4 rounded-2xl shadow-2xl flex items-center gap-2 font-bold text-sm hover:scale-105 transition hover:bg-yellow-400">
            <span class="text-xl">+</span> <span class="hidden sm:inline">Nouveau Bien</span>
        </a>
    </div>

    <div id="rechargeModal" class="hidden fixed inset-0 bg-black/90 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
        <div class="bg-slate-900 border border-slate-700 p-8 rounded-3xl w-full max-w-sm relative shadow-2xl">
            <button onclick="document.getElementById('rechargeModal').classList.add('hidden')" class="absolute top-4 right-4 text-slate-500 hover:text-white transition">✕</button>
            <div class="text-center mb-6">
                <h2 class="text-xl font-bold text-white mb-2">Recharger mon compte</h2>
                <p class="text-slate-400 text-sm">Paiement sécurisé via CinetPay</p>
            </div>
            <form action="/api/payment/init" method="POST" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <select name="amount" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white font-bold outline-none focus:border-[#F59E0B]">
                    <option value="5000">5 000 FCFA</option>
                    <option value="10000" selected>10 000 FCFA</option>
                    <option value="20000">20 000 FCFA</option>
                    <option value="50000">50 000 FCFA</option>
                </select>
                <button type="submit" class="w-full bg-[#F59E0B] text-[#0B1120] font-black py-4 rounded-xl hover:bg-yellow-400 transition">Payer maintenant</button>
            </form>
        </div>
    </div>

    <div id="exitModal" class="hidden fixed inset-0 bg-black/95 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
        <div class="bg-slate-900 border border-slate-700 p-8 rounded-3xl w-full max-w-md relative shadow-2xl">
            <button onclick="document.getElementById('exitModal').classList.add('hidden')" class="absolute top-4 right-4 text-slate-500 hover:text-white transition">✕</button>
            <h2 class="text-xl font-bold text-white mb-1">Départ Locataire</h2>
            <p id="exitTenantName" class="text-sm text-slate-500 mb-6"></p>
            <form action="/owner/end-lease" method="POST" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="leaseId" id="exitLeaseId">
                <div class="bg-slate-800 p-4 rounded-xl border border-slate-700">
                    <p class="text-xs text-slate-400 uppercase">Caution versée</p>
                    <p id="exitDepositDisplay" class="text-xl font-bold text-[#F59E0B]">0 FCFA</p>
                </div>
                <div>
                    <label class="text-xs font-bold text-slate-400 uppercase">Retenue (Travaux/Impayés)</label>
                    <input type="number" name="deduction" value="0" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white mt-1 outline-none focus:border-red-500">
                </div>
                <button type="submit" class="w-full bg-red-600 hover:bg-red-500 text-white font-bold py-3 rounded-xl transition">Confirmer le départ</button>
            </form>
        </div>
    </div>

    <div id="expenseModal" class="hidden fixed inset-0 bg-black/90 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
        <div class="bg-slate-900 border border-slate-700 p-8 rounded-3xl w-full max-w-md relative shadow-2xl">
            <button onclick="document.getElementById('expenseModal').classList.add('hidden')" class="absolute top-4 right-4 text-slate-500 hover:text-white transition">✕</button>
            <h2 class="text-xl font-bold mb-6 text-white">Nouvelle dépense</h2>
            <form action="/owner/add-expense" method="POST" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <select name="propertyId" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white outline-none focus:border-red-500">
                    <% properties.forEach(function(prop) { %> <option value="<%= prop.id %>"><%= prop.title %></option> <% }); %>
                </select>
                <select name="category" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white outline-none focus:border-red-500">
                    <option value="REPARATION">Réparation / Travaux</option>
                    <option value="TAXE">Impôts & Taxes</option>
                    <option value="SYNDIC">Charges de copropriété</option>
                </select>
                <input type="text" name="description" placeholder="Description (ex: Plomberie)" required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white outline-none focus:border-red-500">
                <input type="number" name="amount" placeholder="Montant (FCFA)" required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white outline-none focus:border-red-500">
                <button type="submit" class="w-full bg-red-500 hover:bg-red-600 text-white font-bold py-3 rounded-xl mt-4 transition">Enregistrer</button>
            </form>
        </div>
    </div>

    <div id="artisanModal" class="hidden fixed inset-0 bg-black/90 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
        <div class="bg-slate-900 border border-slate-700 p-8 rounded-3xl w-full max-w-md relative shadow-2xl">
            <button onclick="document.getElementById('artisanModal').classList.add('hidden')" class="absolute top-4 right-4 text-slate-500 hover:text-white transition">✕</button>
            <h2 class="text-xl font-bold mb-6 text-white text-center">Ajouter un Partenaire</h2>
            <form action="/owner/add-artisan" method="POST" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="text" name="name" placeholder="Nom complet" required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white outline-none focus:border-blue-500">
                <select name="job" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white outline-none focus:border-blue-500">
                    <option value="Plombier">Plombier</option>
                    <option value="Electricien">Électricien</option>
                    <option value="Climaticien">Climatisation</option>
                    <option value="Menuisier">Menuisier</option>
                    <option value="Peintre">Peintre</option>
                    <option value="Maçon">Maçon</option>
                </select>
                <select name="location" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white outline-none focus:border-blue-500">
                    <option value="Cocody">Cocody</option>
                    <option value="Yopougon">Yopougon</option>
                    <option value="Marcory">Marcory</option>
                    <option value="Plateau">Plateau</option>
                    <option value="Angré">Angré</option>
                </select>
                <input type="tel" name="phone" placeholder="Téléphone (ex: 0707...)" required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white outline-none focus:border-blue-500">
                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl mt-4 transition">Enregistrer</button>
            </form>
        </div>
    </div>

    <script>
        // --- 1. Gestion du Menu Burger Mobile ---
        function toggleMenu() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('overlay');
            const burgerPath = document.getElementById('burgerPath');
            
            if (sidebar.classList.contains('closed')) {
                sidebar.classList.remove('closed');
                sidebar.classList.add('open');
                overlay.classList.remove('hidden');
                burgerPath.setAttribute('d', 'M6 18L18 6M6 6l12 12');
            } else {
                sidebar.classList.add('closed');
                sidebar.classList.remove('open');
                overlay.classList.add('hidden');
                burgerPath.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
            }
        }

        function closeMenuMobile() {
            if (window.innerWidth < 768) {
                toggleMenu();
            }
        }

        // --- 2. Modals ---
        function openExitModal(leaseId, tenantName, deposit) {
            document.getElementById('exitModal').classList.remove('hidden');
            document.getElementById('exitLeaseId').value = leaseId;
            document.getElementById('exitTenantName').innerText = "Fin de bail pour : " + tenantName;
            document.getElementById('exitDepositDisplay').innerText = parseInt(deposit).toLocaleString('fr-FR') + " FCFA";
        }

        // --- 3. Filtre de Recherche Global ---
        function filterAll() {
            const input = document.getElementById('globalSearch');
            const filter = input.value.toUpperCase();
            const items = document.querySelectorAll('.searchable-item');

            items.forEach(item => {
                const text = item.innerText || item.textContent;
                if (text.toUpperCase().indexOf(filter) > -1) {
                    item.style.display = "";
                } else {
                    item.style.display = "none";
                }
            });
        }

        // --- 4. Initialisation Chart.js (Graphique) ---
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('financeChart').getContext('2d');
            
            // Récupération sécurisée des variables EJS
            const revenus = <%= typeof totalRent !== 'undefined' ? totalRent : 0 %>;
            const depenses = <%= typeof totalExpenses !== 'undefined' ? totalExpenses : 0 %>;

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Revenus', 'Dépenses'],
                    datasets: [{
                        label: 'Montant (FCFA)',
                        data: [revenus, depenses],
                        backgroundColor: [
                            'rgba(34, 197, 94, 0.7)', // Vert pour revenus
                            'rgba(239, 68, 68, 0.7)'  // Rouge pour dépenses
                        ],
                        borderColor: [
                            'rgb(34, 197, 94)',
                            'rgb(239, 68, 68)'
                        ],
                        borderWidth: 1,
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(255, 255, 255, 0.1)' },
                            ticks: { color: '#94a3b8' }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#ffffff', font: { weight: 'bold' } }
                        }
                    }
                }
            });
        });

        // PWA Service Worker
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW Erreur', err));
            });
        }
    </script>
</body>
</html>
