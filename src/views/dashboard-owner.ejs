<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Propriétaire | ImmoFacile CI</title>
    
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0B1120">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="apple-touch-icon" href="/icon.png">

    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(reg => console.log('App installée (SW Registered) ✅'))
                    .catch(err => console.log('Erreur SW ❌', err));
            });
        }
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>html { scroll-behavior: smooth; }</style>
</head>
<body class="bg-[#0B1120] text-white font-['Plus_Jakarta_Sans']">

    <div class="flex min-h-screen">
        <aside class="w-64 border-r border-slate-800 p-6 hidden md:flex flex-col fixed h-full bg-[#0B1120] overflow-y-auto z-10">
            <div class="mb-10 text-center md:text-left">
                <img src="/images/immo_logo.png" alt="ImmoFacile CI" class="h-16 object-contain">
            </div>

            <nav class="space-y-4 flex-1">
                <a href="#dashboard" class="block p-3 bg-blue-600 rounded-xl text-white font-bold hover:bg-blue-700 transition">Tableau de bord</a>
                <a href="#biens" class="block p-3 text-slate-400 hover:text-white hover:bg-slate-900 rounded-xl transition">Mes Biens</a>
                <a href="#locataires" class="block p-3 text-slate-400 hover:text-white hover:bg-slate-900 rounded-xl transition">Locataires</a>
                <a href="#documents" class="block p-3 text-slate-400 hover:text-white hover:bg-slate-900 rounded-xl transition">Documents</a>
                <a href="/logout" class="block p-3 text-red-400 hover:text-red-500 mt-4 hover:bg-red-500/10 rounded-xl transition">Déconnexion</a>
            </nav>

            <div class="mt-auto pt-6 border-t border-slate-800 text-center md:text-left">
                <p class="text-[10px] text-slate-500 uppercase tracking-widest mb-2">Développé par</p>
                <img src="/images/logo_webappci.png" alt="WebApp CI" class="h-8 object-contain opacity-80 hover:opacity-100 transition mb-2">
                <div class="flex flex-col gap-1">
                    <a href="mailto:contact@webappci.com" class="text-[10px] text-slate-400 hover:text-white">contact@webappci.com</a>
                    <a href="/privacy" class="text-[10px] text-[#F59E0B] hover:underline">Confidentialité</a>
                </div>
            </div>
        </aside>

        <main class="flex-1 p-8 md:ml-64">
            <header id="dashboard" class="mb-10 pt-4">
                <h2 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-2">La Météo des Revenus</h2>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
                    <div class="bg-slate-900 border border-slate-800 p-5 rounded-[2rem]">
                        <p class="text-slate-400 text-xs mb-1">Revenus Bruts</p>
                        <p class="text-2xl font-black text-white"><%= typeof totalRent !== 'undefined' ? totalRent.toLocaleString('fr-FR') : 0 %></p>
                        <span class="text-xs text-slate-500">FCFA / mois</span>
                    </div>

                    <div class="bg-slate-900 border border-slate-800 p-5 rounded-[2rem]">
                        <p class="text-slate-400 text-xs mb-1">Dépenses du mois</p>
                        <p class="text-2xl font-black text-red-500">- <%= typeof totalExpenses !== 'undefined' ? totalExpenses.toLocaleString('fr-FR') : 0 %></p>
                        <span class="text-xs text-slate-500">Réparations, Taxes...</span>
                    </div>

                    <div class="bg-gradient-to-br from-blue-900 to-slate-900 border border-blue-500/30 p-5 rounded-[2rem]">
                        <p class="text-blue-200 text-xs mb-1 font-bold">BÉNÉFICE NET</p>
                        <p class="text-2xl font-black text-white"><%= typeof netIncome !== 'undefined' ? netIncome.toLocaleString('fr-FR') : 0 %></p>
                        <span class="text-xs text-blue-200/50">Cash-flow réel</span>
                    </div>

                    <div class="bg-slate-900 border border-slate-800 p-5 rounded-[2rem]">
                        <p class="text-slate-400 text-xs mb-1">Séquestre (Caution)</p>
                        <p class="text-2xl font-black text-[#F59E0B]"><%= typeof totalDeposit !== 'undefined' ? totalDeposit.toLocaleString('fr-FR') : 0 %></p>
                        <span class="text-xs text-slate-500">FCFA bloqués</span>
                    </div>
                </div>

                <div class="mb-8 p-6 bg-gradient-to-r from-[#F59E0B] to-orange-600 rounded-3xl shadow-xl text-white relative overflow-hidden">
                    <div class="absolute top-0 right-0 opacity-10 transform translate-x-4 -translate-y-4">
                        <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.15-1.46-3.27-3.4h1.96c.1 1.05 1.18 1.91 2.53 1.91 1.33 0 2.26-.86 2.26-1.9 0-1.02-.96-1.47-2.27-1.79l-1.46-.35c-2.12-.54-2.77-1.84-2.77-3.04 0-1.86 1.48-3 3.29-3.32V4h2.67v1.9c1.43.33 2.65 1.25 2.76 2.9h-1.86c-.1-1.03-1.05-1.57-2.13-1.57-1.22 0-2.02.77-2.02 1.62 0 .97.99 1.43 2.23 1.74l1.49.37c2.12.55 2.82 1.83 2.82 3.16 0 1.95-1.55 3.19-3.56 3.49z"/></svg>
                    </div>

                    <div class="relative z-10 flex justify-between items-center">
                        <div>
                            <p class="text-xs font-bold uppercase tracking-widest opacity-80 mb-1">Solde Disponible</p>
                            <div class="flex items-baseline gap-1">
                                <span class="text-4xl font-black"><%= user.credit.toLocaleString('fr-FR') %></span>
                                <span class="text-sm font-bold opacity-80">FCFA</span>
                            </div>
                            <% if (user.credit < 2000) { %>
                                <p class="text-xs bg-black/20 inline-block px-2 py-1 rounded mt-2 font-bold text-red-100">⚠️ Solde critique</p>
                            <% } %>
                        </div>

                        <button onclick="document.getElementById('rechargeModal').classList.remove('hidden')" class="bg-white text-orange-600 px-6 py-3 rounded-xl font-bold shadow-lg hover:scale-105 transition flex items-center gap-2">
                            <span>⚡️</span> Recharger
                        </button>
                    </div>
                </div>
            </header>

            <% if (typeof activeIncidentsCount !== 'undefined' && activeIncidentsCount > 0) { %>
            <section class="mb-10 animate-pulse">
                <h3 class="text-xl font-bold mb-4 text-red-500 flex items-center gap-2">🚨 Urgences en cours (<%= activeIncidentsCount %>)</h3>
                <div class="grid gap-4">
                    <% properties.forEach(function(prop) { %>
                        <% prop.incidents.forEach(function(inc) { %>
                            <% if (inc.status !== 'RESOLVED') { %>
                                <div class="bg-red-500/10 border border-red-500/30 p-5 rounded-2xl flex justify-between items-center">
                                    <div>
                                        <div class="flex items-center gap-2 mb-1">
                                            <span class="bg-red-500 text-white text-[10px] font-bold px-2 py-1 rounded uppercase"><%= inc.priority %></span>
                                            <p class="font-bold text-white"><%= inc.title %></p>
                                        </div>
                                        <p class="text-sm text-slate-400">Signalé par <%= inc.reporter.name %> • <%= prop.title %></p>
                                        <p class="text-xs text-slate-500 mt-2 italic">"<%= inc.description %>"</p>
                                    </div>
                                    <form action="/resolve-incident" method="POST">
                                        <input type="hidden" name="incidentId" value="<%= inc.id %>">
                                        <button type="submit" class="bg-white text-red-600 hover:bg-slate-200 font-bold text-xs px-4 py-3 rounded-xl transition shadow-lg">✅ Marquer comme Résolu</button>
                                    </form>
                                </div>
                            <% } %>
                        <% }); %>
                    <% }); %>
                </div>
            </section>
            <% } %>

            <section id="biens" class="mb-10 pt-10 border-t border-slate-800">
                <h3 class="text-xl font-bold mb-6 flex items-center gap-2">🏠 Mes Biens</h3>
                
                <% if (properties.length === 0) { %>
                    <div class="text-center py-10 border border-dashed border-slate-800 rounded-2xl">
                        <p class="text-slate-500 mb-4">Vous n'avez pas encore ajouté de bien.</p>
                        <a href="/add-property" class="text-[#F59E0B] font-bold hover:underline">Ajouter mon premier bien</a>
                    </div>
                <% } %>

                <div class="space-y-4">
                    <% properties.forEach(function(prop) { %>
                        <% const activeLease = prop.leases.find(l => l.isActive === true); %>
                        <div class="bg-slate-900/50 border border-slate-800 p-5 rounded-2xl block hover:border-slate-700 transition">
                            <div class="flex justify-between items-center mb-4">
                                <div class="flex items-center gap-4">
                                    <div class="w-3 h-3 <%= activeLease ? 'bg-green-500' : 'bg-slate-600' %> rounded-full"></div>
                                    <div>
                                        <p class="font-bold text-white text-sm"><%= prop.title %></p>
                                        <p class="text-xs text-slate-500">
                                            <%= prop.commune %> • 
                                            <% if (activeLease) { %>
                                                <span class="text-green-400">Loué à <%= activeLease.tenant.name %></span>
                                            <% } else { %>
                                                <span class="text-slate-500">Vacant</span>
                                            <% } %>
                                        </p>
                                    </div>
                                </div>
                                <span class="text-xs font-bold text-green-400">+ <%= prop.price.toLocaleString('fr-FR') %> FCFA</span>
                            </div>

                            <% if (activeLease) { %>
                                <div class="mt-4 pt-4 border-t border-slate-800">
                                    <div class="flex justify-between items-center w-full mb-3 pb-3 border-b border-slate-800">
                                        <div class="text-xs text-slate-500">📅 Entrée : <%= new Date(activeLease.startDate).toLocaleDateString('fr-FR') %></div>
                                        <div class="flex gap-2">
                                            <a href="/contract/<%= activeLease.id %>" target="_blank" class="flex items-center gap-1 text-[#F59E0B] text-xs font-bold hover:text-white transition">📜 Contrat</a>
                                            <a href="/inventory/<%= activeLease.id %>?type=ENTREE" target="_blank" class="text-slate-400 text-xs hover:text-white transition">📥 EDL Entrée</a>
                                        </div>
                                    </div>

                                    <div class="grid grid-cols-2 gap-2 mb-4">
                                        <a href="/formal-notice/<%= activeLease.id %>" target="_blank" class="text-center bg-red-600 hover:bg-red-700 text-white text-[10px] font-bold uppercase py-2 rounded transition border border-red-500 flex items-center justify-center gap-1">
                                            <span>⚖️</span> Huissier
                                        </a>
                                        <button onclick="openExitModal('<%= activeLease.id %>', '<%= activeLease.tenant.name %>', '<%= activeLease.depositAmount %>')" class="bg-slate-800 hover:bg-slate-700 text-slate-300 text-[10px] font-bold uppercase py-2 rounded transition border border-slate-600">
                                            🚪 Sortie
                                        </button>
                                    </div>

                                    <div class="flex items-center justify-between">
                                        <% 
                                            const currentMonthStr = new Date().toLocaleString('fr-FR', { month: 'long', year: 'numeric' });
                                            const lastPayment = (activeLease.payments && activeLease.payments.length > 0) ? activeLease.payments[activeLease.payments.length - 1] : null;
                                            const isPaidThisMonth = lastPayment && lastPayment.month.toLowerCase() === currentMonthStr.toLowerCase();
                                        %>
                                        
                                        <% if (isPaidThisMonth) { %>
                                            <div class="flex items-center gap-2">
                                                <span class="text-green-400 text-xs font-bold bg-green-500/10 px-2 py-1 rounded">✅ Loyer à jour</span>
                                                <a href="/receipt/<%= lastPayment.id %>" target="_blank" class="text-slate-400 text-xs hover:text-white underline">Quittance</a>
                                            </div>
                                        <% } else { %>
                                            <div class="flex flex-col gap-2 w-full">
                                                <form action="/pay-rent" method="POST" class="w-full">
                                                    <input type="hidden" name="leaseId" value="<%= activeLease.id %>">
                                                    <input type="hidden" name="amount" value="<%= activeLease.monthlyRent %>">
                                                    <input type="hidden" name="month" value="<%= currentMonthStr %>">
                                                    <button type="submit" class="bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold px-3 py-2 rounded-lg transition w-full">
                                                        💰 Encaisser <%= new Date().toLocaleString('fr-FR', { month: 'long' }) %>
                                                    </button>
                                                </form>
                                                <a href="https://wa.me/<%= activeLease.tenant.phone.replace(/\s+/g, '') %>?text=Bonjour <%= activeLease.tenant.name %>, le loyer de <%= new Date().toLocaleString('fr-FR', { month: 'long' }) %> est attendu." target="_blank" class="w-full block text-center bg-[#25D366] hover:bg-[#128C7E] text-white text-xs font-bold py-2 rounded-lg transition flex items-center justify-center gap-2">
                                                    Relance WhatsApp
                                                </a>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
            </section>

            <section id="locataires" class="mb-10 pt-10 border-t border-slate-800">
                <h3 class="text-xl font-bold mb-6 flex items-center gap-2">👤 Annuaire des Locataires</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <% let hasTenants = false; %>
                    <% properties.forEach(function(prop) { %>
                        <% prop.leases.forEach(function(lease) { %>
                            <% if (lease.isActive) { hasTenants = true; %>
                                <div class="bg-slate-900 border border-slate-800 p-5 rounded-2xl flex items-center gap-4">
                                    <div class="w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center text-xl font-bold"><%= lease.tenant.name.charAt(0) %></div>
                                    <div>
                                        <p class="font-bold text-white"><%= lease.tenant.name %></p>
                                        <p class="text-xs text-slate-400"><%= lease.tenant.phone %></p>
                                        <p class="text-xs text-[#F59E0B] mt-1"><%= prop.title %></p>
                                    </div>
                                    <a href="https://wa.me/<%= lease.tenant.phone.replace(/\s+/g, '') %>" target="_blank" class="ml-auto bg-[#25D366] p-2 rounded-full hover:bg-[#128C7E] transition">
                                        <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.017-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
                                    </a>
                                </div>
                            <% } %>
                        <% }); %>
                    <% }); %>
                    <% if (!hasTenants) { %> <div class="col-span-2 text-center text-slate-500 py-4">Aucun locataire actif.</div> <% } %>
                </div>
            </section>

            <div class="fixed bottom-8 right-8 flex flex-col md:flex-row gap-4 items-end z-50">
                <button onclick="document.getElementById('expenseModal').classList.remove('hidden')" class="bg-red-500/10 text-red-500 border border-red-500/50 px-4 py-4 rounded-2xl font-bold hover:bg-red-500 hover:text-white transition flex items-center gap-2 backdrop-blur-md">💸 Dépense</button>
                <div class="flex gap-4">
                    <button onclick="document.getElementById('artisanModal').classList.remove('hidden')" class="bg-blue-600 text-white px-6 py-4 rounded-2xl font-bold shadow-xl hover:scale-105 transition flex items-center gap-2">🔨 Ajouter Artisan</button>
                    <a href="/add-tenant" class="bg-white text-[#0B1120] px-6 py-4 rounded-2xl font-bold shadow-xl hover:scale-105 transition flex items-center gap-2">👤 Nouveau Locataire</a>
                    <a href="/add-property" class="bg-[#F59E0B] text-[#0B1120] px-6 py-4 rounded-2xl font-bold shadow-xl hover:scale-105 transition flex items-center gap-2"><span class="text-xl">+</span> Ajouter un Bien</a>
                </div>
            </div>

            <div id="rechargeModal" class="hidden fixed inset-0 bg-black/90 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
                <div class="bg-slate-900 border border-slate-700 p-8 rounded-3xl w-full max-w-sm relative">
                    <button onclick="document.getElementById('rechargeModal').classList.add('hidden')" class="absolute top-4 right-4 text-slate-500 hover:text-white">✕</button>
                    <div class="text-center mb-6">
                        <h2 class="text-xl font-bold text-white mb-2">Recharger mon compte</h2>
                        <p class="text-slate-400 text-sm">Paiement sécurisé par CinetPay</p>
                        <div class="flex justify-center gap-2 mt-4 opacity-70">
                            <span class="bg-white px-2 rounded h-6 flex items-center"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/c8/Orange_logo.svg/1200px-Orange_logo.svg.png" class="h-4"></span>
                            <span class="bg-blue-500 px-2 rounded h-6 flex items-center text-[10px] font-bold text-white">Wave</span>
                            <span class="bg-yellow-400 px-2 rounded h-6 flex items-center text-[10px] font-bold text-black">MTN</span>
                        </div>
                    </div>
                    <form action="/api/payment/init" method="POST" class="space-y-4">
                        <div>
                            <label class="text-xs font-bold text-slate-400 uppercase">Montant à créditer</label>
                            <select name="amount" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white font-bold mt-2 focus:border-[#F59E0B] outline-none">
                                <option value="5000">5 000 FCFA</option>
                                <option value="10000" selected>10 000 FCFA</option>
                                <option value="20000">20 000 FCFA</option>
                                <option value="50000">50 000 FCFA</option>
                            </select>
                        </div>
                        <button type="submit" class="w-full bg-[#F59E0B] hover:bg-orange-600 text-[#0B1120] font-black py-4 rounded-xl transition mt-2">Payer maintenant</button>
                    </form>
                </div>
            </div>

            <div id="exitModal" class="hidden fixed inset-0 bg-black/90 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
                <div class="bg-slate-900 border border-slate-700 p-8 rounded-3xl w-full max-w-md relative">
                    <button onclick="document.getElementById('exitModal').classList.add('hidden')" class="absolute top-4 right-4 text-slate-500 hover:text-white">✕</button>
                    <h2 class="text-xl font-bold text-white mb-1">Départ Locataire</h2>
                    <p class="text-sm text-slate-500 mb-6" id="exitTenantName"></p>
                    <form action="/end-lease" method="POST" class="space-y-4">
                        <input type="hidden" name="leaseId" id="exitLeaseId">
                        <div class="bg-slate-800 p-4 rounded-xl border border-slate-700">
                            <p class="text-xs text-slate-400 uppercase">Caution versée au départ</p>
                            <p class="text-xl font-bold text-[#F59E0B]" id="exitDepositDisplay">0 FCFA</p>
                        </div>
                        <div>
                            <label class="text-xs font-bold text-slate-400 uppercase">Retenue pour travaux/impayés</label>
                            <input type="number" name="deduction" value="0" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white mt-1">
                        </div>
                        <button type="submit" class="w-full bg-red-600 hover:bg-red-500 text-white font-bold py-3 rounded-xl mt-2">Confirmer le départ</button>
                    </form>
                </div>
            </div>

            <div id="expenseModal" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
                <div class="bg-slate-900 border border-slate-700 p-8 rounded-3xl w-full max-w-md relative">
                    <button onclick="document.getElementById('expenseModal').classList.add('hidden')" class="absolute top-4 right-4 text-slate-500 hover:text-white">✕</button>
                    <h2 class="text-xl font-bold mb-6 text-white">Déclarer une dépense</h2>
                    <form action="/add-expense" method="POST" class="space-y-4">
                        <select name="propertyId" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white">
                            <% properties.forEach(function(prop) { %> <option value="<%= prop.id %>"><%= prop.title %></option> <% }); %>
                        </select>
                        <select name="category" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white">
                            <option value="REPARATION">Réparation / Travaux</option>
                            <option value="TAXE">Impôts & Taxes</option>
                            <option value="SYNDIC">Charges de copropriété</option>
                        </select>
                        <input type="text" name="description" placeholder="Ex: Plombier" required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white">
                        <input type="number" name="amount" placeholder="Montant (FCFA)" required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white">
                        <button type="submit" class="w-full bg-red-500 hover:bg-red-600 text-white font-bold py-3 rounded-xl mt-4">Enregistrer</button>
                    </form>
                </div>
            </div>

            <div id="artisanModal" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
                <div class="bg-slate-900 border border-slate-700 p-8 rounded-3xl w-full max-w-md relative">
                    <button onclick="document.getElementById('artisanModal').classList.add('hidden')" class="absolute top-4 right-4 text-slate-500 hover:text-white">✕</button>
                    <h2 class="text-xl font-bold mb-6 text-white">Ajouter un Partenaire</h2>
                    <form action="/add-artisan" method="POST" class="space-y-4">
                        <input type="text" name="name" placeholder="Nom" required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white">
                        <select name="job" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white">
                            <option value="Plombier">Plombier</option>
                            <option value="Electricien">Électricien</option>
                            <option value="Climaticien">Climatisation</option>
                        </select>
                        <input type="tel" name="phone" placeholder="225 07..." required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-3 text-white">
                        <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl mt-4">Enregistrer</button>
                    </form>
                </div>
            </div>
        </main>
    </div>
    <div class="mt-12 mb-8">
    <div class="flex items-center gap-3 mb-6">
        <div class="p-3 bg-blue-500/10 rounded-xl text-blue-500">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path></svg>
        </div>
        <div>
            <h2 class="text-xl font-black text-[#0B1120]">Annuaire Artisans Agréés</h2>
            <p class="text-slate-500 text-sm">Trouvez un professionnel de confiance pour vos travaux.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% if (locals.artisans && artisans.length > 0) { %>
            <% artisans.forEach(artisan => { %>
                <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition group">
                    <div class="flex justify-between items-start mb-4">
                        <div class="h-10 w-10 rounded-full bg-slate-100 flex items-center justify-center text-xl">👷🏾‍♂️</div>
                        <% if (artisan.isVerified) { %>
                            <span class="bg-green-100 text-green-700 text-[10px] font-bold px-2 py-1 rounded-full uppercase tracking-wider">Vérifié</span>
                        <% } %>
                    </div>
                    
                    <h3 class="font-bold text-[#0B1120]"><%= artisan.name %></h3>
                    <p class="text-[#F59E0B] font-medium text-sm mb-1"><%= artisan.job %></p>
                    <p class="text-slate-400 text-xs mb-4">📍 <%= artisan.location %></p>
                    
                    <a href="tel:<%= artisan.phone %>" class="flex items-center justify-center gap-2 w-full bg-slate-900 text-white py-2 rounded-lg text-sm font-bold hover:bg-[#F59E0B] hover:text-[#0B1120] transition">
                        <span>📞</span> Appeler
                    </a>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-full text-center py-10 bg-slate-50 rounded-2xl border border-dashed border-slate-300">
                <p class="text-slate-400">Aucun artisan n'est référencé pour le moment.</p>
            </div>
        <% } %>
    </div>
</div>

    <script>
        function openExitModal(leaseId, tenantName, deposit) {
            document.getElementById('exitModal').classList.remove('hidden');
            document.getElementById('exitLeaseId').value = leaseId;
            document.getElementById('exitTenantName').innerText = "Départ de : " + tenantName;
            document.getElementById('exitDepositDisplay').innerText = parseInt(deposit).toLocaleString('fr-FR') + " FCFA";
        }
    </script>
</body>
</html>
