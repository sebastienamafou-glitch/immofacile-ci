<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Affiche - <%= property.title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: white; }
        @media print {
            @page { margin: 0; size: A4 portrait; }
            .no-print { display: none !important; }
            body { -webkit-print-color-adjust: exact; }
        }
    </style>
</head>
<body class="flex flex-col h-screen justify-between p-8 border-8 border-[#0B1120]">

    <div class="text-center mt-4">
        <div class="inline-block bg-[#F59E0B] text-[#0B1120] px-6 py-2 rounded-full font-bold text-xl uppercase tracking-widest mb-4">
            Disponible Tout de Suite
        </div>
        <h1 class="text-8xl font-black text-[#0B1120] uppercase leading-none">
            À LOUER
        </h1>
    </div>

    <div class="flexflex-col items-center justify-center text-center my-8">
        <div class="relative inline-block p-4 border-4 border-dashed border-slate-300 rounded-3xl">
            <img src="<%= qrCodeUrl %>" alt="Scan me" class="w-64 h-64 md:w-80 md:h-80 mx-auto">
            <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 bg-[#0B1120] text-white px-6 py-2 rounded-xl font-bold whitespace-nowrap shadow-lg">
                📸 Scannez pour voir les photos
            </div>
        </div>
    </div>

    <div class="text-center space-y-4">
        <h2 class="text-4xl font-bold text-slate-800"><%= property.title %></h2>
        <div class="flex justify-center gap-6 text-2xl text-slate-600 font-medium">
            <span>📍 <%= property.commune %></span>
            <span>•</span>
            <span>🏠 <%= property.type || 'Logement' %></span>
        </div>
        
        <div class="mt-8">
            <span class="text-6xl font-black text-[#0B1120]"><%= property.price.toLocaleString('fr-FR') %></span>
            <span class="text-2xl text-slate-500 font-bold">FCFA / Mois</span>
        </div>
    </div>

    <div class="text-center mt-12 pt-8 border-t-2 border-slate-100">
        <p class="text-slate-400 font-bold text-sm uppercase tracking-widest mb-2">Géré en toute confiance avec</p>
        <div class="flex items-center justify-center gap-2">
            <span class="text-2xl font-black tracking-tighter">ImmoFacile<span class="text-[#F59E0B]">.ci</span></span>
        </div>
    </div>

    <div class="fixed top-4 right-4 no-print">
        <button onclick="window.print()" class="bg-blue-600 text-white font-bold py-3 px-6 rounded-xl shadow-xl hover:bg-blue-700 transition flex items-center gap-2">
            🖨️ Imprimer cette affiche
        </button>
        <br><br>
        <button onclick="history.back()" class="text-slate-400 underline text-sm bg-white/80 p-2 rounded">Retour</button>
    </div>

</body>
</html>
