<div id="globalLoader" class="hidden fixed inset-0 z-[9999] flex flex-col items-center justify-center bg-[#0B1120]/90 backdrop-blur-sm">
    
    <div class="relative flex justify-center items-center">
        <div class="absolute animate-ping inline-flex h-16 w-16 rounded-full bg-[#F59E0B] opacity-20"></div>
        <div class="w-16 h-16 border-4 border-slate-700 border-t-[#F59E0B] rounded-full animate-spin"></div>
    </div>
    
    <p class="text-white font-bold mt-4 animate-pulse text-sm tracking-widest uppercase">Chargement...</p>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const loader = document.getElementById('globalLoader');

        // Force l'affichage immédiat
        window.showLoader = function() {
            if (loader) loader.classList.remove('hidden');
        };

        // Cache immédiat
        window.hideLoader = function() {
            if (loader) loader.classList.add('hidden');
        };

        // 1. Intercepte tous les clics sur les liens
        document.body.addEventListener('click', function(e) {
            // Trouve le lien parent le plus proche (au cas où on clique sur une icône dans le lien)
            const link = e.target.closest('a');
            
            if (link) {
                const href = link.getAttribute('href');
                const target = link.getAttribute('target');
                
                // Si c'est un vrai lien interne, on affiche le loader
                if (href && 
                    !href.startsWith('#') && 
                    !href.startsWith('javascript') && 
                    target !== '_blank' &&
                    !e.ctrlKey && !e.metaKey) { // Ignore Ctrl+Click (nouvel onglet)
                    
                    showLoader();
                }
            }
        });

        // 2. Intercepte les formulaires
        document.querySelectorAll('form').forEach(form => {
            form.addEventListener('submit', function() {
                if (this.checkValidity()) {
                    showLoader();
                }
            });
        });

        // 3. Gestion du bouton "Précédent" du navigateur
        window.addEventListener('pageshow', function(event) {
            hideLoader(); // Force le masquage si on revient en arrière
        });
        
        // Sécurité au chargement initial
        hideLoader();
    });
</script>
