<aside id="sidebar" class="fixed inset-y-0 left-0 w-64 border-r border-slate-800 p-6 bg-[#0B1120] overflow-y-auto z-50 md:z-30 md:translate-x-0 transition-transform duration-300 flex flex-col">
    
    <div class="mb-8 px-2">
        <a href="/admin/dashboard" class="flex items-center gap-3">
            <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-900/20">
                <i class="ph-fill ph-buildings text-white text-2xl"></i>
            </div>
            <span class="text-white font-black text-xl tracking-tighter uppercase">ImmoFacile<span class="text-blue-500">.V4</span></span>
        </a>
    </div>

    <nav class="space-y-1 flex-1">
        <% let dashboardUrl = user.role === 'ADMIN' ? '/admin/dashboard' : (user.role === 'INVESTOR' ? '/investor/dashboard' : '/owner/dashboard'); %>
        <a href="<%= dashboardUrl %>" class="flex items-center gap-3 p-3 bg-blue-600/10 text-blue-400 rounded-xl font-bold border border-blue-600/20 mb-6 transition hover:bg-blue-600/20">
            <i class="ph-fill ph-squares-four text-xl"></i>
            <span>Tableau de bord</span>
        </a>

        <p class="px-3 text-[10px] font-bold text-slate-500 uppercase tracking-[2px] mb-2 mt-4">Gestion Administrative</p>
        
        <a href="#tresorerie" class="flex items-center gap-3 p-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl transition group">
            <i class="ph-duotone ph-wallet text-xl text-[#F59E0B] group-hover:scale-110 transition"></i>
            <span>Guichet Trésorerie</span>
        </a>

        <a href="#agents" class="flex items-center gap-3 p-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl transition group">
            <i class="ph-duotone ph-users-three text-xl text-blue-400 group-hover:scale-110 transition"></i>
            <span>Agents & Sales</span>
        </a>

        <a href="#alertes" class="flex items-center gap-3 p-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl transition group">
            <i class="ph-duotone ph-warning-octagon text-xl text-red-500 group-hover:scale-110 transition"></i>
            <span>Alertes Système</span>
        </a>

        <a href="#artisans" class="flex items-center gap-3 p-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl transition group">
            <i class="ph-duotone ph-toolbox text-xl text-orange-400 group-hover:scale-110 transition"></i>
            <span>Annuaire Artisans</span>
        </a>

        <p class="px-3 text-[10px] font-bold text-slate-500 uppercase tracking-[2px] mb-2 mt-6">Outils & Audit</p>
        
        <button onclick="checkSystemHealth()" class="w-full flex items-center gap-3 p-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl transition group">
            <i class="ph-bold ph-activity text-xl text-emerald-400 group-hover:animate-pulse"></i>
            <span>Santé Système</span>
        </button>

        <a href="/admin/logs" class="flex items-center gap-3 p-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl transition group">
            <i class="ph-bold ph-scroll text-xl text-purple-400 group-hover:scale-110 transition"></i>
            <span>Logs & Exports</span>
        </a>
    </nav>

    <div class="mt-auto pt-6 border-t border-slate-800">
        <div class="bg-slate-900/50 border border-blue-500/20 p-4 rounded-2xl">
            <div class="flex items-center gap-3 mb-2">
                <i class="ph-fill ph-shield-check text-blue-500 text-xl"></i>
                <span class="text-[10px] font-black text-white tracking-widest uppercase">Sécurité V4</span>
            </div>
            <p class="text-[9px] text-slate-500 leading-relaxed italic">
                Scellement <b>SHA-256</b> actif.<br>Conformité Loi 2024-1115[cite: 427, 428, 436].
            </p>
        </div>
        
        <a href="/logout" class="flex items-center gap-3 p-3 mt-4 text-red-400 hover:bg-red-400/10 rounded-xl transition font-bold">
            <i class="ph-bold ph-sign-out text-xl"></i>
            <span>Déconnexion</span>
        </a>
    </div>
</aside>

<script>
/**
 * Diagnostic Santé Système via Dispatcher
 */
async function checkSystemHealth() {
    Swal.fire({
        title: 'Analyse V4 en cours...',
        text: 'Interrogation du Dispatcher Système (Region: iad1)',
        allowOutsideClick: false,
        background: '#0B1120',
        color: '#fff',
        didOpen: () => { Swal.showLoading(); }
    });

    try {
        const res = await fetch('/api/system/status');
        const data = await res.json();
        
        if (data.success) {
            Swal.fire({
                title: 'Système Opérationnel ✅',
                html: `
                    <div class="text-left text-sm space-y-2 py-2">
                        <p>👥 Utilisateurs : <b>${data.stats.users}</b></p>
                        <p>🏠 Biens : <b>${data.stats.properties}</b></p>
                        <p>⏳ Baux en attente : <b>${data.stats.unpaidBails}</b></p>
                        <hr class="border-slate-700">
                        <p class="text-[10px] text-slate-500 uppercase tracking-widest">Région : Vercel Production (iad1)</p>
                    </div>
                `,
                icon: 'success',
                background: '#0B1120',
                color: '#fff',
                confirmButtonColor: '#2563eb'
            });
        }
    } catch (e) {
        Swal.fire({
            title: 'Erreur Connexion',
            text: 'Impossible de joindre le Dispatcher Système.',
            icon: 'error',
            background: '#0B1120',
            color: '#fff'
        });
    }
}
</script>
