<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Espace Investisseur | ImmoFacile CI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body class="bg-[#0B1120] text-white font-['Plus_Jakarta_Sans']">

    <div class="max-w-6xl mx-auto p-6">
        
        <header class="flex justify-between items-center mb-10 bg-slate-900 p-6 rounded-2xl border border-slate-800">
            <div class="flex items-center gap-4">
                <img src="/images/immo_logo.png" alt="Logo" class="h-10">
                <div>
                    <h1 class="text-xl font-bold">Bonjour, Investisseur <%= user.name %> 🚀</h1>
                    <p class="text-slate-500 text-sm">Votre portefeuille immobilier en temps réel</p>
                </div>
            </div>
            <div class="flex gap-3">
                <a href="/investor/opportunities" class="bg-[#F59E0B] text-[#0B1120] px-6 py-2 rounded-xl font-bold hover:scale-105 transition">
                    + Investir
                </a>
                <a href="/logout" class="bg-slate-800 text-white px-4 py-2 rounded-xl hover:bg-red-500 transition">Déconnexion</a>
            </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="bg-gradient-to-br from-blue-900 to-slate-900 border border-blue-500/30 p-6 rounded-3xl">
                <p class="text-blue-300 text-xs font-bold uppercase tracking-widest mb-2">Capital Actif</p>
                <p class="text-3xl font-black text-white"><%= totalInvested.toLocaleString('fr-FR') %> <span class="text-sm text-slate-400 font-normal">FCFA</span></p>
            </div>

            <div class="bg-gradient-to-br from-green-900 to-slate-900 border border-green-500/30 p-6 rounded-3xl">
                <p class="text-green-300 text-xs font-bold uppercase tracking-widest mb-2">Gains Annuels (Est.)</p>
                <p class="text-3xl font-black text-green-400">+<%= projectedProfit.toLocaleString('fr-FR') %> <span class="text-sm text-slate-400 font-normal">FCFA</span></p>
                <p class="text-xs text-slate-500 mt-1">ROI Moyen : 12%</p>
            </div>

            <div class="bg-slate-900 border border-slate-800 p-6 rounded-3xl">
                <p class="text-slate-400 text-xs font-bold uppercase tracking-widest mb-2">Portefeuille Dispo</p>
                <p class="text-3xl font-black text-white"><%= (user.walletBalance || 0).toLocaleString('fr-FR') %> <span class="text-sm text-slate-400 font-normal">FCFA</span></p>
                <div class="mt-4 flex gap-2">
                    <button class="flex-1 bg-slate-800 py-2 rounded-lg text-xs font-bold hover:bg-slate-700">Dépôt</button>
                    <button class="flex-1 bg-slate-800 py-2 rounded-lg text-xs font-bold hover:bg-slate-700">Retrait</button>
                </div>
            </div>
        </div>

        <h3 class="text-xl font-bold mb-6 flex items-center gap-2">📂 Mes Placements</h3>
        
        <% if (investments.length > 0) { %>
            <div class="grid gap-4">
                <% investments.forEach(inv => { %>
                    <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl flex flex-col md:flex-row justify-between items-center hover:border-slate-700 transition">
                        <div class="flex items-center gap-4 mb-4 md:mb-0">
                            <div class="w-12 h-12 bg-[#F59E0B]/20 text-[#F59E0B] rounded-full flex items-center justify-center text-2xl">🏢</div>
                            <div>
                                <p class="font-bold text-white text-lg"><%= inv.projectName %></p>
                                <p class="text-slate-500 text-sm">Investi le <%= new Date(inv.startDate).toLocaleDateString('fr-FR') %></p>
                            </div>
                        </div>
                        
                        <div class="flex gap-8 text-center">
                            <div>
                                <p class="text-[10px] text-slate-500 uppercase">Montant</p>
                                <p class="font-bold text-white"><%= inv.amount.toLocaleString('fr-FR') %> FCFA</p>
                            </div>
                            <div>
                                <p class="text-[10px] text-slate-500 uppercase">Taux</p>
                                <p class="font-bold text-green-400"><%= inv.roiRate %>%</p>
                            </div>
                            <div>
                                <p class="text-[10px] text-slate-500 uppercase">Statut</p>
                                <span class="bg-green-500/20 text-green-400 px-3 py-1 rounded-full text-xs font-bold"><%= inv.status %></span>
                            </div>
                        </div>
                        
                        <div class="ml-4">
                            <button class="text-slate-400 hover:text-white transition">📄 Contrat</button>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-20 bg-slate-900/50 border border-dashed border-slate-800 rounded-3xl">
                <p class="text-4xl mb-4">🌱</p>
                <p class="text-slate-400 mb-6">Vous n'avez pas encore d'investissement actif.</p>
                <a href="/investor/opportunities" class="bg-blue-600 text-white px-6 py-3 rounded-xl font-bold hover:bg-blue-500 transition">Voir les opportunités</a>
            </div>
        <% } %>

    </div>

</body>
</html>
