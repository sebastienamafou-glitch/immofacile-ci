<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Espace Investisseur | ImmoFacile</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Plus Jakarta Sans', sans-serif; }</style>
</head>
<body class="bg-slate-50 text-slate-900">

    <div class="max-w-6xl mx-auto p-6">
        
        <header class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-black text-[#0B1120]">Mon Portefeuille</h1>
                <p class="text-slate-500">Bienvenue, <%= user.name %></p>
            </div>
            <a href="/investor/opportunities" class="bg-[#0B1120] text-white px-6 py-3 rounded-xl font-bold hover:scale-105 transition flex items-center gap-2">
                <i class="ph-bold ph-plus-circle"></i> Nouvelle Opportunité
            </a>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                <div class="flex items-center gap-3 mb-2">
                    <div class="p-2 bg-blue-50 text-blue-600 rounded-lg"><i class="ph-fill ph-wallet text-xl"></i></div>
                    <span class="text-sm font-bold text-slate-400 uppercase">Total Investi</span>
                </div>
                <p class="text-3xl font-black text-[#0B1120]"><%= stats.totalInvested.toLocaleString('fr-FR') %> F</p>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                <div class="flex items-center gap-3 mb-2">
                    <div class="p-2 bg-purple-50 text-purple-600 rounded-lg"><i class="ph-fill ph-chart-line-up text-xl"></i></div>
                    <span class="text-sm font-bold text-slate-400 uppercase">ROI Moyen</span>
                </div>
                <p class="text-3xl font-black text-purple-600"><%= stats.averageRoi %> %</p>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                <div class="flex items-center gap-3 mb-2">
                    <div class="p-2 bg-green-50 text-green-600 rounded-lg"><i class="ph-fill ph-money text-xl"></i></div>
                    <span class="text-sm font-bold text-slate-400 uppercase">Gains Projetés</span>
                </div>
                <p class="text-3xl font-black text-green-600">+<%= stats.projectedEarnings.toLocaleString('fr-FR') %> F</p>
            </div>
        </div>

        <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
            <i class="ph-bold ph-list-dashes"></i> Mes Projets Actifs
        </h2>

        <% if (investments.length === 0) { %>
            <div class="bg-white p-12 rounded-3xl border border-dashed border-slate-300 text-center">
                <i class="ph-duotone ph-safe text-4xl text-slate-300 mb-4"></i>
                <p class="text-slate-500 font-medium">Vous n'avez pas encore d'investissement actif.</p>
                <a href="/investor/opportunities" class="text-blue-600 font-bold hover:underline mt-2 inline-block">Voir les opportunités</a>
            </div>
        <% } else { %>
            <div class="space-y-4">
                <% investments.forEach(inv => { %>
                    <div class="bg-white p-6 rounded-2xl border border-slate-100 flex flex-col md:flex-row justify-between items-center gap-4 hover:border-blue-200 transition">
                        <div class="flex items-center gap-4 w-full md:w-auto">
                            <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center font-bold text-slate-600">
                                <%= inv.projectName.charAt(0) %>
                            </div>
                            <div>
                                <h3 class="font-bold text-[#0B1120]"><%= inv.projectName %></h3>
                                <p class="text-xs text-slate-500">Début : <%= new Date(inv.startDate).toLocaleDateString('fr-FR') %></p>
                            </div>
                        </div>

                        <div class="flex gap-8 text-center w-full md:w-auto justify-between md:justify-end">
                            <div>
                                <p class="text-xs text-slate-400 font-bold uppercase">Montant</p>
                                <p class="font-bold"><%= inv.amount.toLocaleString('fr-FR') %> F</p>
                            </div>
                            <div>
                                <p class="text-xs text-slate-400 font-bold uppercase">Taux</p>
                                <p class="font-bold text-purple-600"><%= inv.roiRate %> %</p>
                            </div>
                            <div>
                                <p class="text-xs text-slate-400 font-bold uppercase">Statut</p>
                                <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold"><%= inv.status %></span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

    </div>

</body>
</html>
