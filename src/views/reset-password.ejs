<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Nouveau mot de passe | ImmoFacile CI</title>
    
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0B1120">
    <link rel="apple-touch-icon" href="/icon.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body class="bg-[#0B1120] text-white font-['Plus_Jakarta_Sans'] flex items-center justify-center min-h-screen p-4">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-2xl font-extrabold">Sécurisation</h1>
            <p class="text-slate-400 mt-2 text-sm">Choisissez un nouveau code secret.</p>
        </div>

        <div class="bg-slate-900 border border-slate-800 p-8 rounded-[2rem] shadow-2xl">
            <% if (locals.error) { %>
                <div class="bg-red-500/10 border border-red-500/20 text-red-400 text-sm p-4 rounded-xl mb-6 text-center"><%= error %></div>
            <% } %>

            <form action="/reset-password/<%= token %>" method="POST" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase mb-2">Nouveau mot de passe</label>
                    <input type="password" name="password" required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:outline-none focus:border-[#F59E0B]">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase mb-2">Confirmer</label>
                    <input type="password" name="confirmPassword" required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:outline-none focus:border-[#F59E0B]">
                </div>
                <button type="submit" class="w-full bg-[#F59E0B] hover:bg-orange-600 text-[#0B1120] font-black py-4 rounded-xl uppercase tracking-wider transition mt-4">
                    Modifier
                </button>
            </form>
        </div>
    </div>
</body>
</html>
