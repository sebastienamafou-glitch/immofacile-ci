<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ajouter un Bien | ImmoFacile CI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body class="bg-[#0B1120] text-white font-['Plus_Jakarta_Sans'] flex items-center justify-center min-h-screen p-4">

    <div class="w-full max-w-4xl">
        <a href="/owner/dashboard" class="flex items-center gap-2 text-slate-400 hover:text-white mb-6 transition">
            <span>←</span> Retour au Dashboard
        </a>

        <div class="bg-slate-900 border border-slate-800 p-8 rounded-3xl shadow-2xl relative overflow-hidden">
            
            <div class="mb-8">
                <h1 class="text-3xl font-black text-white mb-2">Ajouter un nouveau bien</h1>
                <p class="text-slate-500">Remplissez les informations ci-dessous pour publier votre annonce.</p>
            </div>

            <form action="/owner/add-property" method="POST" enctype="multipart/form-data" class="space-y-6">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Titre de l'annonce</label>
                        <input type="text" name="title" placeholder="Ex: Villa Duplex Cocody" required 
                               class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none transition">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Loyer Mensuel (FCFA)</label>
                        <input type="number" name="price" placeholder="500000" required 
                               class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none transition">
                    </div>
                </div>

                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Commune</label>
                        <select name="commune" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none transition appearance-none">
                            <option value="Cocody">Cocody</option>
                            <option value="Yopougon">Yopougon</option>
                            <option value="Marcory">Marcory</option>
                            <option value="Plateau">Plateau</option>
                            <option value="Bingerville">Bingerville</option>
                            <option value="Abobo">Abobo</option>
                            <option value="Koumassi">Koumassi</option>
                            <option value="Port-Bouët">Port-Bouët</option>
                            <option value="Treichville">Treichville</option>
                            <option value="Adjamé">Adjamé</option>
                        </select>
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Adresse Précise</label>
                        <input type="text" name="address" placeholder="Rue des Jardins..." required 
                               class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none transition">
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-4">
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Chambres</label>
                        <input type="number" name="bedrooms" placeholder="3" 
                               class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none transition">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Douches</label>
                        <input type="number" name="bathrooms" placeholder="2" 
                               class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none transition">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Surface (m²)</label>
                        <input type="number" name="surface" placeholder="120" 
                               class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none transition">
                    </div>
                </div>

                <div>
                    <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Description Complète</label>
                    <textarea name="description" rows="4" placeholder="Décrivez les atouts de votre bien (piscine, sécurité, proximité écoles...)" 
                              class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none transition"></textarea>
                </div>

                <div>
                    <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Photos du bien</label>
                    
                    <div class="relative w-full border-2 border-dashed border-slate-700 hover:border-[#F59E0B] bg-[#0B1120]/50 rounded-2xl transition group min-h-[150px] flex items-center justify-center">
                        
                        <input type="file" name="images" id="imageInput" multiple accept="image/*" 
                               class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-20"
                               onchange="handleImagePreview(this)">
                        
                        <div id="uploadPlaceholder" class="text-center pointer-events-none p-6">
                            <div class="w-12 h-12 bg-slate-800 rounded-full flex items-center justify-center mx-auto mb-3 group-hover:bg-[#F59E0B] transition">
                                <svg class="w-6 h-6 text-slate-400 group-hover:text-[#0B1120]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            </div>
                            <p class="text-sm font-bold text-slate-400 group-hover:text-white">Cliquez pour ajouter des photos (Max 5)</p>
                            <p class="text-xs text-slate-600 mt-1">JPG, PNG - Max 5Mo</p>
                        </div>

                        <div id="previewContainer" class="absolute inset-0 w-full h-full p-4 grid grid-cols-3 gap-2 hidden z-10 bg-[#0B1120]">
                            </div>
                    </div>
                </div>

                <button type="submit" class="w-full bg-[#F59E0B] hover:bg-yellow-400 text-[#0B1120] font-black py-4 rounded-xl shadow-lg hover:shadow-yellow-500/20 transition transform hover:scale-[1.01]">
                    Publier le bien
                </button>
            </form>
        </div>
    </div>

    <script>
        function handleImagePreview(input) {
            const container = document.getElementById('previewContainer');
            const placeholder = document.getElementById('uploadPlaceholder');
            
            // Si des fichiers sont sélectionnés
            if (input.files && input.files.length > 0) {
                // On cache le placeholder
                placeholder.classList.add('hidden');
                // On affiche le conteneur
                container.classList.remove('hidden');
                // On vide le conteneur (au cas où on re-sélectionne)
                container.innerHTML = '';

                // On boucle sur les fichiers (max 5 pour l'affichage)
                Array.from(input.files).slice(0, 5).forEach(file => {
                    const reader = new FileReader();
                    
                    reader.onload = function(e) {
                        // Création de la vignette
                        const div = document.createElement('div');
                        div.className = 'relative rounded-lg overflow-hidden border border-slate-700 aspect-square';
                        
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        img.className = 'w-full h-full object-cover';
                        
                        div.appendChild(img);
                        container.appendChild(div);
                    }
                    
                    reader.readAsDataURL(file);
                });
            } else {
                // Si on annule, on remet comme avant
                placeholder.classList.remove('hidden');
                container.classList.add('hidden');
                container.innerHTML = '';
            }
        }
    </script>

</body>
</html>
