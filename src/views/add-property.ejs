<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ajouter un Bien | [cite_start]ImmoFacile CI [cite: 166]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <style>
        /* Animation pour l'apparition des images */
        @keyframes fadeIn { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }
        .thumb-animate { animation: fadeIn 0.3s ease-out forwards; }
        
        /* Personnalisation de la carte pour le thème sombre */
        .leaflet-container {
            font-family: 'Plus Jakarta Sans', sans-serif;
            border-radius: 0.75rem; /* rounded-xl */
        }
    </style>
</head>
<body class="bg-[#0B1120] text-white font-['Plus_Jakarta_Sans'] flex items-center justify-center min-h-screen p-4">

    <div class="w-full max-w-4xl">
        <a href="/owner/dashboard" class="flex items-center gap-2 text-slate-400 hover:text-white mb-6 transition">
            <span>←</span> Retour au Dashboard
        </a>

        <div class="bg-slate-900 border border-slate-800 p-8 rounded-3xl shadow-2xl relative">
            
            <div class="mb-8">
                <h1 class="text-3xl font-black text-white mb-2">Ajouter un nouveau bien</h1>
                <p class="text-slate-500">Remplissez les informations ci-dessous pour publier votre annonce.</p>
            </div>

            <form action="/owner/add-property?_csrf=<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" method="POST" enctype="multipart/form-data" class="space-y-6" id="propertyForm">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Titre de l'annonce</label>
                        <input type="text" name="title" placeholder="Ex: Villa Duplex Cocody" required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Loyer Mensuel (FCFA)</label>
                        <input type="number" name="price" placeholder="500000" required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none">
                    </div>
                </div>

                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Commune</label>
                        <select name="commune" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none appearance-none">
                            <option value="Cocody">Cocody</option>
                            <option value="Yopougon">Yopougon</option>
                            <option value="Marcory">Marcory</option>
                            <option value="Plateau">Plateau</option>
                            <option value="Bingerville">Bingerville</option>
                            <option value="Bouaké">Bouaké</option>
                            <option value="Yamoussoukro">Yamoussoukro</option>
                            <option value="Bassam">Bassam</option>
                            <option value="assinie">assinie</option>
                            <option value="Jacqueville">Jacqueville</option>
                        </select>
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Adresse Précise</label>
                        <input type="text" name="address" placeholder="Rue des Jardins..." required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none">
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-4">
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Chambres</label>
                        <input type="number" name="bedrooms" placeholder="3" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Douches</label>
                        <input type="number" name="bathrooms" placeholder="2" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Surface (m²)</label>
                        <input type="number" name="surface" placeholder="120" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none">
                    </div>
                </div>

                <div>
                    <div class="flex justify-between items-end mb-2">
                        <label class="text-xs font-bold text-slate-500 uppercase block">Description Complète</label>
                        <button type="button" id="btnMagicAI" class="text-xs bg-purple-600 hover:bg-purple-500 text-white px-3 py-1 rounded-full flex items-center gap-1 transition shadow-lg shadow-purple-500/30">
                            <span>✨</span> Générer avec l'IA
                        </button>
                    </div>
                    
                    <textarea id="descField" name="description" rows="6" placeholder="Décrivez votre bien..." 
                        class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none transition"></textarea>
                    
                    <p class="text-[10px] text-slate-500 mt-1 italic text-right">Astuce : Remplissez le type, la commune et les pièces avant de cliquer sur ✨</p>
                </div>

                <div>
                    <div class="flex justify-between items-end mb-2">
                        <label class="text-xs font-bold text-slate-500 uppercase block">Photos du bien</label>
                        <span id="counter" class="text-xs text-[#F59E0B] font-bold hidden">0 photo(s) sélectionnée(s)</span>
                    </div>
                    
                    <div class="border-2 border-dashed border-slate-700 bg-[#0B1120]/50 rounded-2xl p-4">
                        <div id="previewGrid" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4 empty:hidden">
                        </div>

                        <label class="cursor-pointer group flex flex-col items-center justify-center p-6 border border-slate-700 border-dashed rounded-xl hover:bg-slate-800/50 hover:border-[#F59E0B] transition">
                            <div class="w-12 h-12 bg-slate-800 rounded-full flex items-center justify-center mb-2 group-hover:scale-110 transition">
                                <svg class="w-6 h-6 text-slate-400 group-hover:text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                            </div>
                            <span class="text-sm font-bold text-slate-400 group-hover:text-white">Ajouter des photos</span>
                            <span class="text-xs text-slate-600 mt-1">JPG, PNG - Max 5 Mo</span>
                            
                            <input type="file" id="imageInput" multiple accept="image/*" class="hidden">
                            <input type="file" name="images" id="finalInput" multiple class="hidden">
                        </label>
                    </div>
                </div>

                <div class="space-y-2 mb-6">
                    <label class="text-xs font-bold text-slate-500 uppercase block">Localisation Exacte <span class="text-red-500">*</span></label>
                    <p class="text-xs text-slate-400 mb-2">Déplacez le marqueur bleu sur la carte pour indiquer l'entrée exacte de l'immeuble.</p>
                    
                    <div id="mapSelector" class="h-64 w-full rounded-xl border border-slate-700 z-0"></div>
                    
                    <input type="hidden" name="latitude" id="lat" value="5.359952">
                    <input type="hidden" name="longitude" id="lng" value="-4.008256">
                </div>

                <div class="mb-8 border-t border-slate-800 pt-6">
                    <label class="text-xs font-bold text-slate-500 uppercase mb-3 block flex items-center gap-2">
                        <i class="ph-fill ph-detective text-[#F59E0B] text-lg"></i> Déléguer la gestion (Optionnel)
                    </label>
                    <p class="text-xs text-slate-400 mb-4">Choisissez un Agent Certifié pour gérer les visites et les clés à votre place.</p>
                    
                    <div class="relative">
                        <select name="agentId" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none appearance-none cursor-pointer">
                            <option value="">-- Gérer moi-même (Pas d'agent) --</option>
                            
                            <% if (typeof agents !== 'undefined' && agents.length > 0) { %>
                                <% agents.forEach(agent => { %>
                                    <option value="<%= agent.id %>">
                                        <%= agent.name %> (<%= agent.commune || 'Toutes zones' %>)
                                    </option>
                                <% }) %>
                            <% } else { %>
                                <option value="" disabled>Aucun agent disponible pour le moment</option>
                            <% } %>
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-500">
                            <i class="ph-bold ph-caret-down text-lg"></i>
                        </div>
                    </div>
                </div>
                <button type="submit" class="w-full bg-[#F59E0B] hover:bg-yellow-400 text-[#0B1120] font-black py-4 rounded-xl shadow-lg transition transform hover:scale-[1.01]">
                    Publier le bien
                </button>
            </form>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        const dt = new DataTransfer();
        const inputSource = document.getElementById('imageInput');
        const inputFinal = document.getElementById('finalInput');
        const previewGrid = document.getElementById('previewGrid');
        const counter = document.getElementById('counter');

        inputSource.addEventListener('change', function() {
            for (let i = 0; i < this.files.length; i++) {
                const file = this.files[i];
                let isDuplicate = false;
                for (let j = 0; j < dt.files.length; j++) {
                    if (dt.files[j].name === file.name && dt.files[j].size === file.size) {
                        isDuplicate = true;
                        break;
                    }
                }
                if (!isDuplicate) {
                    dt.items.add(file);
                }
            }
            updateFiles();
            this.value = '';
        });

        function updateFiles() {
            inputFinal.files = dt.files;
            if (dt.files.length > 0) {
                counter.classList.remove('hidden');
                counter.innerText = `${dt.files.length} photo(s) prête(s) à l'envoi`;
            } else {
                counter.classList.add('hidden');
            }

            previewGrid.innerHTML = '';
            for (let i = 0; i < dt.files.length; i++) {
                const file = dt.files[i];
                const reader = new FileReader();

                reader.onload = function(e) {
                    const div = document.createElement('div');
                    div.className = 'relative aspect-square rounded-xl overflow-hidden border border-slate-700 bg-black group thumb-animate';
                    
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'w-full h-full object-cover opacity-80 group-hover:opacity-100 transition';
                    
                    const removeBtn = document.createElement('button');
                    removeBtn.innerHTML = '✕';
                    removeBtn.type = 'button';
                    removeBtn.className = 'absolute top-2 right-2 bg-red-500 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold hover:bg-red-600 shadow-lg transform hover:scale-110 transition';
                    removeBtn.onclick = function() {
                        dt.items.remove(i);
                        updateFiles();
                    };
                    div.appendChild(img);
                    div.appendChild(removeBtn);
                    previewGrid.appendChild(div);
                }
                reader.readAsDataURL(file);
            }
        }
    </script>

    <script>
        document.getElementById('btnMagicAI').addEventListener('click', async function() {
            const btn = this;
            const originalText = btn.innerHTML;
            
            // 1. Récupération des données du formulaire
            const type = document.querySelector('input[name="title"]')?.value || "Bien immobilier";
            const pieces = document.querySelector('input[name="bedrooms"]')?.value || "Non spécifié";
            const commune = document.querySelector('select[name="commune"]')?.value;
            const details = document.querySelector('input[name="address"]')?.value;

            if (!commune) {
                alert("Veuillez sélectionner au moins une commune.");
                return;
            }

            // 2. Animation de chargement
            btn.disabled = true;
            btn.innerHTML = '<span>⏳</span> Rédaction en cours...';
            document.getElementById('descField').classList.add('opacity-50');

            try {
                // 3. Appel API
                const response = await fetch('/api/ai/generate-ad', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'CSRF-Token': document.querySelector('input[name="_csrf"]').value
                    },
                    body: JSON.stringify({ type, pieces, commune, details })
                });

                const data = await response.json();

                if (data.success) {
                    // 4. Effet "Machine à écrire" pour le remplissage
                    const textarea = document.getElementById('descField');
                    textarea.value = "";
                    let i = 0;
                    const speed = 10;
                    function typeWriter() {
                        if (i < data.description.length) {
                            textarea.value += data.description.charAt(i);
                            i++;
                            setTimeout(typeWriter, speed);
                        }
                    }
                    typeWriter();
                } else {
                    alert("Erreur IA : " + data.error);
                }

            } catch (error) {
                console.error(error);
                alert("Impossible de contacter l'assistant IA.");
            } finally {
                // Rétablissement du bouton
                btn.disabled = false;
                btn.innerHTML = originalText;
                document.getElementById('descField').classList.remove('opacity-50');
            }
        });
    </script>

    <script>
        // Initialisation de la carte sur Abidjan (Cocody par défaut)
        const map = L.map('mapSelector').setView([5.359952, -4.008256], 13);
        // Ajout des tuiles OpenStreetMap
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        // Ajout du marqueur déplaçable (Draggable)
        const marker = L.marker([5.359952, -4.008256], {draggable: true}).addTo(map);

        // Quand on bouge le marqueur, on met à jour les champs cachés
        marker.on('dragend', function(event) {
            const position = marker.getLatLng();
            document.getElementById('lat').value = position.lat;
            document.getElementById('lng').value = position.lng;
        });

        // Petite astuce pour corriger l'affichage si le conteneur est redimensionné
        setTimeout(() => { map.invalidateSize(); }, 500);
    </script>

</body>
</html>
