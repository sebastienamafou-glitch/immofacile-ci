<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ajouter un Bien | ImmoFacile CI</title> 
    
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0B1120">
    <link rel="apple-touch-icon" href="/icon.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body class="bg-[#0B1120] text-white font-['Plus_Jakarta_Sans'] min-h-screen p-4 md:p-8">

    <div class="max-w-2xl mx-auto mb-6">
        <a href="/owner/dashboard" class="text-slate-500 hover:text-white text-sm flex items-center gap-2 transition">
            <i class="ph-bold ph-arrow-left"></i> Retour au Dashboard
        </a> 
    </div>

    <div class="max-w-2xl mx-auto bg-slate-900 p-8 rounded-3xl border border-slate-800">
        <h2 class="text-2xl font-bold text-white mb-6">Ajouter un nouveau bien</h2>

        <form action="/owner/add-property?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data" class="space-y-6"></form>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Titre de l'annonce</label>
                    <input type="text" name="title" required placeholder="Ex: Villa Duplex Cocody" 
                           class="w-full bg-slate-800 border border-slate-700 text-white rounded-xl p-3 focus:border-[#F59E0B] outline-none">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Loyer Mensuel (FCFA)</label>
                    <input type="number" name="price" required placeholder="500000" 
                           class="w-full bg-slate-800 border border-slate-700 text-white rounded-xl p-3 focus:border-[#F59E0B] outline-none">
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Commune</label>
                    <select name="commune" class="w-full bg-slate-800 border border-slate-700 text-white rounded-xl p-3">
                        <option value="Cocody">Cocody</option>
                        <option value="Marcory">Marcory</option>
                        <option value="Yopougon">Yopougon</option>
                        <option value="Plateau">Plateau</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Adresse précise</label>
                    <input type="text" name="address" required placeholder="Rue des Jardins..." 
                           class="w-full bg-slate-800 border border-slate-700 text-white rounded-xl p-3">
                </div>
            </div>

            <div class="grid grid-cols-3 gap-4">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Chambres</label>
                    <input type="number" name="bedrooms" placeholder="3" 
                           class="w-full bg-slate-800 border border-slate-700 text-white rounded-xl p-3">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Douches</label>
                    <input type="number" name="bathrooms" placeholder="2" 
                           class="w-full bg-slate-800 border border-slate-700 text-white rounded-xl p-3">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Surface (m²)</label>
                    <input type="number" name="surface" placeholder="120" 
                           class="w-full bg-slate-800 border border-slate-700 text-white rounded-xl p-3">
                </div>
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Description complète</label>
                <textarea name="description" rows="4" placeholder="Décrivez les atouts de votre bien (piscine, sécurité, proximité écoles...)" 
                          class="w-full bg-slate-800 border border-slate-700 text-white rounded-xl p-3 focus:border-[#F59E0B] outline-none"></textarea>
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Photos du bien</label>
                <div class="border-2 border-dashed border-slate-700 rounded-xl p-6 text-center hover:border-[#F59E0B] transition cursor-pointer relative">
                    <input type="file" name="images" multiple accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer">
                    <i class="ph-duotone ph-camera text-3xl text-slate-400 mb-2"></i>
                    <p class="text-sm text-slate-400">Cliquez pour ajouter des photos (Max 5)</p>
                </div>
            </div>

            <button type="submit" class="w-full bg-[#F59E0B] hover:bg-yellow-500 text-black font-bold py-4 rounded-xl transition shadow-lg shadow-orange-500/20">
                Publier le bien
            </button>
        </form>
    </div>

    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js'));
        } [cite: 299]
    </script>
</body>
</html>
