<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ajouter un Bien | ImmoFacile CI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        /* Animation pour l'apparition des images */
        @keyframes fadeIn { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }
        .thumb-animate { animation: fadeIn 0.3s ease-out forwards; }
    </style>
</head>
<body class="bg-[#0B1120] text-white font-['Plus_Jakarta_Sans'] flex items-center justify-center min-h-screen p-4">

    <div class="w-full max-w-4xl">
        <a href="/owner/dashboard" class="flex items-center gap-2 text-slate-400 hover:text-white mb-6 transition">
            <span>←</span> Retour au Dashboard
        </a>

        <div class="bg-slate-900 border border-slate-800 p-8 rounded-3xl shadow-2xl relative">
            
            <div class="mb-8">
                <h1 class="text-3xl font-black text-white mb-2">Ajouter un nouveau bien</h1>
                <p class="text-slate-500">Remplissez les informations ci-dessous pour publier votre annonce.</p>
            </div>

            <form action="/owner/add-property" method="POST" enctype="multipart/form-data" class="space-y-6" id="propertyForm">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Titre de l'annonce</label>
                        <input type="text" name="title" placeholder="Ex: Villa Duplex Cocody" required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Loyer Mensuel (FCFA)</label>
                        <input type="number" name="price" placeholder="500000" required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none">
                    </div>
                </div>

                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Commune</label>
                        <select name="commune" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none appearance-none">
                            <option value="Cocody">Cocody</option>
                            <option value="Yopougon">Yopougon</option>
                            <option value="Marcory">Marcory</option>
                            <option value="Plateau">Plateau</option>
                            <option value="Bingerville">Bingerville</option>
                        </select>
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Adresse Précise</label>
                        <input type="text" name="address" placeholder="Rue des Jardins..." required class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none">
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-4">
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Chambres</label>
                        <input type="number" name="bedrooms" placeholder="3" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Douches</label>
                        <input type="number" name="bathrooms" placeholder="2" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Surface (m²)</label>
                        <input type="number" name="surface" placeholder="120" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none">
                    </div>
                </div>

                <div>
                    <label class="text-xs font-bold text-slate-500 uppercase mb-2 block">Description Complète</label>
                    <textarea name="description" rows="4" class="w-full bg-[#0B1120] border border-slate-700 rounded-xl p-4 text-white focus:border-[#F59E0B] outline-none"></textarea>
                </div>

                <div>
                    <div class="flex justify-between items-end mb-2">
                        <label class="text-xs font-bold text-slate-500 uppercase block">Photos du bien</label>
                        <span id="counter" class="text-xs text-[#F59E0B] font-bold hidden">0 photo(s) sélectionnée(s)</span>
                    </div>
                    
                    <div class="border-2 border-dashed border-slate-700 bg-[#0B1120]/50 rounded-2xl p-4">
                        
                        <div id="previewGrid" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4 empty:hidden">
                            </div>

                        <label class="cursor-pointer group flex flex-col items-center justify-center p-6 border border-slate-700 border-dashed rounded-xl hover:bg-slate-800/50 hover:border-[#F59E0B] transition">
                            <div class="w-12 h-12 bg-slate-800 rounded-full flex items-center justify-center mb-2 group-hover:scale-110 transition">
                                <svg class="w-6 h-6 text-slate-400 group-hover:text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                            </div>
                            <span class="text-sm font-bold text-slate-400 group-hover:text-white">Ajouter des photos</span>
                            <span class="text-xs text-slate-600 mt-1">JPG, PNG - Max 5 Mo</span>
                            
                            <input type="file" id="imageInput" multiple accept="image/*" class="hidden">
                            <input type="file" name="images" id="finalInput" multiple class="hidden">
                        </label>
                    </div>
                </div>

                <button type="submit" class="w-full bg-[#F59E0B] hover:bg-yellow-400 text-[#0B1120] font-black py-4 rounded-xl shadow-lg transition transform hover:scale-[1.01]">
                    Publier le bien
                </button>
            </form>
        </div>
    </div>

    <script>
        // On utilise DataTransfer pour manipuler la liste des fichiers comme une base de données
        const dt = new DataTransfer();
        const inputSource = document.getElementById('imageInput'); // Celui sur lequel on clique
        const inputFinal = document.getElementById('finalInput');   // Celui qui part au serveur
        const previewGrid = document.getElementById('previewGrid');
        const counter = document.getElementById('counter');

        inputSource.addEventListener('change', function() {
            // Ajouter les nouveaux fichiers au DataTransfer existant
            for (let i = 0; i < this.files.length; i++) {
                const file = this.files[i];
                // Vérification basique anti-doublon (par nom)
                let isDuplicate = false;
                for (let j = 0; j < dt.files.length; j++) {
                    if (dt.files[j].name === file.name && dt.files[j].size === file.size) {
                        isDuplicate = true;
                        break;
                    }
                }
                if (!isDuplicate) {
                    dt.items.add(file);
                }
            }

            // Mettre à jour l'input final et l'affichage
            updateFiles();
            
            // Réinitialiser l'input source pour permettre de ré-ajouter le même fichier si on l'a supprimé
            this.value = '';
        });

        function updateFiles() {
            // 1. Synchroniser l'input final avec notre objet DataTransfer
            inputFinal.files = dt.files;

            // 2. Mettre à jour le compteur
            if (dt.files.length > 0) {
                counter.classList.remove('hidden');
                counter.innerText = `${dt.files.length} photo(s) prête(s) à l'envoi`;
            } else {
                counter.classList.add('hidden');
            }

            // 3. Régénérer la grille d'affichage
            previewGrid.innerHTML = '';
            
            for (let i = 0; i < dt.files.length; i++) {
                const file = dt.files[i];
                const reader = new FileReader();

                reader.onload = function(e) {
                    const div = document.createElement('div');
                    div.className = 'relative aspect-square rounded-xl overflow-hidden border border-slate-700 bg-black group thumb-animate';

                    // Image
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'w-full h-full object-cover opacity-80 group-hover:opacity-100 transition';
                    
                    // Bouton Supprimer (X)
                    const removeBtn = document.createElement('button');
                    removeBtn.innerHTML = '✕';
                    removeBtn.type = 'button'; // Important pour ne pas submit le form
                    removeBtn.className = 'absolute top-2 right-2 bg-red-500 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold hover:bg-red-600 shadow-lg transform hover:scale-110 transition';
                    
                    // Action de suppression
                    removeBtn.onclick = function() {
                        dt.items.remove(i); // Enlever du DataTransfer
                        updateFiles(); // Tout rafraîchir
                    };

                    div.appendChild(img);
                    div.appendChild(removeBtn);
                    previewGrid.appendChild(div);
                }
                reader.readAsDataURL(file);
            }
        }
    </script>

</body>
</html>
