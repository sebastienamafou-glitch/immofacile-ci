generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String               @id @default(cuid())
  email                String?              @unique
  phone                String?              @unique
  name                 String?
  password             String?
  image                String?
  emailVerified        DateTime?
  phoneVerified        DateTime?
  isVerified           Boolean              @default(false)
  role                 Role                 @default(UNASSIGNED)
  jobTitle             String?
  address              String?
  bio                  String?
  isAvailable          Boolean              @default(false)
  notifEmail           Boolean              @default(true)
  notifSms             Boolean              @default(true)
  isBacker             Boolean              @default(false)
  isPremium            Boolean              @default(false)
  backerTier           String?
  agencyId             String?
  isActive             Boolean              @default(true)
  lastMessageAt        DateTime             @default(now())
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  accounts             Account[]
  auditLogs            AuditLog[]
  bookings             Booking[]
  conversationsAsGuest Conversation[]       @relation("GuestConversations")
  conversationsAsHost  Conversation[]       @relation("HostConversations")
  incidentsAssigned    Incident[]           @relation("ArtisanIncidents")
  incidentsReported    Incident[]           @relation("IncidentReporter")
  investmentContracts  InvestmentContract[]
  leads                Lead[]
  leasesManaged        Lease[]              @relation("LeaseAgent")
  leases               Lease[]              @relation("LeaseTenant")
  listings             Listing[]
  sentMessages         Message[]
  missionsAccepted     Mission[]            @relation("AgentMissions")
  notifications        Notification[]
  payments             Payment[]
  propertiesManaged    Property[]           @relation("PropertyAgent")
  propertiesOwned      Property[]           @relation("PropertyOwner")
  quotesIssued         Quote[]
  reviews              Review[]
  sessions             Session[]
  signatureProofs      SignatureProof[]
  transactions         Transaction[]
  agency               Agency?              @relation(fields: [agencyId], references: [id])
  finance              UserFinance?
  kyc                  UserKYC?
  wishlists            Wishlist[]
  applications Application[]
  mandatesAsOwner  ManagementMandate[] @relation("MandatesAsOwner")
  propertiesForSale PropertyForSale[] @relation("UserPropertiesForSale")
  saleOffers        SaleOffer[]       @relation("UserSaleOffers")
}

model UserFinance {
  id              String   @id @default(cuid())
  userId          String   @unique
  walletBalance   Int      @default(0)
  escrowBalance   Int      @default(0)
  referralBalance Int      @default(0)
  kycTier         Int      @default(1)
  monthlyVolume   Int      @default(0)
  lastResetDate   DateTime @default(now())
  income          Int?
  paymentMethod   String?
  paymentNumber   String?
  version         Int      @default(0)
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserKYC {
  id              String             @id @default(cuid())
  userId          String             @unique
  status          VerificationStatus @default(PENDING)
  documents       String[]
  idType          String?
  idNumber        String?
  expiryDate      DateTime?
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?
  documentUrl     String?            // Stocke le lien Cloudinary de la CNI/Passeport
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Agency {
  id                    String              @id @default(cuid())
  name                  String              @unique
  code                  String              @unique
  slug                  String              @unique
  logoUrl               String?
  email                 String?
  phone                 String?
  primaryColor          String?             @default("#FF7900")
  taxId                 String?
  isActive              Boolean             @default(false)
  walletBalance         Int                 @default(0)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  defaultCommissionRate Float               @default(0.10)
  transactions          AgencyTransaction[]
  listings              Listing[]
  properties            Property[]
  mandates              ManagementMandate[]
  users                 User[]
}

model Application {
  id          String            @id @default(cuid())
  status      ApplicationStatus @default(PENDING)
  message     String?
  documents   String[]          // Pour stocker les URLs des fiches de paie/CNI spécifiques à ce dossier
  propertyId  String
  applicantId String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  property    Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  applicant   User              @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, applicantId]) // Un candidat ne peut postuler qu'une seule fois au même bien
  @@index([propertyId])
  @@index([applicantId])
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Property {
  id           String        @id @default(cuid())
  title        String
  description  String?
  address      String
  commune      String
  price        Int
  type         PropertyType
  bedrooms     Int
  bathrooms    Int
  surface      Float?
  images       String[]
  latitude     Float?
  longitude    Float?
  isPublished  Boolean       @default(true)
  isAvailable  Boolean       @default(true)
  views        Int           @default(0)
  ownerId      String
  agentId      String?
  agencyId     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  source       ListingSource @default(MANUAL)
  originalUrl  String?       @unique
  isClaimed    Boolean       @default(true)
  seoSlug      String?       @unique
  incidents    Incident[]
  inventories  Inventory[]
  leases       Lease[]
  listings     Listing[]
  missions     Mission[]
  agency       Agency?       @relation(fields: [agencyId], references: [id])
  agent        User?         @relation("PropertyAgent", fields: [agentId], references: [id])
  owner        User          @relation("PropertyOwner", fields: [ownerId], references: [id])
  transactions Transaction[]
  applications Application[]
  mandates     ManagementMandate[]


  @@index([commune])
  @@index([price])
  @@index([type])
  @@index([commune, price])
}

model Lease {
  id                   String           @id @default(cuid())
  startDate            DateTime
  endDate              DateTime?
  monthlyRent          Int
  depositAmount        Int
  advanceAmount        Int?
  status               LeaseStatus      @default(PENDING)
  isActive             Boolean          @default(false)
  contractUrl          String?
  documentHash         String?
  signatureStatus      SignatureStatus  @default(PENDING)
  tenantId             String
  propertyId           String
  agentId              String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  agencyCommissionRate Float?
  noticeGivenAt        DateTime?
  plannedDepartureDate DateTime?
  inventories          Inventory[]
  agent                User?            @relation("LeaseAgent", fields: [agentId], references: [id])
  property             Property         @relation(fields: [propertyId], references: [id])
  tenant               User             @relation("LeaseTenant", fields: [tenantId], references: [id])
  payments             Payment[]
  rentSchedules        RentSchedule[]
  signatures           SignatureProof[]
  tenantLeasingFee     Int              @default(0) // Part locataire
  ownerLeasingFee      Int              @default(0) // Part propriétaire prélevée sur l'avance

}

model RentSchedule {
  id           String     @id @default(cuid())
  expectedDate DateTime
  amount       Int
  status       RentStatus @default(PENDING)
  paidAt       DateTime?
  leaseId      String
  paymentId    String?    @unique
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lease        Lease      @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  payment      Payment?   @relation(fields: [paymentId], references: [id])

  @@index([leaseId])
  @@index([status, expectedDate])
}

model Inventory {
  id         String          @id @default(cuid())
  date       DateTime        @default(now())
  type       MissionType
  notes      String?
  reportUrl  String?
  leaseId    String
  propertyId String
  agentId    String?
  lease      Lease           @relation(fields: [leaseId], references: [id])
  property   Property        @relation(fields: [propertyId], references: [id])
  items      InventoryItem[]
}

model InventoryItem {
  id          String    @id @default(cuid())
  roomName    String
  element     String
  condition   String
  comment     String?
  photos      String[]
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
}

model SignatureProof {
  id            String   @id @default(cuid())
  ipAddress     String
  signedAt      DateTime @default(now())
  userAgent     String?
  signatureData String?
  otpToken      String?
  leaseId       String
  signerId      String
  documentType  String   @default("LEASE")
  lease         Lease    @relation(fields: [leaseId], references: [id])
  signer        User     @relation(fields: [signerId], references: [id])
}

model InvestmentContract {
  id               String           @id @default(cuid())
  signedAt         DateTime         @default(now())
  ipAddress        String
  userAgent        String?
  signatureData    String
  paymentReference String?          @unique
  status           InvestmentStatus @default(PENDING)
  roi              Decimal          @default(0)
  userId           String
  packName         InvestmentPack?
  amount           Int
  contractUrl      String?
  user             User             @relation(fields: [userId], references: [id])
}

model Listing {
  id             String         @id @default(cuid())
  title          String
  description    String
  pricePerNight  Int
  address        String
  city           String
  neighborhood   String?
  latitude       Float?
  longitude      Float?
  landmark       String?
  bedrooms       Int            @default(1)
  bathrooms      Int            @default(1)
  maxGuests      Int            @default(2)
  images         String[]
  amenities      Json
  accessVideoUrl String?
  isPublished    Boolean        @default(false)
  hostId         String
  agencyId       String?
  propertyId     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  source         ListingSource  @default(MANUAL)
  originalUrl    String?        @unique
  isClaimed      Boolean        @default(true)
  seoSlug        String?        @unique
  bookings       Booking[]
  conversations  Conversation[]
  agency         Agency?        @relation(fields: [agencyId], references: [id])
  host           User           @relation(fields: [hostId], references: [id])
  property       Property?      @relation(fields: [propertyId], references: [id])
  reviews        Review[]
  wishlists      Wishlist[]

  @@index([city])
  @@index([pricePerNight])
  @@index([city, pricePerNight])
}

model Booking {
  id         String          @id @default(cuid())
  startDate  DateTime
  endDate    DateTime
  totalPrice Int
  status     BookingStatus   @default(PENDING)
  guestId    String
  listingId  String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  guestCount Int             @default(1)
  guest      User            @relation(fields: [guestId], references: [id])
  listing    Listing         @relation(fields: [listingId], references: [id])
  payment    BookingPayment?

  @@unique([listingId, startDate])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  listingId String
  authorId  String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
}

model Payment {
  id                String           @id @default(cuid())
  amount            Int
  date              DateTime         @default(now())
  type              PaymentType
  status            PaymentStatus    @default(PENDING)
  method            PaymentProvider?
  reference         String?          @unique
  idempotencyKey    String?          @unique
  amountOwner       Int              @default(0)
  amountPlatform    Int              @default(0)
  amountAgent       Int              @default(0)
  amountAgency      Int              @default(0)
  platformTaxRate   Float            @default(0.18)
  platformTaxAmount Int              @default(0)
  providerResponse  Json?
  leaseId           String?
  quoteId           String?
  userId            String?
  lease             Lease?           @relation(fields: [leaseId], references: [id])
  quote             Quote?           @relation(fields: [quoteId], references: [id])
  user              User?            @relation(fields: [userId], references: [id])
  rentSchedule      RentSchedule?
}

model BookingPayment {
  id                 String          @id @default(cuid())
  amount             Int
  provider           PaymentProvider
  transactionId      String          @unique
  status             PaymentStatus   @default(PENDING)
  errorReason        String?
  agencyCommission   Int
  hostPayout         Int
  platformCommission Int             @default(0)
  bookingId          String          @unique
  createdAt          DateTime        @default(now())
  booking            Booking         @relation(fields: [bookingId], references: [id])

  @@index([status])
  @@index([createdAt])
}

model Transaction {
  id           String            @id @default(cuid())
  amount       Int
  type         TransactionType
  balanceType  BalanceType
  reason       String
  status       TransactionStatus @default(SUCCESS)
  reference    String?           @unique
  userId       String
  previousHash String?
  quoteId      String?
  incidentId   String?
  propertyId   String?
  createdAt    DateTime          @default(now())
  incident     Incident?         @relation(fields: [incidentId], references: [id])
  property     Property?         @relation(fields: [propertyId], references: [id])
  quote        Quote?            @relation(fields: [quoteId], references: [id])
  user         User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model AgencyTransaction {
  id        String   @id @default(cuid())
  amount    Int
  type      String
  reason    String
  status    String   @default("SUCCESS")
  agencyId  String
  createdAt DateTime @default(now())
  agency    Agency   @relation(fields: [agencyId], references: [id])
}

model Mission {
  id            String        @id @default(cuid())
  type          MissionType
  status        MissionStatus @default(PENDING)
  fee           Int
  dateScheduled DateTime?
  reportData    String?
  propertyId    String
  agentId       String?
  createdAt     DateTime      @default(now())
  agent         User?         @relation("AgentMissions", fields: [agentId], references: [id])
  property      Property      @relation(fields: [propertyId], references: [id])
}

model Incident {
  id           String           @id @default(cuid())
  title        String
  description  String
  priority     IncidentPriority @default(NORMAL)
  photos       String[]
  photosBefore String[]
  photosAfter  String[]
  status       IncidentStatus   @default(OPEN)
  quoteAmount  Int?
  finalCost    Int?
  reporterId   String
  assignedToId String?
  propertyId   String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  conversation Conversation?
  assignedTo   User?            @relation("ArtisanIncidents", fields: [assignedToId], references: [id])
  property     Property         @relation(fields: [propertyId], references: [id])
  reporter     User             @relation("IncidentReporter", fields: [reporterId], references: [id])
  quote        Quote?
  transactions Transaction[]
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  needs     String?
  budget    Int?
  status    String   @default("NEW")
  agentId   String?
  createdAt DateTime @default(now())
  agent     User?    @relation(fields: [agentId], references: [id])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Conversation {
  id            String    @id @default(cuid())
  guestId       String?
  hostId        String?
  listingId     String?
  incidentId    String?   @unique
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  guest         User?     @relation("GuestConversations", fields: [guestId], references: [id])
  host          User?     @relation("HostConversations", fields: [hostId], references: [id])
  incident      Incident? @relation(fields: [incidentId], references: [id])
  listing       Listing?  @relation(fields: [listingId], references: [id])
  messages      Message[]
}

model Message {
  id             String       @id @default(cuid())
  content        String
  isRead         Boolean      @default(false)
  conversationId String
  senderId       String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])
}

model Quote {
  id           String        @id @default(cuid())
  number       String        @unique
  status       QuoteStatus   @default(PENDING)
  totalNet     Int
  taxAmount    Int           @default(0)
  totalAmount  Int
  validityDate DateTime
  notes        String?
  incidentId   String        @unique
  artisanId    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  payments     Payment[]
  artisan      User          @relation(fields: [artisanId], references: [id])
  incident     Incident      @relation(fields: [incidentId], references: [id])
  items        QuoteItem[]
  transactions Transaction[]
}

model QuoteItem {
  id          String @id @default(cuid())
  description String
  quantity    Int    @default(1)
  unitPrice   Int
  total       Int
  quoteId     String
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("INFO")
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead])
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entityId   String?
  entityType String?
  userId     String?
  userEmail  String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())
  user       User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
}

model ProcessedWebhook {
  id          String   @id
  processedAt DateTime @default(now())

  @@index([processedAt])
}

enum IncidentPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum InvestmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  DEFAULTED
}

enum InvestmentPack {
  STARTER
  PREMIUM
  VIP
  INSTITUTIONAL
}

enum RentStatus {
  PENDING
  PAID
  LATE
  PARTIAL
}

enum AuditAction {
  PAYMENT_SUCCESS
  BOOKING_PAYMENT_SUCCESS
  CROWDFUNDING_SUCCESS
  PAYMENT_FAILED
  FRAUD_ATTEMPT
  KYC_VALIDATED
  KYC_REJECTED
  USER_DELETED
  NOTICE_GIVEN
  NOTICE_ACKNOWLEDGED
  DEPOSIT_REFUNDED
  PROPERTY_CREATED
  PROPERTY_UPDATED
  AGENCY_CREATED
  MISSION_CREATED
  MISSION_ACCEPTED
  LEASE_APPLICATION
  LEASE_SIGNED
  LEASE_TERMINATED
  LISTING_CREATED
  LISTING_UPDATED
  SECURITY_ALERT
}

enum TransactionType {
  CREDIT
  DEBIT
  REFUND
}

enum BalanceType {
  WALLET
  ESCROW
  REFERRAL
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
  PAID
}

enum Role {
  UNASSIGNED
  SUPER_ADMIN
  AGENCY_ADMIN
  ADMIN
  OWNER
  TENANT
  GUEST
  AGENT
  ARTISAN
  INVESTOR
  AMBASSADOR
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum SignatureStatus {
  PENDING
  SIGNED_TENANT
  SIGNED_OWNER
  COMPLETED
}

enum PropertyType {
  APPARTEMENT
  VILLA
  STUDIO
  MAGASIN
  BUREAU
  TERRAIN
}

enum LeaseStatus {
  PENDING
  ACTIVE
  IN_NOTICE
  TERMINATED
  CANCELLED
}

enum BookingStatus {
  PENDING
  PAID
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentType {
  LOYER
  DEPOSIT
  CHARGES
  FEE
  TOPUP
}

enum PaymentProvider {
  WAVE
  ORANGE_MONEY
  MTN_MOMO
  MOOV_MONEY
  STRIPE
  CASH
  CINETPAY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  QUOTATION
  RESOLVED
  CLOSED
}

enum MissionStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum MissionType {
  VISITE
  ETAT_DES_LIEUX_ENTREE
  ETAT_DES_LIEUX_SORTIE
  PHOTOS
}

enum ListingSource {
  MANUAL
  SCRAPER
  MAKE_COM
  API
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

enum MandateStatus {
  PENDING
  ACTIVE
  TERMINATED
}

model ManagementMandate {
  id              String          @id @default(cuid())
  commissionRate  Float           // ex: 8.0 pour 8% de frais de gestion
  startDate       DateTime        @default(now())
  endDate         DateTime?
  status          MandateStatus   @default(PENDING)
  signatureStatus SignatureStatus @default(PENDING) // Utilise ton Enum existant
  documentUrl     String?         // URL du PDF signé (Cloudinary/S3)

  // Relations
  propertyId      String
  property        Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  ownerId         String
  owner           User            @relation("MandatesAsOwner", fields: [ownerId], references: [id])

  agencyId        String
  agency          Agency          @relation(fields: [agencyId], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// ==========================================
// 🏗️ MODULE VENTE & FONCIER (ISOLÉ)
// ==========================================

// 1. Les statuts légaux spécifiques à la Côte d'Ivoire
enum IvorianLegalStatus {
  ACD                       // Arrêté de Concession Définitive (Sécurité Max)
  TITRE_FONCIER             // Titre Foncier classique
  CERTIFICAT_MOUCHETE       // Certificat de propriété
  ATTESTATION_VILLAGEOISE   // Risque élevé, nécessite approbation villageoise/ministérielle
  LETTRE_ATTRIBUTION
}

// 2. Le pipeline de la transaction immobilière
enum SaleTransactionStep {
  AVAILABLE                 // En vente
  OFFER_PENDING             // Offres en cours d'analyse
  OFFER_ACCEPTED            // Offre acceptée, attente notaire
  COMPROMIS_SIGNED          // Promesse de vente signée chez le notaire
  ACTE_AUTHENTIQUE_SIGNED   // Vente définitive actée
  CLOSED                    // Fonds débloqués, transaction terminée
  CANCELLED
}

// 3. Modèle du Bien en Vente (Terrain ou Maison)
model PropertyForSale {
  id              String              @id @default(cuid())
  ownerId         String              // Relation vers User (Le Vendeur)
  
  title           String
  description     String
  priceCfa        Decimal             @db.Decimal(15, 2) // Précision financière stricte
  surfaceArea     Float               // en m²
  location        String              // ex: "Cocody Angré, Abidjan"
  images          String[]           
  
  legalStatus     IvorianLegalStatus  // La garantie légale du terrain
  status          SaleTransactionStep @default(AVAILABLE)
  
  // Relations actives
  owner           User                @relation("UserPropertiesForSale", fields: [ownerId], references: [id])
  offers          SaleOffer[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

// 4. Modèle de l'Offre d'Achat (Nécessite le KYC de l'Acheteur)
model SaleOffer {
  id              String              @id @default(cuid())
  propertyId      String
  buyerId         String              // Relation vers User (L'Acheteur KYC Validé)
  
  amountCfa       Decimal             @db.Decimal(15, 2)
  status          QuoteStatus         @default(PENDING) // On réutilise l'enum existant
  
  property        PropertyForSale     @relation(fields: [propertyId], references: [id])
  buyer           User                @relation("UserSaleOffers", fields: [buyerId], references: [id])

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}
