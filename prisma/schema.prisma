// schema.prisma - VERSION COMPLÈTE CORRIGÉE (V3 + V4 Signature)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- MODÈLES UTILISATEURS ---

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String   @unique
  name      String?
  role      UserRole @default(TENANT)
  address   String?
  commune   String?
  password  String
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  
  // FINANCES
  walletBalance Int    @default(0)
  escrowBalance Int    @default(0)

  // RELATIONS PRINCIPALES
  properties        Property[]          @relation("OwnerProperties")
  managedProperties Property[]          @relation("AgentProperties")
  leasesAsTenant    Lease[]             @relation("TenantLeases")
  reportedIncidents Incident[]          @relation("Reporter")
  leads             Lead[]              @relation("AgentLeads")
  transactions      CreditTransaction[]
  withdrawals       Withdrawal[]       
  investments       Investment[]       
  
  // PROFILS SPÉCIFIQUES
  artisanProfile    Artisan?
  tenantProfile     TenantProfile?

  // RELATIONS SYSTÈME
  pushSubscriptions PushSubscription[]
  activityLogs      ActivityLog[]
}

enum UserRole {
  OWNER
  TENANT
  ADMIN
  AGENT
  INVESTOR
  ARTISAN 
}

// --- TRAÇABILITÉ DE L'ARGENT ---

model CreditTransaction {
  id          String   @id @default(cuid())
  amount      Int
  description String
  date        DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Withdrawal {
  id        String   @id @default(cuid())
  amount    Int
  details   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
}

// --- MODÈLE INVESTISSEMENT ---

model Investment {
  id          String   @id @default(cuid())
  amount      Int
  roiRate     Float
  duration    Int
  startDate   DateTime @default(now())
  status      String   @default("ACTIVE")
  projectName String
  investorId  String
  investor    User     @relation(fields: [investorId], references: [id])
  createdAt   DateTime @default(now())
}

// --- MODÈLES IMMOBILIERS ---

model Property {
  id          String   @id @default(cuid())
  title       String
  address     String
  commune     String
  bedrooms    Int      @default(0) 
  bathrooms   Int      @default(0) 
  surface     Float?   
  price       Int
  description String?
  latitude    Float?  @default(5.359952)
  longitude   Float?  @default(-4.008256)
  createdAt   DateTime @default(now())
  images      String[]

  ownerId     String
  owner       User     @relation("OwnerProperties", fields: [ownerId], references: [id])

  managedById String?
  manager     User?    @relation("AgentProperties", fields: [managedById], references: [id])

  leases      Lease[]
  incidents   Incident[]
  expenses    Expense[]
  candidates  Candidate[]
}

model Lease {
  id            String      @id @default(cuid())
  startDate     DateTime
  endDate       DateTime?
  depositAmount Int
  monthlyRent   Int
  status        LeaseStatus @default(PENDING_FEES)
  isActive      Boolean     @default(false)

  tenantId      String
  tenant        User      @relation("TenantLeases", fields: [tenantId], references: [id])

  propertyId    String
  property      Property  @relation(fields: [propertyId], references: [id])

  payments      Payment[]
  inventories   Inventory[]
  
  // Relation V4 Scellement
  signatureProof SignatureProof?
}

enum LeaseStatus {
  PENDING_FEES
  ACTIVE
  TERMINATED
}

// --- FINANCES, INCIDENTS ET ÉTAT DES LIEUX ---

model Payment {
  id        String      @id @default(cuid())
  amount    Int
  date      DateTime    @default(now())
  month     String?
  type      PaymentType @default(LOYER)
  leaseId   String
  lease     Lease       @relation(fields: [leaseId], references: [id])
}

enum PaymentType {
  LOYER
  FRAIS_DOSSIER
}

model Incident {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  createdAt   DateTime @default(now())
  
  reporterId  String
  reporter    User     @relation("Reporter", fields: [reporterId], references: [id])

  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])

  assignedToId String?
  assignedTo   Artisan? @relation(fields: [assignedToId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Int
  date        DateTime @default(now())
  category    String
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
}

model Inventory {
  id             String   @id @default(cuid())
  type           String
  date           DateTime @default(now())
  kitchenState   String?
  kitchenPhoto   String?
  livingState    String?
  livingPhoto    String?
  bathState      String?
  bathPhoto      String?
  generalComment String?
  leaseId        String
  lease          Lease    @relation(fields: [leaseId], references: [id])
}

// --- GESTION DES PROSPECTS ET CANDIDATS ---

model Lead {
  id          String   @id @default(cuid())
  name        String
  phone       String
  address     String?
  status      String   @default("NOUVEAU")
  createdAt   DateTime @default(now())
  agentId     String?
  agent       User?    @relation("AgentLeads", fields: [agentId], references: [id])
}

model Candidate {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String
  income      Int
  status      String   @default("PENDING")
  score       Int
  createdAt   DateTime @default(now())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
}

// --- MODÈLE ARTISAN ---

model Artisan {
  id          String   @id @default(uuid())
  name        String
  job         String
  phone       String
  location    String
  isVerified  Boolean  @default(true)
  rating      Float    @default(5.0)
  createdAt   DateTime @default(now())
  userId      String?  @unique
  user        User?    @relation(fields: [userId], references: [id])
  incidents   Incident[]
}

// --- SYSTÈME & LOGS ---

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  keys      Json
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  category    String
  metadata    Json?
  createdAt   DateTime @default(now())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
}

model TenantProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  idCardUrl     String?
  idCardStatus  String   @default("PENDING")
  extractedData Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- MODÈLE REGISTRE DE PREUVES DE SIGNATURE (V4) ---

model SignatureProof {
  id           String    @id @default(uuid())
  leaseId      String    @unique
  documentHash String    // Empreinte SHA-256 du bail
  ownerSigned  Boolean   @default(false)
  tenantSigned Boolean   @default(false)
  ownerOtp     String?   // Le code envoyé par SMS
  tenantOtp    String?
  ownerIp      String?
  tenantIp     String?
  signedAt     DateTime?
  lease        Lease     @relation(fields: [leaseId], references: [id])
}
